          <li><a href="https://music.apple.com/cl/artist/banda-bruna/1828449193" target="_blank" rel="noopener" class="hover:text-gold-bruna transition-colors">Apple Music</a></li>
          <li><a href="https://www.deezer.com/mx/artist/337478561" target="_blank" rel="noopener" class="hover:text-gold-bruna transition-colors">Deezer</a></li>
        </ul>
      </div>

      <!-- Booking / Info -->
      <div class="flex flex-col gap-4 text-left">
        <span class="font-title text-xs font-bold text-white tracking-widest uppercase">Contrataciones</span>
        <ul class="flex flex-col gap-2.5 text-xs list-none p-0">
          <li><strong>Jaime Cárdenas:</strong> <a href="tel:+56990021689" class="hover:text-gold-bruna transition-colors">+56 9 9002 1689</a></li>
