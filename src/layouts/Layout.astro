          <li><a href="/" class="hover:text-gold-bruna transition-colors">Inicio</a></li>
          <li><a href="/banda" class="hover:text-gold-bruna transition-colors">Banda</a></li>
          <li><a href="/integrantes" class="hover:text-gold-bruna transition-colors">Integrantes</a></li>
          <li><a href="/musica" class="hover:text-gold-bruna transition-colors">Música</a></li>
          <li><a href="/videos" class="hover:text-gold-bruna transition-colors">Videos</a></li>
          <li><a href="/agenda" class="hover:text-gold-bruna transition-colors">Agenda</a></li>
          <li><a href="/noticias" class="hover:text-gold-bruna transition-colors">Noticias</a></li>
