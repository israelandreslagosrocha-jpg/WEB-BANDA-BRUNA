---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Banda Bruna | Orquesta Oficial - Música en Vivo para Eventos y Festivales", 
  description = "Sitio oficial de Banda Bruna. Cumbia chilena y show en vivo para festivales, municipalidades, matrimonios y eventos corporativos." 
} = Astro.props;

const currentPath = Astro.url.pathname;

// Helper to determine active link styling
const getLinkClass = (path: string) => {
  const isActive = currentPath === path || currentPath === `${path}/` || (path !== '/' && currentPath.startsWith(path));
  return isActive 
    ? "text-gold-bruna font-extrabold border-b-2 border-gold-bruna pb-1 transition-all" 
    : "text-slate-300 hover:text-white pb-1 transition-all";
};
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
