      const comForm = document.getElementById('form-comentario-lanzamiento');
      const successMsg = document.getElementById('comentario-success-msg');
      const comentOtroBtn = document.getElementById('btn-comentar-otro');

      // Palabras no deseadas básicas
      const badWords = ['weon', 'culiao', 'conchadesumadre', 'ctm', 'wea', 'chucha', 'pico', 'tula', 'maraco', 'ql', 'culiazo', 'puta', 'mierda'];
      
      let currentIndex = 0;
      let autoPlayInterval;

      function initCarousel() {
        const track = document.getElementById('comentarios-muro-grid');
        const container = document.getElementById('carousel-container');
        const prevBtn = document.getElementById('btn-slide-prev');
        const nextBtn = document.getElementById('btn-slide-next');
        if (!track || !container) return;

        const items = track.querySelectorAll('.carousel-item');
        if (items.length <= 1) {
          if (prevBtn) prevBtn.style.display = 'none';
          if (nextBtn) nextBtn.style.display = 'none';
          return;
        } else {
          if (prevBtn) prevBtn.style.display = 'flex';
          if (nextBtn) nextBtn.style.display = 'flex';
        }

        // Limpiar intervalos previos
        if (autoPlayInterval) clearInterval(autoPlayInterval);
        currentIndex = 0;
        track.style.transform = `translateX(0px)`;

        function getVisibleWidth() {
          return container.clientWidth;
        }

        function getTrackWidth() {
          return track.scrollWidth;
        }

        function slideTo(index) {
          const itemWidth = items[0].clientWidth + 16; // ancho + gap
          const maxScroll = getTrackWidth() - getVisibleWidth();
          let newTranslate = -index * itemWidth;

          if (Math.abs(newTranslate) >= maxScroll) {
            newTranslate = -maxScroll;
            currentIndex = Math.ceil(maxScroll / itemWidth);
          }
          if (newTranslate > 0) {
            newTranslate = 0;
            currentIndex = 0;
          }

          track.style.transform = `translateX(${newTranslate}px)`;
        }

        if (nextBtn) {
          nextBtn.onclick = () => {
            const itemWidth = items[0].clientWidth + 16;
            const maxScroll = getTrackWidth() - getVisibleWidth();
            const currentScroll = currentIndex * itemWidth;
            if (currentScroll >= maxScroll) {
              currentIndex = 0;
            } else {
              currentIndex++;
            }
            slideTo(currentIndex);
          };
        }

        if (prevBtn) {
          prevBtn.onclick = () => {
            if (currentIndex <= 0) {
              const itemWidth = items[0].clientWidth + 16;
              const maxScroll = getTrackWidth() - getVisibleWidth();
              currentIndex = Math.ceil(maxScroll / itemWidth);
            } else {
              currentIndex--;
            }
            slideTo(currentIndex);
          };
        }

        // Auto-play suave cada 4 segundos
        autoPlayInterval = setInterval(() => {
          const itemWidth = items[0].clientWidth + 16;
          const maxScroll = getTrackWidth() - getVisibleWidth();
          const currentScroll = currentIndex * itemWidth;
          if (currentScroll >= maxScroll) {
            currentIndex = 0;
          } else {
            currentIndex++;
          }
          slideTo(currentIndex);
        }, 4000);

        // Detener autoplay en hover
        container.onmouseenter = () => clearInterval(autoPlayInterval);
        container.onmouseleave = () => {
          clearInterval(autoPlayInterval);
          autoPlayInterval = setInterval(() => {
            const itemWidth = items[0].clientWidth + 16;
            const maxScroll = getTrackWidth() - getVisibleWidth();
            const currentScroll = currentIndex * itemWidth;
            if (currentScroll >= maxScroll) {
              currentIndex = 0;
            } else {
              currentIndex++;
            }
            slideTo(currentIndex);
          }, 4000);
        };
      }

      function loadMuroComentarios() {
        if (!supabaseUrl || !supabaseKey || !muroGrid) return;
        fetch(`${supabaseUrl}/rest/v1/comentarios_lanzamientos?lanzamiento_slug=eq.${slug}&aprobado=eq.true&select=*&order=created_at.desc`, {
          headers: {
            'apikey': supabaseKey,
            'Authorization': `Bearer ${supabaseKey}`
          }
        })
        .then(res => res.json())
        .then(data => {
          if (!data || data.length === 0) {
            muroGrid.innerHTML = `<p class="text-xs text-slate-500 py-8 col-span-full uppercase font-bold tracking-widest font-title">¡Sé el primero en dejar tu buena vibra!</p>`;
            return;
          }
          muroGrid.innerHTML = data.map(com => {
            const estrellas = '★'.repeat(com.calificacion) + '☆'.repeat(5 - com.calificacion);
            const fecha = new Date(com.created_at).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' });
            return `
              <div class="carousel-item">
                <div class="bg-slate-900/60 border border-white/5 rounded-xl p-4 flex flex-col text-left gap-2 backdrop-blur-sm relative hover:border-gold-bruna/20 transition-all duration-300 h-full min-h-[110px]">
                  <div class="flex justify-between items-start">
                    <div class="min-w-0 flex-grow">
                      <h4 class="font-bold text-[11px] text-white uppercase tracking-wider truncate">${com.nombre}</h4>
                      ${com.ciudad ? `<span class="text-[8px] text-slate-500 font-bold uppercase truncate block mt-0.5">${com.ciudad}</span>` : ''}
                    </div>
                    <div class="text-gold-bruna text-[9px] tracking-wide font-mono shrink-0 pl-2">${estrellas}</div>
                  </div>
                  <p class="text-[11px] text-slate-300 leading-snug font-light line-clamp-3">${com.comentario}</p>
                  <span class="text-[7px] text-slate-600 uppercase font-mono mt-auto pt-1">${fecha}</span>
                </div>
              </div>
            `;
          }).join('');
          
          initCarousel();
        })
        .catch(err => {
          console.error("Error al cargar comentarios:", err);
          muroGrid.innerHTML = `<p class="text-xs text-red-400 py-6 col-span-full">Error al cargar el muro de opiniones.</p>`;
        });
      }

      // Inicializar estrellas interactiva
      starBtns.forEach(btn => {
        btn.classList.add('text-gold-bruna');

        btn.addEventListener('click', () => {
          const val = parseInt(btn.getAttribute('data-star-value') || '5');
          if (califInput) califInput.value = String(val);
          starBtns.forEach(b => {
            const bVal = parseInt(b.getAttribute('data-star-value') || '0');
            if (bVal <= val) {
              b.classList.remove('text-slate-650');
              b.classList.add('text-gold-bruna');
            } else {
              b.classList.remove('text-gold-bruna');
              b.classList.add('text-slate-650');
            }
          });
        });
      });

      // Envío de opiniones
      if (comForm) {
        comForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const nombre = document.getElementById('com-nombre').value.trim();
          const ciudad = document.getElementById('com-ciudad').value.trim();
          const calificacion = parseInt(califInput ? califInput.value : '5');
          const comentario = document.getElementById('com-contenido').value.trim();

          // Validar palabras groseras
          const lowerText = (nombre + ' ' + comentario).toLowerCase();
          const hasBadWord = badWords.some(word => lowerText.includes(word));
          if (hasBadWord) {
            alert('Por favor, mantén las buenas vibras en tus comentarios.');
            return;
          }

          const submitBtn = document.getElementById('btn-submit-comentario');
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Enviando...';
          }

          fetch(`${supabaseUrl}/rest/v1/comentarios_lanzamientos`, {
            method: 'POST',
            headers: {
              'apikey': supabaseKey,
              'Authorization': `Bearer ${supabaseKey}`,
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              nombre,
              ciudad: ciudad || null,
              comentario,
              calificacion,
              lanzamiento_slug: slug,
              aprobado: false // Moderación requerida
            })
          })
          .then(res => {
            if (!res.ok) throw new Error('Error al enviar opinión');
            return res;
          })
          .then(() => {
            comForm.reset();
            // Resetear estrellas a 5
            starBtns.forEach(b => {
              b.classList.remove('text-slate-650');
              b.classList.add('text-gold-bruna');
            });
            if (califInput) califInput.value = "5";
            
            comForm.classList.add('hidden');
            if (successMsg) successMsg.classList.remove('hidden');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Enviar Opinión';
            }
          })
          .catch(err => {
            console.error(err);
            alert('Error al enviar la opinión. Inténtalo de nuevo.');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Enviar Opinión';
            }
          });
        });
      }

      if (comentOtroBtn) {
        comentOtroBtn.addEventListener('click', () => {
          if (successMsg) successMsg.classList.add('hidden');
          if (comForm) comForm.classList.remove('hidden');
        });
      }

      // Carga inicial y auto-recarga cada 10 segundos
      loadMuroComentarios();
      setInterval(loadMuroComentarios, 10000);

      // COUNT UP ANIMATION LOGIC FOR STATISTICS
      function setupCountUp() {
        const counters = document.querySelectorAll('[data-count-target]');
        if (counters.length === 0) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const counter = entry.target;
              const target = parseFloat(counter.getAttribute('data-count-target'));
              const duration = 2000; // 2 seconds animation
              const startTime = performance.now();
              const prefix = counter.getAttribute('data-count-prefix') || '';
              const suffix = counter.getAttribute('data-count-suffix') || '';
              const isDecimal = counter.hasAttribute('data-count-decimal');

              function animate(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                
                // Easing function outQuad
                const easeProgress = progress * (2 - progress);
                
                let currentVal = easeProgress * target;
                
                if (isDecimal) {
                  counter.textContent = prefix + currentVal.toFixed(1).replace('.', ',') + suffix;
                } else {
                  counter.textContent = prefix + Math.floor(currentVal).toLocaleString('es-CL') + suffix;
                }

                if (progress < 1) {
                  requestAnimationFrame(animate);
                } else {
                  if (isDecimal) {
                    counter.textContent = prefix + target.toFixed(1).replace('.', ',') + suffix;
                  } else {
                    counter.textContent = prefix + target.toLocaleString('es-CL') + suffix;
                  }
                }
              }

              requestAnimationFrame(animate);
              observer.unobserve(counter);
            }
          });
        }, { threshold: 0.1 });

        counters.forEach(counter => {
          observer.observe(counter);
        });
      }

      // Hacer disponible globalmente para poder llamarla desde unlockMediaAndLinks
      window.setupCountUp = setupCountUp;

      // Si ya está desbloqueado de inicio, animar de inmediato
      if (initialDistance <= 0) {
        setupCountUp();
      }
    });
  </script>

