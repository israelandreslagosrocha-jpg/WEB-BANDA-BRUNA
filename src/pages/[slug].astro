      function unlockMediaAndLinks() {
        unlocked = true;

        // 1. Quitar overlay de video bloqueado
        if (lockedOverlay) {
          lockedOverlay.style.opacity = '0';
          setTimeout(() => lockedOverlay.style.display = 'none', 300);
        }

        // 2. Mostrar contenedor de pestañas
        if (mediaTabs) {
          mediaTabs.classList.remove('opacity-0', 'pointer-events-none', 'select-none');
          mediaTabs.classList.add('opacity-100');
        }

        // 3. Cargar video de youtube por defecto
        loadYoutube();

        // 4. Activar, brillar y cambiar texto en tarjetas de plataformas
        platformCards.forEach(card => {
          card.classList.remove('pointer-events-none', 'opacity-50');
          card.classList.add('glow-active'); // Activa animación de brillo y destello
          
          const plat = card.getAttribute('data-platform');
