  <!-- Countdown, lock, copy link & Youtube iframe Script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const root = document.getElementById('lanzamiento-root');
      if (!root) return;

      const launchDateStr = root.getAttribute('data-launch-date');
      const youtubeId = root.getAttribute('data-youtube-id');
      const instagramId = root.getAttribute('data-instagram-id');
      if (!launchDateStr) return;

      let launchDate = new Date(launchDateStr).getTime();

      // Consulta en tiempo real a Supabase para evitar desactualizaciones por SSG
      const supabaseUrl = root.getAttribute('data-supabase-url');
      const supabaseKey = root.getAttribute('data-supabase-key');
      const slug = root.getAttribute('data-slug') || 'ahogado-en-un-bar';

      if (supabaseUrl && supabaseKey) {
        fetch(`${supabaseUrl}/rest/v1/lanzamientos?slug=eq.${slug}&select=fecha_lanzamiento,plataformas_links`, {
          headers: {
            'apikey': supabaseKey,
            'Authorization': `Bearer ${supabaseKey}`
          }
        })
        .then(res => res.json())
        .then(data => {
          if (data && data.length > 0) {
            const item = data[0];
            
            // 1. Actualizar fecha de lanzamiento
            if (item.fecha_lanzamiento) {
              launchDate = new Date(item.fecha_lanzamiento).getTime();
              updateTimer();
            }
            
            // 2. Actualizar estadísticas de YouTube
            if (item.plataformas_links) {
              const views = item.plataformas_links.youtube_views;
              const likes = item.plataformas_links.youtube_likes;
              
              let updated = false;
              if (views !== undefined && views !== null) {
                const viewsEl = document.getElementById('yt-views-counter');
                if (viewsEl) {
                  viewsEl.setAttribute('data-count-target', views.toString());
                  updated = true;
                }
              }
              if (likes !== undefined && likes !== null) {
                const likesEl = document.getElementById('yt-likes-counter');
                if (likesEl) {
                  likesEl.setAttribute('data-count-target', likes.toString());
                  updated = true;
                }
              }
              
              // Si la fecha ya pasó y los contadores cambiaron, relanzar la animación
              if (updated && (launchDate - new Date().getTime() <= 0) && typeof window.setupCountUp === 'function') {
                window.setupCountUp();
              }
            }
          }
        })
        .catch(err => console.error("Error al obtener datos en tiempo real de Supabase:", err));
      }
      const badgeEstado = document.getElementById('badge-estado-lanzamiento');
      const countdownSection = document.getElementById('countdown-landing');
      
      const daysEl = document.getElementById('days');
      const hoursEl = document.getElementById('hours');
