---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../services/supabaseClient.js';
import { getNews } from '../services/socialApi.js';

export async function getStaticPaths() {
  try {
    const { data } = await supabase
      .from('lanzamientos')
      .select('slug')
      .eq('estado', 'publicado');

    if (data && data.length > 0) {
      return data.map((item: any) => ({
        params: { slug: item.slug }
      }));
    }
  } catch (err) {
    console.error("Error al generar getStaticPaths para lanzamientos:", err);
  }
  
  // Fallback para compilar sin errores en build
  return [
    { params: { slug: 'ahogado-en-un-bar' } }
  ];
}

const { slug } = Astro.params;

// Cargar datos de la campaña desde Supabase
let lanzamiento: any = null;
try {
  const { data, error } = await supabase
    .from('lanzamientos')
    .select('*')
    .eq('slug', slug)
    .single();

  if (data) {
    lanzamiento = data;
    if (lanzamiento.slug === 'ahogado-en-un-bar') {
      lanzamiento.imagen_desktop = 'https://res.cloudinary.com/dhgifjpkh/image/upload/v1783052331/compressed_BANDA_BRUNA_-_AHOGADO_EN_UN_BAR_mgwlvi.webp';
    }
  }
} catch (err) {
  console.error("Error al cargar detalles del lanzamiento:", err);
}

// Redirigir si no existe
if (!lanzamiento) {
  return Astro.redirect('/404');
}

// Cargar noticias relacionadas
const newsList = getNews();
const relatedNews = newsList.filter(news => {
  const slugMatch = news.slug && news.slug.includes(slug || '');
  const titleMatch = news.title && news.title.toLowerCase().includes(lanzamiento.nombre.toLowerCase());
  const summaryMatch = news.summary && news.summary.toLowerCase().includes(lanzamiento.nombre.toLowerCase());
  return slugMatch || titleMatch || summaryMatch;
});

// Extraer ID de YouTube
function getYouTubeId(url: string) {
  if (!url) return '';
  // Soportar shorts: youtube.com/shorts/ID
  if (url.includes('/shorts/')) {
    const parts = url.split('/shorts/');
    if (parts.length > 1) {
      return parts[1].split(/[?#&]/)[0];
    }
  }
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 12) ? match[2].substring(0, 11) : (match && match[2].length === 11) ? match[2] : '';
}

const youtubeId = getYouTubeId(lanzamiento.plataformas_links?.youtube || '');
const hasYoutube = !!youtubeId;
const youtubeViews = lanzamiento.plataformas_links?.youtube_views || (lanzamiento.slug === 'ahogado-en-un-bar' ? 14087 : 0);
const youtubeLikes = lanzamiento.plataformas_links?.youtube_likes || (lanzamiento.slug === 'ahogado-en-un-bar' ? 218 : 0);

// Extraer ID de Instagram
function getInstagramId(url: string) {
  if (!url) return '';
  const match = url.match(/\/p\/([a-zA-Z0-9_-]+)/);
  return match ? match[1] : '';
}

const instagramLink = lanzamiento.plataformas_links?.instagram || '';
const instagramId = getInstagramId(instagramLink);

// Determinar si el lanzamiento ya se encuentra disponible (para renderizar de inmediato)
const isReleased = lanzamiento.fecha_lanzamiento ? new Date(lanzamiento.fecha_lanzamiento).getTime() <= Date.now() : false;

// SEO Variables
const pageTitle = lanzamiento.meta_title || `${lanzamiento.titulo} - Banda Bruna | Próximo Estreno`;
const pageDescription = lanzamiento.meta_description || lanzamiento.descripcion;
const keywords = lanzamiento.keywords || 'banda bruna, lanzamiento musical, cumbia';
const shareImage = lanzamiento.imagen_compartir || lanzamiento.imagen_desktop;
const canonicalUrl = `https://bandabruna.cl/${lanzamiento.slug}`;

// Generar JSON-LD
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://bandabruna.cl"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": lanzamiento.nombre,
      "item": canonicalUrl
    }
  ]
};

const musicRecordingSchema = {
  "@context": "https://schema.org",
  "@type": "MusicRecording",
  "name": lanzamiento.nombre,
  "byArtist": {
    "@type": "MusicGroup",
    "name": "Banda Bruna",
    "url": "https://bandabruna.cl"
  },
  "datePublished": lanzamiento.fecha_lanzamiento,
  "description": lanzamiento.descripcion,
  "genre": "Cumbia / Tropical",
  "image": lanzamiento.imagen_desktop
};

const videoSchema = hasYoutube ? {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": `${lanzamiento.titulo} - Videoclip Oficial`,
  "description": lanzamiento.descripcion,
  "thumbnailUrl": [lanzamiento.imagen_desktop],
  "uploadDate": lanzamiento.fecha_lanzamiento,
  "embedUrl": `https://www.youtube.com/embed/${youtubeId}`
} : null;

// Combinar videos de backstage con publicaciones de Instagram relacionadas para "Ahogado en un Bar"
const instagramReels = (slug === 'ahogado-en-un-bar') ? [
  {
    url: "https://www.youtube.com/watch?v=nzPlTQTNkug",
    thumbnail: "https://img.youtube.com/vi/nzPlTQTNkug/0.jpg",
    caption: "Detrás de cámaras del videoclip Ahogado en un Bar realizado por Agencia CK 🎬",
    tipo: "youtube",
    aspect: "horizontal"
  },
  {
    url: "https://www.instagram.com/p/DaY5-_YCctx/",
    thumbnail: lanzamiento?.imagen_desktop || "/assets/images/instagram/reel_cover.webp",
    caption: "¡Video oficial del lanzamiento! Ya disponible en Instagram. 📸",
    tipo: "instagram",
    aspect: "vertical"
  },
  {
    url: "https://www.instagram.com/p/DZkqDn1uNpC/",
    thumbnail: "/assets/images/instagram/segunda_publicacion.webp",
    caption: "Próximamente en todas nuestras plataformas..! 🎸 BANDA BRUNA BB!! 🎶",
    tipo: "instagram",
    aspect: "vertical"
  },
  {
    url: "https://www.instagram.com/p/DZpvNd-uBjx/",
    thumbnail: "/assets/images/instagram/reel_cover.webp",
    caption: "Un pequeño resumen del proceso de grabación de nuestro nuevo videoclip junto a nuestros queridos amigos de Agencia CK 🎬",
    tipo: "instagram",
    aspect: "vertical"
  }
] : [];

const allDetrasCamaras = [
  ...(lanzamiento.detras_camaras_videos || []),
  ...instagramReels
];
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
>
  <!-- SEO Tags in Head slot -->
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta name="keywords" content={keywords} />
    <meta property="og:type" content="music.song" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={shareImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(musicRecordingSchema)}></script>
    {videoSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(videoSchema)}></script>}
  </Fragment>

  <div 
    class="min-h-screen text-white pb-20 relative overflow-hidden" 
    style={`background-color: ${lanzamiento.color_secundario || '#0d0a0a'}`}
    id="lanzamiento-root"
    data-launch-date={lanzamiento.fecha_lanzamiento}
    data-youtube-id={youtubeId}
    data-instagram-id={instagramId}
    data-supabase-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-supabase-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    data-slug={lanzamiento.slug}
  >
    <!-- Background blurred ambient glow -->
    <div class="absolute inset-0 pointer-events-none z-0">
      <div 
        class="absolute -top-40 left-1/4 w-[500px] h-[500px] rounded-full blur-[150px] opacity-20"
        style={`background-color: ${lanzamiento.color_principal}`}
      ></div>
      <div 
        class="absolute top-1/2 right-1/4 w-[400px] h-[400px] rounded-full blur-[120px] opacity-15"
        style={`background-color: ${lanzamiento.color_principal}`}
      ></div>
    </div>

    <!-- 1. HERO SECTION & EXPECTACIÓN -->
    <section class="relative pt-32 pb-16 md:py-24 z-10 px-6 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center min-h-[85vh]">
      <!-- Left side: Text info & Expectation -->
      <div class="lg:col-span-7 text-left flex flex-col gap-6">
        <div class="flex items-center gap-3">
          <span 
            class="text-[10px] font-extrabold tracking-widest px-3 py-1 rounded-sm uppercase font-title"
            style={`background-color: ${lanzamiento.color_principal}`}
          >
            {lanzamiento.tipo === 'videoclip' ? 'Videoclip Oficial' : lanzamiento.tipo === 'album' ? 'Nuevo Álbum' : 'Nuevo Sencillo'}
          </span>
          <span 
            id="badge-estado-lanzamiento" 
            class="text-xs font-bold tracking-wider uppercase font-title text-gold-bruna animate-pulse"
          >
            PRÓXIMO ESTRENO
          </span>
        </div>

        <h1 class="text-4xl md:text-6xl font-extrabold font-title uppercase tracking-wide leading-none">
          {lanzamiento.titulo}
        </h1>

        {lanzamiento.subtitulo && (
          <h2 class="text-lg md:text-xl font-medium text-slate-300 font-title italic tracking-wide">
            {lanzamiento.subtitulo}
          </h2>
        )}

        <div class="h-[1px] w-24 bg-white/20"></div>

        <p class="text-base text-slate-300 font-light leading-relaxed max-w-2xl">
          <strong class="text-white font-medium block text-lg mb-2">{lanzamiento.bold_text}</strong>
          {lanzamiento.descripcion}
        </p>

        <!-- Countdown / Ya disponible block -->
        <div class="mt-4 flex flex-col gap-4">
          <!-- Countdown Timer -->
          <div id="countdown-landing" class="flex flex-col gap-2">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Cuenta Regresiva para el Estreno</span>
            <div class="flex items-center gap-4">
              <div class="flex flex-col items-center bg-black/40 border border-white/5 rounded-xl px-4 py-3 min-w-16 md:min-w-20 backdrop-blur-md">
                <span id="days" class="text-2xl md:text-4xl font-extrabold text-white font-mono leading-none">00</span>
                <span class="text-[8px] md:text-[9px] text-slate-500 uppercase tracking-widest font-bold mt-1.5">Días</span>
              </div>
              <div class="flex flex-col items-center bg-black/40 border border-white/5 rounded-xl px-4 py-3 min-w-16 md:min-w-20 backdrop-blur-md">
                <span id="hours" class="text-2xl md:text-4xl font-extrabold text-white font-mono leading-none">00</span>
                <span class="text-[8px] md:text-[9px] text-slate-500 uppercase tracking-widest font-bold mt-1.5">Horas</span>
              </div>
              <div class="flex flex-col items-center bg-black/40 border border-white/5 rounded-xl px-4 py-3 min-w-16 md:min-w-20 backdrop-blur-md">
                <span id="minutes" class="text-2xl md:text-4xl font-extrabold text-white font-mono leading-none">00</span>
                <span class="text-[8px] md:text-[9px] text-slate-500 uppercase tracking-widest font-bold mt-1.5">Minutos</span>
              </div>
              <div class="flex flex-col items-center bg-black/40 border border-white/5 rounded-xl px-4 py-3 min-w-16 md:min-w-20 backdrop-blur-md">
                <span id="seconds" class="text-2xl md:text-4xl font-extrabold font-mono leading-none" style={`color: ${lanzamiento.color_principal}`}>00</span>
                <span class="text-[8px] md:text-[9px] text-slate-500 uppercase tracking-widest font-bold mt-1.5">Segundos</span>
              </div>
            </div>
          </div>

          <!-- Share section -->
          <div class="flex flex-col gap-2 mt-4 text-left">
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Comparte este lanzamiento</span>
            <div class="flex flex-wrap gap-2">
              <a 
                href={`https://api.whatsapp.com/send?text=¡Mira el próximo lanzamiento de Banda Bruna! ${encodeURIComponent(canonicalUrl)}`} 
                target="_blank" 
                rel="noopener" 
                class="bg-[#128c7e]/20 border border-[#128c7e]/30 hover:bg-[#128c7e]/30 hover:border-[#128c7e]/50 text-white text-[10px] font-bold py-2 px-4 rounded transition-colors flex items-center gap-2"
              >
                🟢 WHATSAPP
              </a>
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`} 
                target="_blank" 
                rel="noopener" 
                class="bg-[#3b5998]/20 border border-[#3b5998]/30 hover:bg-[#3b5998]/30 hover:border-[#3b5998]/50 text-white text-[10px] font-bold py-2 px-4 rounded transition-colors flex items-center gap-2"
              >
                🔵 FACEBOOK
              </a>
              <button 
                id="btn-copy-link" 
                class="bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 text-white text-[10px] font-bold py-2 px-4 rounded transition-all cursor-pointer flex items-center gap-2"
              >
                🔗 COPIAR ENLACE
              </button>
            </div>
            <span id="copy-toast" class="text-[10px] text-green-400 font-bold opacity-0 transition-opacity duration-300">¡Enlace copiado al portapapeles!</span>
          </div>
        </div>
      </div>

      <!-- Right side: Video player / Cover graphic -->
      <div class="lg:col-span-5 w-full flex flex-col gap-3 relative">
        <!-- Selector de Video (Pestañas) - Solo visible cuando está desbloqueado -->
        {(instagramId || slug === 'ahogado-en-un-bar') && (
          <div 
            id="media-tabs" 
            class="flex flex-wrap justify-start gap-2 opacity-0 pointer-events-none select-none transition-all duration-500 z-20"
          >
            <button 
              id="btn-play-youtube" 
              class="px-4 py-2 rounded-xl text-[10px] font-extrabold uppercase tracking-widest bg-red-600/20 text-red-300 border border-red-500/40 transition-all cursor-pointer flex items-center gap-2 shadow-lg shadow-black/40 ring-1 ring-white/10"
            >
              <span class="text-xs">📹</span> Ver Videoclip
            </button>
            {instagramId && (
              <button 
                id="btn-play-instagram" 
                class="px-4 py-2 rounded-xl text-[10px] font-extrabold uppercase tracking-widest bg-slate-900/50 text-slate-400 border border-white/5 hover:bg-slate-900/80 hover:text-white transition-all cursor-pointer flex items-center gap-2 shadow-lg shadow-black/40 ring-1 ring-white/5"
              >
                <span class="text-xs">📸</span> Ver Instagram
              </button>
            )}
            {slug === 'ahogado-en-un-bar' && (
              <button 
                id="btn-play-backstage-ck" 
                class="px-4 py-2 rounded-xl text-[10px] font-extrabold uppercase tracking-widest bg-slate-900/50 text-slate-400 border border-white/5 hover:bg-slate-900/80 hover:text-white transition-all cursor-pointer flex items-center gap-2 shadow-lg shadow-black/40 ring-1 ring-white/5"
              >
                <span class="text-xs">🎬</span> Detrás de Cámaras
              </button>
            )}
          </div>
        )}
        
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60 z-10 rounded-2xl pointer-events-none"></div>
          
          <!-- Video/Image Display Container -->
          <div id="media-frame" class="w-full aspect-video bg-slate-950 border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-black/80 relative flex items-center justify-center">
          <!-- Cover Image -->
          <img 
            id="cover-media" 
            src={lanzamiento.imagen_desktop} 
            alt={lanzamiento.nombre} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
          />
          
          <!-- Locked overlay for video -->
          <div 
            id="locked-video-overlay" 
            class="absolute inset-0 bg-black/60 backdrop-blur-sm z-20 flex flex-col items-center justify-center gap-3 p-6 text-center"
          >
            <div class="w-16 h-16 rounded-full border border-white/20 bg-white/5 flex items-center justify-center text-2xl text-slate-355">
              🔒
            </div>
          </div>
        </div>

        <!-- INDICADORES DINÁMICOS DE YOUTUBE -->
        {hasYoutube && (
          <div 
            id="youtube-stats-indicators" 
            class={`grid grid-cols-2 gap-4 mt-2 ${isReleased ? '' : 'hidden opacity-0 transition-all duration-500'}`}
          >
            <!-- Reproducciones -->
            <div class="flex flex-col items-center bg-slate-900/40 border border-white/5 rounded-2xl py-4 px-3 backdrop-blur-md transition-all hover:scale-102 hover:border-gold-bruna/20 duration-300">
              <div class="w-8 h-8 rounded-full bg-slate-950 border border-white/5 flex items-center justify-center text-gold-bruna mb-2 shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              </div>
              <span id="yt-views-counter" class="text-xl md:text-2xl font-extrabold font-title text-white block mb-0.5" data-count-target={youtubeViews}>0</span>
              <span class="text-[8px] text-slate-400 font-bold uppercase tracking-wider block text-center leading-snug">Visualizaciones YouTube</span>
            </div>

            <!-- Likes -->
            <div class="flex flex-col items-center bg-slate-900/40 border border-white/5 rounded-2xl py-4 px-3 backdrop-blur-md transition-all hover:scale-102 hover:border-gold-bruna/20 duration-300">
              <div class="w-8 h-8 rounded-full bg-slate-950 border border-white/5 flex items-center justify-center text-gold-bruna mb-2 shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>
              </div>
              <span id="yt-likes-counter" class="text-xl md:text-2xl font-extrabold font-title text-white block mb-0.5" data-count-target={youtubeLikes}>0</span>
              <span class="text-[8px] text-slate-400 font-bold uppercase tracking-wider block text-center leading-snug">Me Gusta YouTube</span>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- 1.5 SECCIÓN DE OPINIONES (CARRUSEL Y FORMULARIO COMPACTO) -->
    <section class="relative z-10 px-6 max-w-7xl mx-auto py-12 border-t border-white/5" id="opinions-section">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        
        <!-- Formulario Compacto (4 columnas en lg) -->
        <div class="lg:col-span-4 bg-slate-900/40 border border-white/5 rounded-2xl p-5 md:p-6 text-left backdrop-blur-md relative h-full flex flex-col justify-center">
          <h3 class="font-title font-extrabold text-sm text-white uppercase tracking-wider mb-1">
            ¿Qué te pareció el lanzamiento?
          </h3>
          <p class="text-[9px] text-slate-455 uppercase tracking-widest font-bold mb-4">Comenta qué te pareció el videoclip y el single</p>
          
          <form id="form-comentario-lanzamiento" class="flex flex-col gap-3">
            <div class="flex flex-col gap-1">
              <label for="com-nombre" class="text-[8px] font-bold text-slate-400 uppercase tracking-wider">Nombre / Apodo</label>
              <div class="flex gap-2 items-center">
                <input type="text" id="com-nombre" required placeholder="ej: Juan" class="flex-grow bg-slate-950 border border-white/5 rounded-lg p-2 text-white text-[11px] outline-none focus:border-gold-bruna/40 transition-colors" />
                
                <!-- Selector minimalista de estrellas -->
                <div class="flex items-center gap-0.5 shrink-0 bg-slate-950 border border-white/5 px-2 py-1.5 rounded-lg" id="stars-selector">
                  <button type="button" data-star-value="1" class="star-btn text-xs text-slate-650 hover:scale-110 transition-transform focus:outline-none cursor-pointer">★</button>
                  <button type="button" data-star-value="2" class="star-btn text-xs text-slate-650 hover:scale-110 transition-transform focus:outline-none cursor-pointer">★</button>
                  <button type="button" data-star-value="3" class="star-btn text-xs text-slate-650 hover:scale-110 transition-transform focus:outline-none cursor-pointer">★</button>
                  <button type="button" data-star-value="4" class="star-btn text-xs text-slate-650 hover:scale-110 transition-transform focus:outline-none cursor-pointer">★</button>
                  <button type="button" data-star-value="5" class="star-btn text-xs text-slate-650 hover:scale-110 transition-transform focus:outline-none cursor-pointer">★</button>
                  <input type="hidden" id="com-calificacion" value="5" />
                </div>
              </div>
            </div>

            <div class="flex flex-col gap-1">
              <div class="flex justify-between items-center">
                <label for="com-contenido" class="text-[8px] font-bold text-slate-400 uppercase tracking-wider">Opinión</label>
                <input type="text" id="com-ciudad" placeholder="Ciudad (opcional)" class="bg-transparent text-right text-slate-500 text-[9px] outline-none focus:text-gold-bruna transition-colors border-none p-0 w-24" />
              </div>
              <textarea id="com-contenido" required rows="2" placeholder="¡Escribe tus buenas vibras aquí!..." class="bg-slate-950 border border-white/5 rounded-lg p-2 text-white text-[11px] outline-none resize-none focus:border-gold-bruna/40 transition-colors"></textarea>
            </div>

            <button type="submit" id="btn-submit-comentario" class="bg-gradient-to-r from-gold-bruna/80 to-gold-bruna text-black text-[10px] font-bold py-2.5 px-4 rounded-lg uppercase tracking-widest hover:scale-[1.01] active:scale-[0.99] transition-all cursor-pointer text-center">
              Enviar Opinión
            </button>
          </form>
          
          <div id="comentario-success-msg" class="hidden text-center py-6">
            <div class="w-8 h-8 rounded-full bg-green-500/10 text-green-400 flex items-center justify-center text-sm mx-auto mb-2 font-bold">✓</div>
            <p class="text-xs text-slate-200 font-bold uppercase tracking-wider">¡Opinión enviada!</p>
            <p class="text-[9px] text-slate-400 mt-1">Aparecerá tras ser moderada.</p>
            <button id="btn-comentar-otro" class="text-[8px] text-gold-bruna hover:underline uppercase tracking-wider mt-4 cursor-pointer">Opinar otra vez</button>
          </div>
        </div>

