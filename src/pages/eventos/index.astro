---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../services/supabaseClient.js';

// Cargar estadísticas o información básica si es necesario
// Las tarjetas de eventos se configurarán de forma estática pero apuntando a sus rutas SEO
const eventCategories = [
  {
    id: "fiestas-patrias",
    title: "Fiestas Patrias 2026",
    description: "El show de cumbia chilena más prendido para fondas, ramadas y eventos municipales de Fiestas Patrias.",
    image: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1781892646/compressed_Proyecto-nuevo_e1myjx.webp",
    url: "/eventos/fiestas-patrias",
    cta: "Ver Propuesta Festiva"
  },
  {
    id: "municipalidades",
    title: "Municipalidades",
    description: "Show familiar y masivo ideal para plazas de armas, veranos alegres, ferias costumbristas y shows públicos.",
    image: "/assets/images/hero/hero_3.webp",
    url: "/eventos/municipalidades",
    cta: "Ver Detalles"
  },
  {
    id: "eventos-corporativos",
    title: "Eventos Corporativos",
    description: "Música en vivo para cenas anuales, aniversarios de empresas, lanzamientos de marca y fiestas de fin de año.",
    image: "/assets/images/hero/hero_4.webp",
    url: "/eventos/eventos-corporativos",
    cta: "Ver Detalles"
  },
  {
    id: "eventos-privados",
    title: "Eventos Privados",
    description: "Cumpleaños, fiestas de gala y celebraciones exclusivas con la mejor energía y repertorio bailable.",
    image: "/assets/images/experiencia/experiencia_1.webp",
    url: "/eventos/eventos-privados",
    cta: "Ver Detalles"
  },
  {
    id: "aniversarios",
    title: "Aniversarios",
    description: "Shows en vivo a medida para aniversarios comunales, de clubes, gremios y organizaciones en todo el país.",
    image: "/assets/images/experiencia/experiencia_2.webp",
    url: "/eventos/aniversarios",
    cta: "Ver Detalles"
  },
  {
    id: "festivales",
    title: "Festivales",
    description: "Puesta en escena impactante para festivales de música, eventos masivos regionales e interregionales.",
    image: "/assets/images/hero/hero_1.webp",
    url: "/eventos/festivales",
    cta: "Ver Detalles"
  },
  {
    id: "colegios-universidades",
    title: "Colegios y Ues",
    description: "Fiestas de graduación, aniversarios estudiantiles, semanas universitarias y festivales juveniles.",
    image: "/assets/images/experiencia/experiencia_3.webp",
    url: "/eventos/colegios-universidades",
    cta: "Ver Detalles"
  },
  {
    id: "matrimonios",
    title: "Matrimonios",
    description: "Boda de ensueño con música en vivo desde el cóctel hasta el show bailable principal que hará saltar a todos.",
    image: "/assets/images/experiencia/experiencia_4.webp",
    url: "/eventos/matrimonios",
    cta: "Ver Detalles"
  },
  {
    id: "producciones-medios",
    title: "Producciones y Medios",
    description: "Participación en transmisiones en vivo, shows televisivos, grabaciones radiales y festivales de medios de comunicación.",
    image: "/assets/images/experiencia/experiencia_5.webp",
    url: "/eventos/producciones-medios",
    cta: "Ver Detalles"
  }
];
---

<Layout 
  title="Eventos y Contrataciones | Banda Bruna - Orquesta y Show en Vivo" 
  description="Contrata a Banda Bruna para municipalidades, festivales, empresas, matrimonios y fiestas patrias en todo Chile. Cotiza tu evento con la mejor cumbia."
>
  <!-- SEO Breadcrumbs Structured Data -->
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://bandabruna.cl/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Eventos",
          "item": "https://bandabruna.cl/eventos/"
        }
      ]
    }
  </script>

  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center bg-black overflow-hidden py-20 px-6 border-b border-white/5">
    <!-- Background glow and grid -->
    <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(9,21,53,0.6)_0%,rgba(4,8,21,1)_80%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] z-0"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center scroll-reveal">
      <span class="text-gold-bruna text-xs md:text-sm tracking-[0.3em] font-extrabold uppercase block mb-3">
        BOOKING OFICIAL CHILE
      </span>
      <h1 class="text-4xl md:text-6xl font-black font-title text-white tracking-tight uppercase leading-tight mb-6">
        EVENTOS Y <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-bruna via-amber-400 to-gold-bruna-hover">CONTRATACIONES</span>
      </h1>
      <p class="text-sm md:text-lg text-slate-300 font-light leading-relaxed max-w-2xl mx-auto mb-10">
        Presentaciones profesionales para municipalidades, empresas, fiestas patrias, eventos privados, festivales y celebraciones en todo Chile.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="#cotizar-section" 
          class="w-full sm:w-auto bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black px-8 py-3.5 rounded-sm font-extrabold text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-lg shadow-gold-bruna/20 cursor-pointer"
        >
          SOLICITAR COTIZACIÓN
        </a>
        <a 
          href="/agenda" 
          class="w-full sm:w-auto border border-white/10 hover:border-gold-bruna text-white hover:text-gold-bruna px-8 py-3.5 rounded-sm font-extrabold text-xs uppercase tracking-widest hover:scale-105 transition-all bg-black/40 cursor-pointer"
        >
          VER DISPONIBILIDAD
        </a>
      </div>
    </div>
  </section>

  <!-- Categories Grid Section -->
  <section class="max-w-[1400px] mx-auto px-6 py-20">
    <div class="text-center mb-16 scroll-reveal">
      <span class="text-gold-bruna text-xs tracking-[0.2em] font-bold uppercase block mb-1">CATEGORÍAS</span>
      <h2 class="text-3xl md:text-4xl font-extrabold font-title uppercase text-white">Nuestros Espectáculos</h2>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
      <p class="text-xs md:text-sm text-slate-400 font-light max-w-md mx-auto mt-3">
        Selecciona el tipo de evento para conocer nuestra propuesta comercial y técnica.
      </p>
    </div>

    <!-- Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {eventCategories.map((cat, idx) => (
        <div class="scroll-reveal group" style={`transition-delay: ${idx * 50}ms`}>
          <div class="relative h-[320px] rounded-xl overflow-hidden bg-slate-900 border border-white/5 shadow-xl group-hover:border-gold-bruna/45 group-hover:shadow-gold-bruna/5 transition-all duration-500 flex flex-col justify-end p-6">
            
            <!-- Background Image with Overlay -->
            <div class="absolute inset-0 z-0">
              <img 
                src={cat.image} 
                alt={`Banda Bruna - ${cat.title}`} 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-40 group-hover:opacity-50"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent z-1"></div>
            </div>

            <!-- Card Info -->
            <div class="relative z-10 flex flex-col text-left">
              <span class="text-[10px] text-gold-bruna font-extrabold tracking-widest uppercase mb-1 font-title">
                {cat.id === "fiestas-patrias" ? "★ Recomendado ★" : "Contratación"}
              </span>
              <h3 class="text-xl font-bold font-title text-white uppercase mb-2 group-hover:text-gold-bruna transition-colors">
                {cat.title}
              </h3>
              <p class="text-xs text-slate-300 font-light leading-relaxed mb-5 min-h-[48px]">
                {cat.description}
              </p>
              
              <!-- CTA Button inside Card -->
              <a 
                href={cat.url} 
                class="self-start inline-flex items-center gap-1.5 text-[11px] font-bold text-white group-hover:text-gold-bruna tracking-wider uppercase transition-colors"
              >
                {cat.cta}
                <span class="text-xs transition-transform group-hover:translate-x-1 duration-300">➔</span>
              </a>
            </div>
            
            <!-- Bottom decorative line -->
            <div class="absolute bottom-0 left-0 w-0 h-[3px] bg-gradient-to-r from-gold-bruna to-amber-500 group-hover:w-full transition-all duration-500"></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Quote Form Section -->
  <section id="cotizar-section" class="border-t border-white/5 bg-[#030612] py-20 px-6">
    <div class="max-w-4xl mx-auto">
      
      <div class="text-center mb-12 scroll-reveal">
        <span class="text-gold-bruna text-xs tracking-[0.25em] font-extrabold uppercase block mb-1">
          FORMULARIO DE RESERVAS
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold font-title uppercase text-white">
          SOLICITA TU COTIZACIÓN
        </h2>
        <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
        <p class="text-xs md:text-sm text-slate-400 font-light mt-3 max-w-lg mx-auto">
          Completa el formulario y te enviaremos una propuesta formal adaptada a los requerimientos técnicos y de producción de tu evento.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-10 scroll-reveal">
        <!-- Direct contact CTAs -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="https://wa.me/56990021689" target="_blank" rel="noopener" class="bg-slate-950 border border-white/5 hover:border-green-500 rounded-xl p-5 flex justify-between items-center transition-all group cursor-pointer shadow-md">
            <div>
              <span class="text-[9px] text-slate-500 font-extrabold uppercase tracking-widest block mb-1">Mánager Comercial</span>
              <span class="text-white font-bold text-base block">+56 9 9002 1689</span>
            </div>
            <span class="text-[10px] text-green-400 font-bold border border-green-500/20 px-3 py-1.5 rounded bg-green-950/20 group-hover:bg-green-500 group-hover:text-black transition-colors uppercase tracking-wider">
              WhatsApp Directo
            </span>
          </a>

          <a href="mailto:contacto@bandabruna.cl" class="bg-slate-950 border border-white/5 hover:border-gold-bruna rounded-xl p-5 flex justify-between items-center transition-all group cursor-pointer shadow-md">
            <div>
              <span class="text-[9px] text-slate-500 font-extrabold uppercase tracking-widest block mb-1">Correo de Reserva</span>
              <span class="text-white font-bold text-base block">contacto@bandabruna.cl</span>
            </div>
            <span class="text-[10px] text-gold-bruna font-bold border border-gold-bruna/20 px-3 py-1.5 rounded bg-amber-950/20 group-hover:bg-gold-bruna group-hover:text-black transition-colors uppercase tracking-wider">
              Enviar Email
            </span>
          </a>
        </div>

        <!-- Form Wrapper -->
        <div id="booking-form-container" class="bg-slate-900/60 border border-white/5 backdrop-blur-md rounded-2xl p-6 md:p-10 shadow-2xl">
          <form id="quote-form-extended" class="flex flex-col gap-6 text-left" novalidate>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="ext-name" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Nombre del Contacto / Productor</label>
                <input 
                  type="text" 
                  id="ext-name" 
                  name="name" 
                  placeholder="Ingresa tu nombre completo" 
                  required
                  class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
                />
                <span class="text-[10px] text-red-400 hidden" id="ext-name-err">Por favor ingresa tu nombre.</span>
              </div>
              
              <div class="flex flex-col gap-2">
                <label for="ext-phone" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Teléfono de Contacto</label>
                <input 
                  type="tel" 
                  id="ext-phone" 
                  name="phone" 
                  placeholder="+56 9 1234 5678" 
                  required
                  autocomplete="tel"
                  inputmode="tel"
                  class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
                />
                <span class="text-[10px] text-red-400 hidden" id="ext-phone-err">Por favor ingresa tu teléfono.</span>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="ext-email" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Correo Electrónico</label>
                <input 
                  type="email" 
                  id="ext-email" 
                  name="email" 
                  placeholder="ejemplo@correo.com" 
                  required
                  autocomplete="email"
                  inputmode="email"
                  class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
                />
                <span class="text-[10px] text-red-400 hidden" id="ext-email-err">Por favor ingresa un correo válido.</span>
              </div>
              
              <div class="flex flex-col gap-2">
                <label for="ext-type" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Tipo de Evento a Cotizar</label>
                <select 
                  id="ext-type" 
                  name="event-type"
                  class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors cursor-pointer"
                >
                  <option value="municipal">Festival Municipal / Show Público</option>
                  <option value="fiestas-patrias">Fiestas Patrias / Fondas</option>
                  <option value="corporativo">Evento Corporativo / Empresa</option>
                  <option value="privado">Celebración Privada / Cumpleaños</option>
                  <option value="aniversario">Aniversario Regional / Gremial</option>
                  <option value="festival">Festival Musical Independiente</option>
                  <option value="colegio-universidad">Evento Estudiantil / Graduación</option>
                  <option value="matrimonio">Matrimonio / Boda</option>
                  <option value="produccion">Producciones / Programas de Medios</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="ext-date" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Fecha Tentativa del Evento</label>
                <input 
                  type="date" 
                  id="ext-date" 
                  name="event-date"
                  required
                  class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors cursor-pointer"
                />
                <span class="text-[10px] text-red-400 hidden" id="ext-date-err">Por favor selecciona la fecha.</span>
              </div>
              
              <div class="flex flex-col gap-2">
                <label for="ext-city" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Ciudad o Comuna del Evento</label>
                <input 
                  type="text" 
                  id="ext-city" 
                  name="city" 
                  placeholder="Ej: Temuco, Valdivia, Santiago" 
                  required
                  class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
                />
                <span class="text-[10px] text-red-400 hidden" id="ext-city-err">Por favor ingresa la comuna.</span>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="ext-message" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Requerimientos Especiales / Detalles del Evento</label>
              <textarea 
                id="ext-message" 
                name="message" 
                rows="5" 
                placeholder="Indícanos la duración deseada, estimación de público, si provees sonido/escenario o si requieres producción técnica completa de nuestra parte..."
                class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors resize-none"
              ></textarea>
            </div>

            <button type="submit" class="bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black font-extrabold py-3.5 rounded text-xs uppercase tracking-widest hover:scale-102 hover:shadow-lg hover:shadow-gold-bruna/20 transition-all cursor-pointer">
              ENVIAR SOLICITUD DE COTIZACIÓN
            </button>
            
            <div id="ext-form-feedback" class="hidden text-center text-xs py-2.5 px-4 rounded border" role="alert"></div>

          </form>
        </div>

        <!-- Success Panel (Hidden by default) -->
        <div id="success-panel" class="hidden bg-slate-900 border border-white/5 rounded-2xl p-8 md:p-10 shadow-2xl text-center flex flex-col items-center gap-6">
          <div class="w-16 h-16 rounded-full bg-green-950/40 border border-green-500/30 text-green-400 flex items-center justify-center text-3xl animate-bounce">
            ✓
          </div>
          <div>
            <h3 class="font-title font-extrabold text-2xl text-white uppercase tracking-wide">¡Cotización Recibida!</h3>
            <p class="text-slate-300 text-sm font-light mt-2 max-w-lg mx-auto">
              Hemos registrado tu solicitud y enviado un correo de respaldo con todos los detalles a <strong class="text-white">contacto@bandabruna.cl</strong>.
            </p>
          </div>

          <div class="w-full max-w-md border-t border-white/5 pt-6 mt-2 flex flex-col gap-4">
            <span class="text-[10px] font-bold text-slate-500 tracking-widest uppercase">NOTIFICAR INMEDIATAMENTE AL STAFF COMERCIAL</span>
            <p class="text-slate-400 text-xs font-light leading-relaxed">
              Haz clic en cualquiera de los siguientes botones para enviar la notificación directamente por WhatsApp y acelerar el proceso de revisión:
            </p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
              <a id="btn-wa-jaime" href="#" target="_blank" rel="noopener" class="bg-green-600 hover:bg-green-700 text-white font-bold text-xs py-3.5 px-4 rounded transition-all flex items-center justify-center gap-2 uppercase tracking-wider">
                💬 Jaime Cárdenas
              </a>
              <a id="btn-wa-cesar" href="#" target="_blank" rel="noopener" class="bg-green-600 hover:bg-green-700 text-white font-bold text-xs py-3.5 px-4 rounded transition-all flex items-center justify-center gap-2 uppercase tracking-wider">
                💬 César Bruna
              </a>
            </div>
          </div>

          <button id="btn-reset-form" class="mt-4 border border-white/10 hover:border-gold-bruna text-white hover:text-gold-bruna text-xs py-2 px-6 rounded transition-colors uppercase font-bold tracking-wider cursor-pointer">
            Cotizar Otro Show
          </button>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  import { supabase } from '../../services/supabaseClient.js';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('quote-form-extended') as HTMLFormElement;
    const feedback = document.getElementById('ext-form-feedback');
    const nameInput = document.getElementById('ext-name') as HTMLInputElement;
    const phoneInput = document.getElementById('ext-phone') as HTMLInputElement;
    const emailInput = document.getElementById('ext-email') as HTMLInputElement;
    const dateInput = document.getElementById('ext-date') as HTMLInputElement;
    const cityInput = document.getElementById('ext-city') as HTMLInputElement;
    const typeSelect = document.getElementById('ext-type') as HTMLSelectElement;

    const nameErr = document.getElementById('ext-name-err');
    const phoneErr = document.getElementById('ext-phone-err');
    const emailErr = document.getElementById('ext-email-err');
    const dateErr = document.getElementById('ext-date-err');
    const cityErr = document.getElementById('ext-city-err');
    
    const formContainer = document.getElementById('booking-form-container');
    const successPanel = document.getElementById('success-panel');
    const resetBtn = document.getElementById('btn-reset-form');

    // Pre-seleccionar tipo si viene por Query Parameter
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('type') && typeSelect) {
      typeSelect.value = decodeURIComponent(urlParams.get('type') || '');
    }

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        nameErr?.classList.add('hidden');
        phoneErr?.classList.add('hidden');
        emailErr?.classList.add('hidden');
        dateErr?.classList.add('hidden');
        cityErr?.classList.add('hidden');
        if (feedback) feedback.classList.add('hidden');

        let valid = true;

        if (!nameInput.value.trim()) {
          nameErr?.classList.remove('hidden');
          valid = false;
        }

        if (!phoneInput.value.trim()) {
          phoneErr?.classList.remove('hidden');
          valid = false;
        }

        if (!emailInput.value.trim() || !emailInput.checkValidity()) {
          emailErr?.classList.remove('hidden');
          valid = false;
        }

        if (!dateInput.value) {
          dateErr?.classList.remove('hidden');
          valid = false;
        }

        if (!cityInput.value.trim()) {
          cityErr?.classList.remove('hidden');
          valid = false;
        }

        if (!valid) return;

        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const origText = btn.textContent;
        btn.textContent = 'Enviando...';
        btn.disabled = true;

        const nameVal = nameInput.value.trim();
        const phoneVal = phoneInput.value.trim();
        const emailVal = emailInput.value.trim();
        const typeVal = typeSelect ? typeSelect.options[typeSelect.selectedIndex].text : '';
        const dateVal = dateInput.value;
        const cityVal = cityInput.value.trim();
        const msgVal = (document.getElementById('ext-message') as HTMLTextAreaElement).value.trim() || 'Sin detalles adicionales.';

        // Guardar cotización en Supabase
        supabase.from('cotizaciones').insert([
          {
            nombre: nameVal,
            telefono: phoneVal,
            email: emailVal,
            fecha_evento: dateVal || null,
            ciudad: cityVal,
            tipo_evento: typeVal,
            mensaje: msgVal
          }
        ]).then(({ error }) => {
          if (error) {
            console.error('Error al guardar en Supabase:', error);
          } else {
            console.log('Cotización guardada exitosamente en Supabase');
          }
        });

        // Enviar correo asíncronamente con FormSubmit.co
        fetch("https://formsubmit.co/ajax/contacto@bandabruna.cl", {
          method: "POST",
          headers: { 
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({
            "Asunto": "Nueva Cotización desde la Sección de Eventos",
            "Nombre": nameVal,
            "Teléfono": phoneVal,
            "Email": emailVal,
            "Tipo de Evento": typeVal,
            "Fecha Tentativa": dateVal,
            "Ciudad/Comuna": cityVal,
            "Detalles/Mensaje": msgVal
          })
        })
        .then(response => {
          if (!response.ok) throw new Error('Error al enviar.');
          return response.json();
        })
        .then(() => {
          btn.textContent = origText;
          btn.disabled = false;

          // Formatear mensaje para WhatsApp
          const waMessage = `*Nueva Solicitud de Cotización - Banda Bruna*\n\n` +
            `👤 *Contacto:* ${nameVal}\n` +
            `📞 *Fono:* ${phoneVal}\n` +
            `📧 *Email:* ${emailVal}\n` +
            `🎭 *Evento:* ${typeVal}\n` +
            `📅 *Fecha:* ${dateVal}\n` +
            `📍 *Ciudad/Comuna:* ${cityVal}\n` +
            `📝 *Detalles:* ${msgVal}`;
          
          const encodedMessage = encodeURIComponent(waMessage);

          // Configurar botones de WhatsApp
          const btnJaime = document.getElementById('btn-wa-jaime') as HTMLAnchorElement;
          const btnCesar = document.getElementById('btn-wa-cesar') as HTMLAnchorElement;
          if (btnJaime) btnJaime.href = `https://wa.me/56990021689?text=${encodedMessage}`;
          if (btnCesar) btnCesar.href = `https://wa.me/56976149408?text=${encodedMessage}`;

          // Intentar abrir WhatsApp automáticamente con Jaime
          window.open(`https://wa.me/56990021689?text=${encodedMessage}`, '_blank');

          // Ocultar formulario y mostrar panel de éxito
          formContainer?.classList.add('hidden');
          successPanel?.classList.remove('hidden');

          form.reset();
        })
        .catch(() => {
          btn.textContent = origText;
          btn.disabled = false;
          if (feedback) {
            feedback.textContent = 'Hubo un inconveniente al enviar tu cotización por correo. Por favor, intenta de nuevo o contáctanos directamente a través de WhatsApp.';
            feedback.className = 'text-center text-xs py-2.5 px-4 rounded border bg-red-950/20 border-red-500/20 text-red-400 block';
          }
        });
      });
    }

    if (resetBtn && formContainer && successPanel) {
      resetBtn.addEventListener('click', () => {
        successPanel.classList.add('hidden');
        formContainer.classList.remove('hidden');
      });
    }
  });
</script>
