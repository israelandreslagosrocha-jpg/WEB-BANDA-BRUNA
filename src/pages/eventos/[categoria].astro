---
import Layout from '../../layouts/Layout.astro';

// Mapeo de todos los slugs de evento con su información de display
const categorias: Record<string, { title: string; subtitle: string; icon: string; color: string; description: string }> = {
  "municipalidades": {
    title: "Municipalidades",
    subtitle: "Shows Municipales & Plazas de Armas",
    icon: "🏛️",
    color: "from-blue-600/20 to-indigo-900/10",
    description: "Show familiar y masivo ideal para plazas de armas, veranos alegres, ferias costumbristas y shows públicos municipales."
  },
  "eventos-privados": {
    title: "Eventos Privados",
    subtitle: "Cumpleaños, Galas & Celebraciones Exclusivas",
    icon: "🎉",
    color: "from-purple-600/20 to-violet-900/10",
    description: "Cumpleaños, fiestas de gala y celebraciones exclusivas con la mejor energía y repertorio bailable."
  },
  "aniversarios": {
    title: "Aniversarios",
    subtitle: "Comunales, Gremiales & Organizaciones",
    icon: "🎊",
    color: "from-rose-600/20 to-red-900/10",
    description: "Shows en vivo a medida para aniversarios comunales, de clubes, gremios y organizaciones en todo Chile."
  },
  "colegios-universidades": {
    title: "Colegios y Universidades",
    subtitle: "Graduaciones, Semanas Universitarias & Festivales Juveniles",
    icon: "🎓",
    color: "from-teal-600/20 to-green-900/10",
    description: "Fiestas de graduación, aniversarios estudiantiles, semanas universitarias y festivales juveniles con toda la energía."
  },
  "matrimonios": {
    title: "Matrimonios",
    subtitle: "Bodas & Celebraciones Nupciales",
    icon: "💍",
    color: "from-pink-600/20 to-rose-900/10",
    description: "Boda de ensueño con música en vivo desde el cóctel hasta el show bailable principal que hará saltar a todos."
  }
};

export function getStaticPaths() {
  return [
    { params: { categoria: "municipalidades" } },
    { params: { categoria: "eventos-privados" } },
    { params: { categoria: "aniversarios" } },
    { params: { categoria: "colegios-universidades" } },
    { params: { categoria: "matrimonios" } }
  ];
}

const { categoria } = Astro.params;
const info = categorias[categoria] || {
  title: "Eventos",
  subtitle: "Contrataciones",
  icon: "🎵",
  color: "from-gold-bruna/20 to-amber-900/10",
  description: "Pronto tendremos toda la información de esta sección disponible para ti."
};

const pageTitle = `${info.title} | Banda Bruna - Contrataciones y Shows en Vivo`;
const pageDescription = info.description;
---

<Layout title={pageTitle} description={pageDescription}>

  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-6 py-24">

    <!-- Background ambient glow -->
    <div class="absolute inset-0 z-0">
      <div class={`absolute inset-0 bg-gradient-to-b ${info.color} via-transparent to-transparent`}></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(214,175,55,0.04)_0%,transparent_70%)]"></div>
      <!-- Grid pattern -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">

      <!-- Back Button -->
      <a 
        href="/eventos" 
        class="inline-flex items-center gap-2 text-[10px] font-bold text-slate-400 hover:text-gold-bruna transition-colors uppercase tracking-widest mb-12 group"
      >
        <svg class="w-3 h-3 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        Volver a Eventos
      </a>

      <!-- Category label -->
      <div class="mb-6 inline-flex items-center gap-2 bg-slate-900/60 border border-white/10 rounded-full px-4 py-1.5 backdrop-blur-md">
        <span class="text-xs font-bold tracking-widest text-gold-bruna uppercase font-title">
          Banda Bruna — Contrataciones
        </span>
      </div>

      <!-- Icon -->
      <div class="text-7xl md:text-8xl mb-8 select-none" role="img" aria-label={info.title}>
        {info.icon}
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-6xl font-black font-title text-white uppercase tracking-tight leading-tight mb-4">
        {info.title}
      </h1>
      <p class="text-xs md:text-sm text-gold-bruna font-bold tracking-[0.2em] uppercase mb-8">
        {info.subtitle}
      </p>

      <!-- Divider -->
      <div class="flex items-center gap-4 justify-center mb-8">
        <div class="w-12 h-px bg-gold-bruna/30"></div>
        <div class="w-2 h-2 rounded-full bg-gold-bruna/50"></div>
        <div class="w-12 h-px bg-gold-bruna/30"></div>
      </div>

      <!-- Status Message -->
      <div class="bg-slate-900/70 border border-gold-bruna/20 rounded-2xl p-8 md:p-10 backdrop-blur-md mb-10 shadow-2xl shadow-black/60">
        
        <!-- Animated icon -->
        <div class="flex items-center justify-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-full bg-gold-bruna/10 border border-gold-bruna/30 flex items-center justify-center text-gold-bruna animate-pulse">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="text-[10px] font-extrabold tracking-widest text-gold-bruna uppercase font-title">
            Sección en Preparación
          </span>
        </div>

        <p class="text-white font-bold text-lg md:text-xl mb-3 leading-snug">
          Estamos preparando todo el material de esta sección.
        </p>
        <p class="text-slate-400 text-sm leading-relaxed max-w-xl mx-auto">
          {info.description} Pronto tendrás acceso a fotos, videos, referencias y toda la información necesaria para contratar a Banda Bruna para tu <strong class="text-slate-300">{info.title.toLowerCase()}</strong>.
        </p>

        <!-- Progress bar visual -->
        <div class="mt-8 text-left">
          <div class="flex justify-between items-center mb-2">
            <span class="text-[9px] font-bold tracking-widest text-slate-400 uppercase">Recopilación de material</span>
            <span class="text-[9px] font-bold text-gold-bruna">En progreso...</span>
          </div>
          <div class="w-full h-1 bg-slate-800 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-gold-bruna to-amber-500 rounded-full w-[35%] relative">
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 bg-amber-300 rounded-full shadow-lg shadow-amber-400/50 animate-pulse"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <p class="text-slate-400 text-xs mb-6 tracking-wide">
        ¿Necesitas información ahora? Contáctanos directamente y te asesoramos sin compromiso.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contrataciones" 
          class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black font-extrabold text-xs tracking-widest uppercase px-8 py-4 rounded-lg hover:scale-105 transition-all shadow-lg shadow-gold-bruna/20 active:scale-95"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L0 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a 
          href="/eventos" 
          class="inline-flex items-center justify-center gap-2 bg-transparent border border-white/15 text-slate-300 hover:text-white hover:border-white/30 font-bold text-xs tracking-widest uppercase px-8 py-4 rounded-lg hover:scale-105 transition-all active:scale-95"
        >
          Ver Otros Eventos
        </a>
      </div>
    </div>

  </section>

</Layout>

<style>
  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
</style>
