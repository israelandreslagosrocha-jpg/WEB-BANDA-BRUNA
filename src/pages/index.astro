---
import Layout from '../layouts/Layout.astro';
import { 
  getLatestVideo, 
  getInstagramFeed, 
  getFacebookFeed, 
  getUpcomingEvents, 
  getNews 
} from '../services/socialApi.js';

// Fetch mock social data at build time
const latestVideo = getLatestVideo();
const instagramFeed = getInstagramFeed();
const facebookFeed = getFacebookFeed();
const upcomingEvents = getUpcomingEvents(); // Show all 5 events
const newsList = getNews();
---

<Layout title="Banda Bruna | Orquesta Oficial - Música en Vivo para Eventos y Festivales" description="Sitio oficial de Banda Bruna. Cumbia sureña y cumbia chilena en vivo para festivales municipales, bodas y eventos corporativos.">
  
  <!-- Hero Section with Background Video Loop -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden bg-black px-6" aria-label="Portada Principal">
    
    <!-- Video background / Iframe container -->
    <div class="absolute top-0 left-0 w-full h-full z-0 opacity-30 pointer-events-none overflow-hidden">
      <!-- Fallback static hero image during load -->
      <div class="absolute top-0 left-0 w-full h-full bg-cover bg-center bg-no-repeat" style="background-image: url('assets/images/hero.png');"></div>
      
      <!-- YouTube Embed in background simulating automated video loop -->
      <iframe 
        class="absolute top-1/2 left-1/2 w-[100vw] h-[56.25vw] min-h-screen min-w-[177.77vh] -translate-x-1/2 -translate-y-1/2"
        src={latestVideo.embedUrl}
        title="Banda Bruna Hero Background Video"
        frameborder="0" 
        allow="autoplay; mute; loop; encrypted-media" 
        allowfullscreen
      ></iframe>
    </div>

    <!-- Radial backdrop gradient overlay -->
    <div class="absolute top-0 left-0 w-full h-full z-10 bg-radial-gradient from-transparent via-bg-darkest/65 to-bg-darkest" aria-hidden="true"></div>

    <!-- Hero Content Layout -->
    <div class="relative max-w-7xl mx-auto w-full z-20 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center pt-16">
      
      <!-- Text & Primary CTAs (Left) -->
      <div class="lg:col-span-7 text-left flex flex-col gap-6">
        <span class="text-xs tracking-[0.4em] font-semibold text-gold-bruna uppercase block">
          CUMBIA · SHOW EN VIVO · EXPERIENCIA BRUNA
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold leading-none tracking-tight font-title">
          MÚSICA EN VIVO PARA <br class="hidden md:inline"/>
          <span class="text-gold-bruna uppercase">EVENTOS, FESTIVALES <br class="hidden md:inline"/>Y CELEBRACIONES</span>
        </h1>
        <div class="flex flex-wrap gap-4 mt-4">
          <a href="#lanzamientos" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-6 py-3.5 rounded-sm font-bold text-xs hover:scale-105 transition-all shadow-lg shadow-gold-bruna/20 cursor-pointer text-center flex items-center gap-2">
            <!-- Inline play icon in a circle -->
            <span class="w-4 h-4 bg-black text-gold-bruna rounded-full flex items-center justify-center text-[8px] pl-0.5">▶</span>
            VER ÚLTIMO VIDEOCLIP
          </a>
          <a href="https://wa.me/56912345678" target="_blank" rel="noopener" class="border border-white/20 hover:border-white bg-white/5 hover:bg-white/10 px-6 py-3.5 rounded-sm font-bold text-xs hover:scale-105 transition-all cursor-pointer text-center flex items-center gap-2 justify-center uppercase">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.688 2.012 14.218.993 12.003.993c-5.44 0-9.866 4.372-9.87 9.802 0 1.714.47 3.387 1.357 4.868l-.993 3.624 3.73-.974h-.002zm11.367-7.374c-.327-.162-1.928-.94-2.224-1.047-.297-.108-.512-.162-.728.162-.215.324-.837 1.047-1.026 1.262-.19.216-.379.243-.705.082-.328-.162-1.38-.503-2.63-1.608-.973-.859-1.63-1.922-1.821-2.247-.19-.325-.02-.5-.184-.66-.147-.146-.327-.379-.49-.569-.164-.189-.219-.324-.327-.54-.109-.217-.055-.407-.027-.57.028-.162.22-1.05.28-1.243.06-.192.12-.324.21-.54.09-.217.045-.406.022-.57-.022-.162-.218-1.047-.726-2.247-.32-.76-.667-.655-.726-.658h-.65c-.215 0-.56.08-.853.38-.293.305-1.12.973-1.12 2.373 0 1.4 1.033 2.75 1.178 2.94.145.19 2.032 3.065 4.92 4.29.686.29 1.222.463 1.64.595.69.217 1.319.186 1.815.112.553-.083 1.928-.779 2.2-1.493.272-.714.272-1.328.19-1.457-.08-.13-.298-.216-.625-.378z"/></svg>
            COTIZAR EVENTO
          </a>
        </div>
      </div>

      <!-- Featured Video Card (Right) -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end">
        <a href={latestVideo.youtubeUrl} target="_blank" rel="noopener" class="bg-slate-950/80 border border-white/5 hover:border-gold-bruna rounded-xl p-4 w-full max-w-[360px] shadow-2xl shadow-black/90 hover:translate-y-[-5px] transition-all group block">
          <div class="relative aspect-video rounded-lg overflow-hidden mb-4 bg-slate-900 border border-white/5">
            <img src={latestVideo.thumbnail} alt={latestVideo.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 flex items-center justify-center bg-black/40">
              <div class="w-12 h-12 bg-white/90 rounded-full flex items-center justify-center text-black shadow-lg group-hover:scale-110 transition-transform">
                <span class="text-xs pl-0.5 text-black">▶</span>
              </div>
            </div>
            <span class="absolute top-2.5 left-2.5 bg-blue-600 text-white text-[9px] font-bold px-2 py-0.5 rounded tracking-widest uppercase">NUEVO</span>
          </div>
          <div>
            <span class="text-[10px] text-slate-400 font-bold tracking-wider uppercase block">BANDA BRUNA</span>
            <h2 class="text-white font-title font-extrabold text-base mt-0.5 group-hover:text-gold-bruna transition-colors uppercase">{latestVideo.title}</h2>
            <p class="text-xs text-slate-400 mt-1">{latestVideo.type}</p>
            <div class="flex items-center gap-1 text-[10px] text-slate-500 font-semibold mt-3 hover:underline">
              <span>Ver en YouTube</span>
              <span>📹</span>
            </div>
          </div>
        </a>
      </div>

    </div>

    <!-- Centered Down Arrow -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 text-slate-400 text-xl font-bold animate-bounce" aria-hidden="true">
      <a href="#lanzamientos" aria-label="Desplazarse abajo">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </a>
    </div>
  </section>

  <!-- Auto Content Badges Bar -->
  <div class="border-y border-white/5 bg-slate-950/60 py-6">
    <div class="max-w-[1400px] mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-6 text-center md:text-left">
      
      <!-- Badge 1 -->
      <div class="flex flex-col md:flex-row items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-950/50 border border-blue-500/10 flex items-center justify-center text-blue-400 flex-shrink-0">
          <svg class="w-4 h-4 fill-blue-400" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        </div>
        <div>
          <span class="text-xs font-bold text-white block tracking-wider uppercase">CONTENIDO AUTOMÁTICO</span>
          <span class="text-[11px] text-slate-400">Actualizamos nuestra web automáticamente desde YouTube, Instagram y Facebook.</span>
        </div>
      </div>
      
      <!-- Badge 2 -->
      <div class="flex flex-col md:flex-row items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-pink-950/40 border border-pink-500/10 flex items-center justify-center text-pink-400 flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </div>
        <div>
          <span class="text-xs font-bold text-white block tracking-wider uppercase">REDES EN TIEMPO REAL</span>
          <span class="text-[11px] text-slate-400">Síguenos y mira nuestras últimas publicaciones en tiempo real.</span>
        </div>
      </div>

      <!-- Badge 3 -->
      <div class="flex flex-col md:flex-row items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-amber-950/40 border border-amber-500/10 flex items-center justify-center text-gold-bruna flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <div>
          <span class="text-xs font-bold text-white block tracking-wider uppercase">AGENDA ACTUALIZADA</span>
          <span class="text-[11px] text-slate-400">Nuestros próximos shows siempre al día. ¡No te pierdas ninguno!</span>
        </div>
      </div>

      <!-- Badge 4 -->
      <div class="flex flex-col md:flex-row items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-yellow-950/30 border border-yellow-500/10 flex items-center justify-center text-yellow-400 flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
        </div>
        <div>
          <span class="text-xs font-bold text-white block tracking-wider uppercase">ESCUCHA NUESTRA MÚSICA</span>
          <span class="text-[11px] text-slate-400">Disponible en Spotify, YouTube Music, Apple Music y más plataformas.</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Section: Split Grid (ÚLTIMOS LANZAMIENTOS & PRÓXIMOS EVENTOS) -->
  <section id="lanzamientos" class="max-w-[1400px] mx-auto px-6 py-24 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start scroll-reveal">
    
    <!-- LEFT SIDE: Últimos Lanzamientos (Col span 8) -->
    <div class="lg:col-span-8 flex flex-col gap-6 w-full">
      <div>
        <h2 class="font-title font-extrabold text-2xl text-white uppercase tracking-wider mb-8">ÚLTIMOS LANZAMIENTOS</h2>
      </div>

      <!-- Grid of 3 columns of cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Card 1: YouTube -->
        <div class="bg-slate-900 border border-white/5 rounded overflow-hidden group flex flex-col justify-between hover:border-gold-bruna transition-colors">
          <div class="relative aspect-video bg-black overflow-hidden">
            <img src={latestVideo.thumbnail} alt={latestVideo.title} class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" />
            <a href={latestVideo.youtubeUrl} target="_blank" rel="noopener" class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/20 transition-all cursor-pointer">
              <div class="w-10 h-10 bg-black/60 rounded-full border border-white/20 flex items-center justify-center text-white">
                <span class="text-xs pl-0.5">▶</span>
              </div>
            </a>
            <span class="absolute top-2.5 left-2.5 bg-blue-600 text-white text-[8px] font-bold px-2 py-0.5 rounded-sm tracking-widest">YOUTUBE</span>
          </div>
          <div class="p-5 flex-grow flex flex-col justify-between text-left">
            <div>
              <h3 class="font-title font-extrabold text-base text-white tracking-wide group-hover:text-gold-bruna transition-colors uppercase">{latestVideo.title}</h3>
              <p class="text-xs text-slate-400 mt-2">Videoclip Oficial</p>
            </div>
            <span class="text-[10px] text-slate-500 font-semibold block mt-4">{latestVideo.publishedAt}</span>
          </div>
        </div>

        <!-- Card 2: Instagram -->
        <div class="bg-slate-900 border border-white/5 rounded overflow-hidden group flex flex-col justify-between hover:border-gold-bruna transition-colors">
          <div class="relative aspect-video bg-black overflow-hidden">
            <img src={instagramFeed[0].imageUrl} alt="Instagram" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" />
            <a href={instagramFeed[0].link} target="_blank" rel="noopener" class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/20 transition-all cursor-pointer">
              <div class="w-10 h-10 bg-black/60 rounded-full border border-white/20 flex items-center justify-center text-white">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </div>
            </a>
            <span class="absolute top-2.5 left-2.5 bg-pink-600 text-white text-[8px] font-bold px-2 py-0.5 rounded-sm tracking-widest">INSTAGRAM</span>
          </div>
          <div class="p-5 flex-grow flex flex-col justify-between text-left">
            <div>
              <h3 class="font-title font-bold text-xs text-white leading-relaxed line-clamp-2">Así vivimos el fin de semana en Los Ángeles 🔥🎶</h3>
              <p class="text-xs text-slate-400 mt-2">Seguimos llevando el ritmo de la cumbia sureña a todos los rincones.</p>
            </div>
            <span class="text-[10px] text-slate-500 font-semibold block mt-4">Hace 1 día</span>
          </div>
        </div>

        <!-- Card 3: News -->
        <div class="bg-slate-900 border border-white/5 rounded overflow-hidden group flex flex-col justify-between hover:border-gold-bruna transition-colors">
          <div class="relative aspect-video bg-[#0b132b] overflow-hidden flex items-center justify-center border-b border-white/5">
            <div class="w-12 h-12 bg-slate-950 rounded-full border border-white/5 flex items-center justify-center text-gold-bruna">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1M19 20a2 2 0 002-2V8a2 2 0 00-2-2h-5M19 20a2 2 0 01-2-2V6m0 14V4"/></svg>
            </div>
            <span class="absolute top-2.5 left-2.5 bg-amber-500 text-black text-[8px] font-bold px-2 py-0.5 rounded-sm tracking-widest">NOTICIAS</span>
          </div>
          <div class="p-5 flex-grow flex flex-col justify-between text-left">
            <div>
              <h3 class="font-title font-bold text-xs text-white leading-relaxed line-clamp-2">{newsList[0].title}</h3>
              <p class="text-xs text-slate-400 mt-2">La organización confirmó a Banda Bruna en el horario estelar.</p>
            </div>
            <span class="text-[10px] text-slate-500 font-semibold block mt-4">{newsList[0].publishedAt}</span>
          </div>
        </div>

      </div>
    </div>

    <!-- RIGHT SIDE: Próximos Eventos & Banner (Col span 4) -->
    <div class="lg:col-span-4 flex flex-col gap-6 w-full">
      <div class="flex justify-between items-center mb-2">
        <h2 class="font-title font-extrabold text-2xl text-white uppercase tracking-wider">PRÓXIMOS EVENTOS</h2>
        <a href="/agenda" class="text-gold-bruna text-[10px] font-bold hover:underline tracking-wider uppercase flex items-center gap-1 flex-shrink-0">
          Ver agenda completa →
        </a>
      </div>

      <!-- Events List Timeline -->
      <div class="bg-slate-900 border border-white/5 rounded-xl p-5 shadow-lg flex flex-col gap-5 text-left">
        <ul class="flex flex-col gap-4 list-none p-0 m-0">
          {upcomingEvents.map(event => (
            <li class="flex items-center justify-between gap-4 pb-4 border-b border-white/5 last:border-0 last:pb-0">
              <div class="flex items-center gap-3">
                <div class="flex flex-col text-left leading-none min-w-[32px]">
                  <span class="text-2xl font-extrabold font-title text-white tracking-tighter">{event.date}</span>
                  <span class="text-[9px] text-slate-500 font-bold uppercase mt-0.5 tracking-wider">{event.month}</span>
                </div>
                <div>
                  <h3 class="font-title font-bold text-xs text-white tracking-wide uppercase line-clamp-1">{event.title}</h3>
                  <span class="text-[10px] text-slate-400">{event.location}</span>
                </div>
              </div>
              
              {event.statusType === 'confirmed' ? (
                <span class="bg-green-950/20 border border-green-500/20 text-green-400 text-[8px] font-bold px-2 py-0.5 rounded-sm uppercase tracking-wide flex-shrink-0">
                  CONFIRMADO
                </span>
              ) : (
                <span class="bg-amber-950/20 border border-amber-500/20 text-amber-400 text-[8px] font-bold px-2 py-0.5 rounded-sm uppercase tracking-wide flex-shrink-0">
                  POR CONFIRMAR
                </span>
              )}
            </li>
          ))}
        </ul>
        
        <a href="/agenda" class="w-full text-center border border-white/10 hover:border-gold-bruna bg-slate-950 hover:bg-slate-950/80 text-white font-bold py-2.5 rounded-sm text-[10px] tracking-widest flex items-center justify-center gap-2 transition-colors uppercase cursor-pointer mt-1">
          <span>📅</span>
          VER AGENDA COMPLETA
        </a>
      </div>

      <!-- Balancing Banner Image below the timeline -->
      <div class="relative aspect-[21/9] rounded-xl overflow-hidden border border-white/5 bg-slate-900 group shadow-lg">
        <img src="assets/images/hero.png" alt="Banda Bruna Show en vivo" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500 opacity-80" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex items-end p-4">
          <span class="font-title font-bold text-xs text-gold-bruna tracking-widest uppercase">LA ORQUESTA DEL SUR</span>
        </div>
      </div>

    </div>

  </section>

  <!-- Section: La Experiencia Bruna (Carousel & Stats) -->
  <section class="max-w-[1400px] mx-auto px-6 py-24 border-t border-white/5 scroll-reveal">
    <div class="text-left mb-12">
      <h2 class="font-title font-extrabold text-2xl text-white uppercase tracking-wider relative inline-block pb-3">
        LA EXPERIENCIA BRUNA
        <span class="absolute bottom-0 left-0 w-12 h-1 bg-gold-bruna"></span>
      </h2>
    </div>

    <!-- Images Carousel slider mock -->
    <div class="relative flex items-center justify-center gap-4 mb-16">
      
      <!-- Left arrow -->
      <button class="w-10 h-10 rounded-full border border-white/10 hover:border-gold-bruna bg-slate-950 flex items-center justify-center text-slate-400 hover:text-white transition-colors cursor-pointer flex-shrink-0" aria-label="Anterior">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </button>

      <!-- Carousel Images Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full">
        <div class="relative aspect-[4/3] rounded overflow-hidden border border-white/5 bg-slate-900">
          <img src="assets/images/hero.png" alt="Concierto Escenario Bruna 1" class="w-full h-full object-cover" />
        </div>
        <div class="relative aspect-[4/3] rounded overflow-hidden border border-white/5 bg-slate-900">
          <img src="assets/images/album.png" alt="Concierto Escenario Bruna 2" class="w-full h-full object-cover" />
        </div>
        <div class="relative aspect-[4/3] rounded overflow-hidden border border-white/5 bg-slate-900">
          <img src="assets/images/hero.png" alt="Concierto Escenario Bruna 3" class="w-full h-full object-cover" />
        </div>
        <div class="relative aspect-[4/3] rounded overflow-hidden border border-white/5 bg-slate-900">
          <img src="assets/images/album.png" alt="Concierto Escenario Bruna 4" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Right arrow -->
      <button class="w-10 h-10 rounded-full border border-white/10 hover:border-gold-bruna bg-slate-950 flex items-center justify-center text-slate-400 hover:text-white transition-colors cursor-pointer flex-shrink-0" aria-label="Siguiente">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </button>
      
    </div>

    <!-- Centered Statistics row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center max-w-4xl mx-auto">
      <div>
        <span class="text-4xl sm:text-5xl font-extrabold font-title text-gold-bruna block mb-1.5">+10</span>
        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">AÑOS DE TRAYECTORIA</span>
      </div>
      <div>
        <span class="text-4xl sm:text-5xl font-extrabold font-title text-gold-bruna block mb-1.5">+300</span>
        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">EVENTOS REALIZADOS</span>
      </div>
      <div>
        <span class="text-4xl sm:text-5xl font-extrabold font-title text-gold-bruna block mb-1.5">+80K</span>
        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">SEGUIDORES EN REDES</span>
      </div>
      <div>
        <span class="text-4xl sm:text-5xl font-extrabold font-title text-gold-bruna block mb-1.5">5</span>
        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">REGIONES DE CHILE</span>
      </div>
    </div>

  </section>

  <!-- Section: Síguenos en Tiempo Real (Unified Social Feed Row) -->
  <section class="bg-slate-950/40 border-t border-white/5 py-24 scroll-reveal">
    <div class="max-w-[1400px] mx-auto px-6">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12">
        <div>
          <h2 class="font-title font-extrabold text-2xl text-white uppercase tracking-wider">SÍGUENOS EN TIEMPO REAL</h2>
        </div>
        
