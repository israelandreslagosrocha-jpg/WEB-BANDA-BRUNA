        <div class="absolute top-1/2 -translate-y-1/2 right-12 w-96 h-96 rounded-full blur-[120px] opacity-25" style={`background-color: ${activeLanzamiento.color_principal};`}></div>
      </div>

      <!-- Main Layout -->
      <div class="relative z-10 max-w-[1400px] mx-auto flex flex-col lg:flex-row items-center justify-between gap-6 lg:gap-12">
        
        <!-- Left: Text info -->
        <div class="flex-grow flex flex-col md:flex-row items-center md:items-start gap-4 md:gap-6 text-center md:text-left">
          <!-- Release Image Thumbnail -->
          {activeLanzamiento.imagen_desktop ? (
            <img 
              src={activeLanzamiento.imagen_desktop} 
              alt={activeLanzamiento.nombre} 
              class="w-16 h-16 md:w-20 md:h-20 rounded-lg object-cover border border-white/10 shadow-lg shadow-black/40 hover:scale-[1.03] transition-transform duration-300 shrink-0" 
            />
          ) : (
            <div class="w-16 h-16 md:w-20 md:h-20 bg-slate-950 border border-white/10 rounded-lg flex items-center justify-center text-2xl shrink-0">
              🚀
            </div>
          )}
          
          <div class="flex-grow">
            <div class="flex items-center justify-center md:justify-start gap-2.5 mb-1.5 flex-wrap">
              <span 
                class="text-[9px] font-extrabold tracking-widest px-2.5 py-0.5 rounded-sm uppercase font-title"
                style={`background-color: ${activeLanzamiento.color_principal}; color: #ffffff;`}
              >
                {activeLanzamiento.tipo === 'videoclip' ? 'Videoclip Oficial' : activeLanzamiento.tipo === 'album' ? 'Nuevo Álbum / EP' : 'Nuevo Single'}
              </span>
              <span id="lanzamiento-badge-estado" class="text-gold-bruna text-[10px] font-extrabold tracking-widest uppercase font-title animate-pulse">
                PRÓXIMO ESTRENO
