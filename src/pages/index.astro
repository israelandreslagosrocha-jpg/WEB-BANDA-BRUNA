---
import Layout from '../layouts/Layout.astro';
import { 
  getLatestVideo, 
  getInstagramFeed, 
  getFacebookFeed, 
  getNews 
} from '../services/socialApi.js';
import socialStats from '../data/socialStats.json';
import { supabase } from '../services/supabaseClient.js';

// Fetch mock social data at build time
const latestVideo = getLatestVideo();
const instagramFeed = getInstagramFeed();
const facebookFeed = getFacebookFeed();
const newsList = getNews();

// Cargar eventos activos desde Supabase ordenados por fecha ascendente
const { data: rawEvents } = await supabase
  .from('eventos')
  .select('*')
  .eq('publicado', true)
  .order('fecha', { ascending: true });

const months = ["ENE", "FEB", "MAR", "ABR", "MAY", "JUN", "JUL", "AGO", "SET", "OCT", "NOV", "DIC"];

const upcomingEvents = (rawEvents || []).map((event: any) => {
  const d = new Date(event.fecha + 'T12:00:00'); // Evitar descalces de zona horaria
  const day = d.getDate();
  const monthName = months[d.getMonth()];
  const year = d.getFullYear();
  const fullDateStr = event.fecha.replace(/-/g, '');

  const isNegociacion = (event.lugar && event.lugar.toLowerCase().includes('negociación')) || 
                        (event.lugar && event.lugar.toLowerCase().includes('negociacion')) ||
                        (event.nombre && event.nombre.toLowerCase().includes('negociación')) ||
                        (event.nombre && event.nombre.toLowerCase().includes('negociacion'));

  return {
    id: event.id,
    date: isNegociacion ? '—' : day,
    month: monthName,
    year: year,
    time: isNegociacion ? 'Por confirmar' : "20:00", // Hora por defecto
    title: event.nombre,
    venue: event.lugar || 'Por confirmar',
    location: event.ciudad || '',
    mapUrl: '#',
    statusType: isNegociacion ? 'pending' : 'confirmed',
    fullDate: fullDateStr
  };
}).slice(0, 5);

const experienciaImages = [
  "/assets/images/experiencia/experiencia_1.webp",
  "/assets/images/experiencia/experiencia_2.webp",
  "/assets/images/experiencia/experiencia_3.webp",
  "/assets/images/experiencia/experiencia_4.webp",
  "/assets/images/experiencia/experiencia_5.webp"
];

// Cargar estadísticas desde Supabase
const { data: dbConfig } = await supabase
  .from('configuracion')
  .select('*')
  .eq('id', 1)
  .single();

const config = dbConfig || {};
const stats = {
  musiciansTrajectory: config.cant_trayectoria !== undefined && config.cant_trayectoria !== null ? config.cant_trayectoria : socialStats.musiciansTrajectory,
  stageYears: config.cant_escenarios !== undefined && config.cant_escenarios !== null ? config.cant_escenarios : socialStats.stageYears,
  instagramFollowers: config.cant_instagram !== undefined && config.cant_instagram !== null ? config.cant_instagram : socialStats.instagramFollowers,
  facebookFriends: config.cant_facebook !== undefined && config.cant_facebook !== null ? config.cant_facebook : socialStats.facebookFriends,
  youtubeSubscribers: config.cant_youtube !== undefined && config.cant_youtube !== null ? config.cant_youtube : socialStats.youtubeSubscribers,
  tiktokFollowers: config.cant_tiktok !== undefined && config.cant_tiktok !== null ? config.cant_tiktok : socialStats.tiktokFollowers,
  regions: config.cant_regiones !== undefined && config.cant_regiones !== null ? config.cant_regiones : socialStats.regions
};

// Cargar testimonios aprobados
const { data: dbTestimonios } = await supabase
  .from('testimonios')
  .select('*')
  .eq('aprobado', true)
  .order('created_at', { ascending: false });

const testimonios = dbTestimonios || [];

// Cargar lanzamiento activo desde Supabase para la campaña musical
let activeLanzamiento = null;
try {
  const { data: dbLanzamientos } = await supabase
    .from('lanzamientos')
    .select('*')
    .eq('estado', 'publicado')
    .eq('mostrar_home', true)
    .lte('fecha_inicio', new Date().toISOString())
    .order('orden', { ascending: true })
    .order('fecha_lanzamiento', { ascending: true })
    .limit(1);

  if (dbLanzamientos && dbLanzamientos.length > 0) {
    activeLanzamiento = dbLanzamientos[0];
  }
} catch (err) {
  console.error("Error al cargar lanzamiento activo:", err);
}
---

<Layout title="Banda Bruna | Orquesta Oficial - Música en Vivo para Eventos y Festivales" description="Sitio oficial de Banda Bruna. Cumbia sureña y cumbia chilena en vivo para festivales municipales, bodas y eventos corporativos.">
