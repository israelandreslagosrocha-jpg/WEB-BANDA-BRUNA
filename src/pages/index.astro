                  id="qh-type" 
                  name="event-type"
                  class="bg-slate-950/80 border border-white/5 rounded-sm p-3 text-white text-xs outline-none focus:border-gold-bruna transition-colors cursor-pointer"
                >
                  <option value="" disabled selected>Tipo de evento</option>
                  <option value="municipal">Festival Municipal / Show Público</option>
                  <option value="costumbrista">Fiesta Costumbrista</option>
                  <option value="corporativo">Evento Corporativo / Empresa</option>
                  <option value="matrimonio">Matrimonio / Fiesta Privada</option>
                  <option value="otro">Otro</option>
                </select>
                <span class="text-[9px] text-red-400 hidden" id="qh-type-err">Selecciona tipo de evento.</span>
              </div>
            </div>

            <!-- Row 3: Fecha & Ciudad/Comuna -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label for="qh-date" class="sr-only">Fecha tentativa del evento</label>
                <input 
                  type="date" 
                  id="qh-date" 
                  name="event-date"
                  required
                  class="bg-slate-950/80 border border-white/5 rounded-sm p-3 text-white text-xs outline-none focus:border-gold-bruna transition-colors cursor-pointer"
                />
                <span class="text-[9px] text-red-400 hidden" id="qh-date-err">Selecciona la fecha.</span>
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="qh-city" class="sr-only">Ciudad o comuna del evento</label>
                <input 
                  type="text" 
                  id="qh-city" 
                  name="city" 
                  placeholder="Ciudad / Comuna del evento" 
                  required
                  class="bg-slate-950/80 border border-white/5 rounded-sm p-3 text-white text-xs outline-none focus:border-gold-bruna transition-colors"
                />
                <span class="text-[9px] text-red-400 hidden" id="qh-city-err">Ingresa la comuna.</span>
              </div>
            </div>

            <!-- Textarea: Requerimientos/Detalles -->
            <div class="flex flex-col gap-1.5">
              <label for="qh-message" class="sr-only">Detalles adicionales del show</label>
              <textarea 
                id="qh-message" 
                name="message" 
                rows="4" 
                placeholder="Detalles adicionales del show (escenario, horarios, duración, etc.)"
                class="bg-slate-950/80 border border-white/5 rounded-sm p-3 text-white text-xs outline-none focus:border-gold-bruna transition-colors resize-none"
              ></textarea>
            </div>

            <button type="submit" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black font-title font-bold py-3.5 rounded-sm text-xs transition-colors cursor-pointer uppercase tracking-widest mt-2 w-full">
              ENVIAR SOLICITUD DE COTIZACIÓN
            </button>
            
            <div id="qh-form-feedback" class="hidden text-center text-xs py-2.5 px-4 rounded border" role="alert"></div>

          </form>
        </div>

        <!-- Success Panel (Hidden by default) -->
        <div id="success-panel-home" class="hidden text-center flex flex-col items-center gap-5 py-4">
          <div class="w-14 h-14 rounded-full bg-green-950/40 border border-green-500/30 text-green-400 flex items-center justify-center text-2xl animate-bounce">
            ✓
          </div>
          <div>
            <h3 class="font-title font-extrabold text-xl text-white uppercase tracking-wide">¡Cotización Procesada!</h3>
            <p class="text-slate-300 text-xs font-light mt-1.5 max-w-md mx-auto leading-relaxed">
              Hemos enviado un correo electrónico con todos los detalles de tu cotización a <strong class="text-white">contacto@bandabruna.cl</strong>.
            </p>
          </div>

          <div class="w-full max-w-md border-t border-white/5 pt-4 mt-1 flex flex-col gap-3">
            <span class="text-[9px] font-bold text-slate-500 tracking-widest uppercase">Notificar por WhatsApp</span>
            <p class="text-slate-400 text-[10px] font-light leading-relaxed">
              Hemos intentado abrir WhatsApp para avisar a Jaime Cárdenas. Si no se abrió, haz clic en el siguiente botón para abrir el chat con el mensaje:
            </p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-1">
              <a id="btn-wa-jaime-home" href="#" target="_blank" rel="noopener" class="bg-green-600 hover:bg-green-700 text-white font-bold text-[10px] py-2.5 px-3 rounded transition-all flex items-center justify-center gap-1.5 uppercase tracking-wide">
                Jaime Cárdenas
              </a>
              <a id="btn-wa-cesar-home" href="#" target="_blank" rel="noopener" class="bg-green-600 hover:bg-green-700 text-white font-bold text-[10px] py-2.5 px-3 rounded transition-all flex items-center justify-center gap-1.5 uppercase tracking-wide">
                César Bruna
              </a>
            </div>
          </div>

          <button id="btn-reset-home-form" class="mt-2 text-slate-400 hover:text-gold-bruna text-[10px] font-bold uppercase tracking-wider transition-colors cursor-pointer">
            Cotizar otro show
          </button>
        </div>

      </div>

    </div>
  </section>

  <!-- Script for form submission -->
  <script>
    import { supabase } from '../services/supabaseClient.js';

    const formH = document.getElementById('quote-form-home');
    const formContainerH = document.getElementById('booking-form-container-home');
    const successPanelH = document.getElementById('success-panel-home');
    const feedbackH = document.getElementById('qh-form-feedback');
    const nameInputH = document.getElementById('qh-name');
    const phoneInputH = document.getElementById('qh-phone');
    const emailInputH = document.getElementById('qh-email');
    const typeInputH = document.getElementById('qh-type');
    const dateInputH = document.getElementById('qh-date');
    const cityInputH = document.getElementById('qh-city');
    const messageInputH = document.getElementById('qh-message');

    const nameErrH = document.getElementById('qh-name-err');
    const phoneErrH = document.getElementById('qh-phone-err');
    const emailErrH = document.getElementById('qh-email-err');
    const typeErrH = document.getElementById('qh-type-err');
    const dateErrH = document.getElementById('qh-date-err');
    const cityErrH = document.getElementById('qh-city-err');
    const btnResetH = document.getElementById('btn-reset-home-form');

    if (formH) {
      formH.addEventListener('submit', (e) => {
        e.preventDefault();
        
        nameErrH.classList.add('hidden');
        phoneErrH.classList.add('hidden');
        emailErrH.classList.add('hidden');
        typeErrH.classList.add('hidden');
        dateErrH.classList.add('hidden');
        cityErrH.classList.add('hidden');
        feedbackH.classList.add('hidden');

        let valid = true;

        if (!nameInputH.value.trim()) {
          nameErrH.classList.remove('hidden');
          valid = false;
        }

        if (!phoneInputH.value.trim()) {
          phoneErrH.classList.remove('hidden');
          valid = false;
        }

        if (!emailInputH.value.trim() || !emailInputH.checkValidity()) {
          emailErrH.classList.remove('hidden');
          valid = false;
        }

        if (!typeInputH.value) {
          typeErrH.classList.remove('hidden');
          valid = false;
        }

        if (!dateInputH.value) {
          dateErrH.classList.remove('hidden');
          valid = false;
        }

        if (!cityInputH.value.trim()) {
          cityErrH.classList.remove('hidden');
          valid = false;
        }

        if (!valid) return;

        const btn = formH.querySelector('button[type="submit"]');
        const origText = btn.textContent;
        btn.textContent = 'Enviando...';
        btn.disabled = true;

        const nameVal = nameInputH.value.trim();
        const phoneVal = phoneInputH.value.trim();
        const emailVal = emailInputH.value.trim();
        const typeVal = typeInputH.options[typeInputH.selectedIndex].text;
        const dateVal = dateInputH.value;
        const cityVal = cityInputH.value.trim();
        const msgVal = messageInputH.value.trim() || 'Sin detalles adicionales.';

        // Guardar cotización en Supabase
        supabase.from('cotizaciones').insert([
          {
            nombre: nameVal,
            telefono: phoneVal,
            email: emailVal,
            fecha_evento: dateVal || null,
            ciudad: cityVal,
            tipo_evento: typeVal,
            mensaje: msgVal
          }
        ]).then(({ error }) => {
          if (error) {
            console.error('Error al guardar en Supabase:', error);
          } else {
            console.log('Cotización guardada exitosamente en Supabase (desde Home)');
          }
        });

        // Send email asynchronously using FormSubmit.co
        fetch("https://formsubmit.co/ajax/contacto@bandabruna.cl", {
          method: "POST",
          headers: { 
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({
            "_cc": "contactobandabruna@gmail.com",
            "Asunto": "Nueva Cotización desde Home del Sitio Web",
            "Nombre": nameVal,
            "Teléfono": phoneVal,
            "Email": emailVal,
            "Tipo de Evento": typeVal,
            "Fecha Tentativa": dateVal,
            "Ciudad/Comuna": cityVal,
            "Detalles/Mensaje": msgVal
          })
        })
        .then(response => {
          if (!response.ok) throw new Error('Error de envío.');
          return response.json();
        })
        .then(() => {
          btn.textContent = origText;
          btn.disabled = false;

          // Formulate WhatsApp notification message
          const waMessage = `*Nueva Solicitud de Cotización - Banda Bruna*\n\n` +
            `👤 *Contacto:* ${nameVal}\n` +
            `📞 *Fono:* ${phoneVal}\n` +
            `📧 *Email:* ${emailVal}\n` +
            `🎭 *Evento:* ${typeVal}\n` +
            `📅 *Fecha:* ${dateVal}\n` +
            `📍 *Ciudad/Comuna:* ${cityVal}\n` +
            `📝 *Detalles:* ${msgVal}`;
          
          const encodedMessage = encodeURIComponent(waMessage);

          // Configure Jaime and Cesar WhatsApp links for Home success panel
          const btnJaimeH = document.getElementById('btn-wa-jaime-home');
          const btnCesarH = document.getElementById('btn-wa-cesar-home');
          if (btnJaimeH) btnJaimeH.href = `https://wa.me/56990021689?text=${encodedMessage}`;
          if (btnCesarH) btnCesarH.href = `https://wa.me/56976149408?text=${encodedMessage}`;

          // Try opening Jaime's WhatsApp window automatically
          window.open(`https://wa.me/56990021689?text=${encodedMessage}`, '_blank');

          // Hide form container and show success panel
          if (formContainerH) formContainerH.classList.add('hidden');
          if (successPanelH) successPanelH.classList.remove('hidden');

          formH.reset();
        })
        .catch((err) => {
          btn.textContent = origText;
          btn.disabled = false;
          feedbackH.textContent = 'Hubo un inconveniente al enviar tu cotización por correo. Por favor, intenta de nuevo o contáctanos por WhatsApp.';
          feedbackH.className = 'text-center text-xs py-2.5 px-4 rounded border bg-red-950/20 border-red-500/20 text-red-400 mt-2 block';
        });
      });
    }

    if (btnResetH) {
      btnResetH.addEventListener('click', () => {
        if (successPanelH) successPanelH.classList.add('hidden');
        if (formContainerH) formContainerH.classList.remove('hidden');
      });
    }

    // HERO BACKGROUND SLIDER LOGIC
    const slides = document.querySelectorAll('.hero-slide');
    const prevBtn = document.getElementById('hero-prev');
    const nextBtn = document.getElementById('hero-next');
    
    let currentIndex = 0;
    let autoplayInterval;
    const slideDuration = 6000; // 6 seconds per slide
    
    function showSlide(index) {
      if (index >= slides.length) currentIndex = 0;
      else if (index < 0) currentIndex = slides.length - 1;
      else currentIndex = index;
      
      slides.forEach((slide, idx) => {
        if (idx === currentIndex) {
          slide.classList.remove('opacity-0', 'scale-105');
          slide.classList.add('opacity-100', 'scale-100');
        } else {
          slide.classList.remove('opacity-100', 'scale-100');
          slide.classList.add('opacity-0', 'scale-105');
        }
      });
    }
    
    function startAutoplay() {
      clearInterval(autoplayInterval);
      autoplayInterval = setInterval(() => {
        showSlide(currentIndex + 1);
      }, slideDuration);
    }
    
    if (nextBtn && prevBtn) {
      nextBtn.addEventListener('click', () => {
        showSlide(currentIndex + 1);
        startAutoplay();
      });
      
      prevBtn.addEventListener('click', () => {
        showSlide(currentIndex - 1);
        startAutoplay();
      });
    }
    
    // Initialize slider
    showSlide(0);
    startAutoplay();

    // EXPERIENCIA BRUNA SLIDER LOGIC
    function setupExperienciaSlider() {
      const prevBtn = document.getElementById('exp-prev');
      const nextBtn = document.getElementById('exp-next');
      const track = document.getElementById('exp-slider-track');
      const container = document.getElementById('exp-slider-container');
      
      if (!track || !container || !prevBtn || !nextBtn) return;
      
      const items = track.children;
      if (items.length === 0) return;
      
      let expIndex = 0;
      let itemWidth = items[0] ? items[0].getBoundingClientRect().width : 0;
      const gap = 16; // gap-4 is 16px
      
      function getVisibleItemsCount() {
        const width = window.innerWidth;
        if (width >= 768) return 4;
        if (width >= 640) return 3;
        return 2;
      }
      
      function updateSlider() {
        const visibleCount = getVisibleItemsCount();
        const maxIndex = items.length - visibleCount;
        
        if (expIndex < 0) expIndex = 0;
        if (expIndex > maxIndex) expIndex = maxIndex;
        
        const offset = expIndex * (itemWidth + gap);
        
        track.style.transform = `translateX(-${offset}px)`;
        
        prevBtn.disabled = expIndex === 0;
        nextBtn.disabled = expIndex === maxIndex;
      }
      
      const newPrev = prevBtn.cloneNode(true);
      prevBtn.parentNode.replaceChild(newPrev, prevBtn);
      newPrev.addEventListener('click', () => {
        expIndex--;
        updateSlider();
      });
      
      const newNext = nextBtn.cloneNode(true);
      nextBtn.parentNode.replaceChild(newNext, nextBtn);
      newNext.addEventListener('click', () => {
        expIndex++;
        updateSlider();
      });
      
      function handleResize() {
        itemWidth = items[0] ? items[0].getBoundingClientRect().width : 0;
        updateSlider();
      }
      
      window.addEventListener('resize', handleResize);
      
      let startX = 0;
      container.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
      }, { passive: true });
      
      container.addEventListener('touchend', (e) => {
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;
        const visibleCount = getVisibleItemsCount();
        const maxIndex = items.length - visibleCount;
        
        if (Math.abs(diff) > 40) {
          if (diff > 0 && expIndex < maxIndex) {
            expIndex++;
          } else if (diff < 0 && expIndex > 0) {
            expIndex--;
          }
          updateSlider();
        }
      }, { passive: true });
      
      updateSlider();
    }

    setupExperienciaSlider();
    document.addEventListener('astro:after-swap', setupExperienciaSlider);

    // COUNT UP ANIMATION LOGIC FOR STATISTICS
    function setupCountUp() {
      const counters = document.querySelectorAll('[data-count-target]');
      if (counters.length === 0) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const counter = entry.target;
            const target = parseFloat(counter.getAttribute('data-count-target'));
            const duration = 2000; // 2 seconds animation
            const startTime = performance.now();
            const prefix = counter.getAttribute('data-count-prefix') || '';
            const suffix = counter.getAttribute('data-count-suffix') || '';
            const isDecimal = counter.hasAttribute('data-count-decimal');

            function animate(currentTime) {
              const elapsed = currentTime - startTime;
              const progress = Math.min(elapsed / duration, 1);
              
              // Easing function outQuad
              const easeProgress = progress * (2 - progress);
              
              let currentVal = easeProgress * target;
              
              if (isDecimal) {
                counter.textContent = prefix + currentVal.toFixed(1).replace('.', ',') + suffix;
              } else {
                counter.textContent = prefix + Math.floor(currentVal).toLocaleString('es-CL') + suffix;
              }

              if (progress < 1) {
                requestAnimationFrame(animate);
              } else {
                if (isDecimal) {
                  counter.textContent = prefix + target.toFixed(1).replace('.', ',') + suffix;
                } else {
                  counter.textContent = prefix + target.toLocaleString('es-CL') + suffix;
                }
              }
            }

            requestAnimationFrame(animate);
            observer.unobserve(counter);
          }
        });
      }, { threshold: 0.1 });

      counters.forEach(counter => {
        observer.observe(counter);
      });
    }

    setupCountUp();

    // CONTROL DEL CARRUSEL DE VIDEOS DESTACADOS DEL HOME
    function setupHomeVideoCarousel() {
      const carousel = document.getElementById('home-video-carousel');
      const prevBtn = document.getElementById('home-prev-video');
      const nextBtn = document.getElementById('home-next-video');
      const dots = document.querySelectorAll('[data-home-slide]');
      const videos = document.querySelectorAll('#home-video-carousel video') as NodeListOf<HTMLVideoElement>;

      if (!carousel || videos.length === 0) return;

      let currentSlide = 0;

      function updateCarousel(index: number) {
        // Pausar todos los videos de este carrusel
        videos.forEach(vid => vid.pause());

        currentSlide = index;
        carousel.style.transform = `translateX(-${currentSlide * 100}%)`;

        // Actualizar dots
        dots.forEach((dot, idx) => {
          if (idx === currentSlide) {
            dot.classList.add('bg-white');
            dot.classList.remove('bg-white/40');
          } else {
            dot.classList.remove('bg-white');
            dot.classList.add('bg-white/40');
          }
        });
      }

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener('click', () => {
          let index = currentSlide - 1;
          if (index < 0) index = videos.length - 1;
          updateCarousel(index);
        });

        nextBtn.addEventListener('click', () => {
          let index = currentSlide + 1;
          if (index >= videos.length) index = 0;
          updateCarousel(index);
        });
      }

      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          updateCarousel(idx);
        });
      });

      // Inicializar primer estado
      updateCarousel(0);
    }

    setupHomeVideoCarousel();

    document.addEventListener('astro:after-swap', () => {
      setupCountUp();
      setupHomeVideoCarousel();
    });
  </script>
</Layout>
