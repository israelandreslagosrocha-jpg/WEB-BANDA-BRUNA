            </div>
            <h3 class="text-lg md:text-xl font-extrabold font-title tracking-wide text-white uppercase mb-1 leading-tight">
              {activeLanzamiento.titulo}
            </h3>
            <p class="text-xs text-slate-350 font-light max-w-2xl leading-relaxed">
              <strong class="text-white font-medium">{activeLanzamiento.bold_text}</strong> {activeLanzamiento.descripcion}
            </p>
          </div>
        </div>

        <!-- Middle/Right: Countdown & CTA -->
        <div class="flex flex-col sm:flex-row items-center gap-6 shrink-0 w-full lg:w-auto justify-end">
          
          <!-- Countdown container -->
          <div id="lanzamiento-countdown-container" class="flex items-center gap-3">
            <div class="flex flex-col items-center justify-center bg-black/40 border border-white/5 rounded-lg px-3 py-2 w-14 backdrop-blur-sm">
              <span id="countdown-days" class="text-lg md:text-xl font-extrabold text-white font-mono leading-none">00</span>
              <span class="text-[8px] text-slate-500 uppercase tracking-widest font-bold mt-1">Días</span>
            </div>
            <div class="flex flex-col items-center justify-center bg-black/40 border border-white/5 rounded-lg px-3 py-2 w-14 backdrop-blur-sm">
              <span id="countdown-hours" class="text-lg md:text-xl font-extrabold text-white font-mono leading-none">00</span>
              <span class="text-[8px] text-slate-500 uppercase tracking-widest font-bold mt-1">Horas</span>
            </div>
            <div class="flex flex-col items-center justify-center bg-black/40 border border-white/5 rounded-lg px-3 py-2 w-14 backdrop-blur-sm">
              <span id="countdown-minutes" class="text-lg md:text-xl font-extrabold text-white font-mono leading-none">00</span>
              <span class="text-[8px] text-slate-500 uppercase tracking-widest font-bold mt-1">Min</span>
            </div>
            <div class="flex flex-col items-center justify-center bg-black/40 border border-white/5 rounded-lg px-3 py-2 w-14 backdrop-blur-sm">
              <span id="countdown-seconds" class="text-lg md:text-xl font-extrabold text-white font-mono leading-none" style={`color: ${activeLanzamiento.color_principal};`}>00</span>
              <span class="text-[8px] text-slate-500 uppercase tracking-widest font-bold mt-1">Seg</span>
            </div>
          </div>

          <!-- Buttons / CTA -->
          <div class="flex flex-col gap-2 w-full sm:w-auto shrink-0">
            <a 
              href={`/${activeLanzamiento.slug}`} 
              class="w-full sm:w-auto bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black px-6 py-3 rounded-md font-extrabold text-xs tracking-widest hover:scale-105 active:scale-95 transition-all text-center uppercase shadow-lg shadow-gold-bruna/10 cursor-pointer block"
            >
              IR AL LANZAMIENTO
            </a>
          </div>

        </div>

      </div>
    </div>

    <!-- Countdown Javascript Client-side Script -->
    <script is:inline>
      (function() {
        const block = document.getElementById('homepage-lanzamiento-block');
        if (!block) return;

        const launchDateStr = block.getAttribute('data-launch-date');
        if (!launchDateStr) return;

        let launchDate = new Date(launchDateStr).getTime();
        const countdownContainer = document.getElementById('lanzamiento-countdown-container');
        const badgeEstado = document.getElementById('lanzamiento-badge-estado');
        
        const daysEl = document.getElementById('countdown-days');
        const hoursEl = document.getElementById('countdown-hours');
        const minutesEl = document.getElementById('countdown-minutes');
        const secondsEl = document.getElementById('countdown-seconds');

        // Consulta en tiempo real a Supabase para evitar desfases por caché estática (SSG)
        const supabaseUrl = block.getAttribute('data-supabase-url');
        const supabaseKey = block.getAttribute('data-supabase-key');
        const slug = block.getAttribute('data-slug');

        if (supabaseUrl && supabaseKey && slug) {
          fetch(`${supabaseUrl}/rest/v1/lanzamientos?slug=eq.${slug}&select=fecha_lanzamiento`, {
            headers: {
              'apikey': supabaseKey,
              'Authorization': `Bearer ${supabaseKey}`
            }
          })
          .then(res => res.json())
          .then(data => {
            if (data && data.length > 0 && data[0].fecha_lanzamiento) {
              launchDate = new Date(data[0].fecha_lanzamiento).getTime();
              updateTimer();
            }
          })
          .catch(err => console.error("Error al obtener fecha en tiempo real:", err));
        }

        function updateTimer() {
          const now = new Date().getTime();
          const distance = launchDate - now;

          if (distance <= 0) {
            // Lanzado
            if (countdownContainer) countdownContainer.style.display = 'none';
            if (badgeEstado) {
              badgeEstado.textContent = '¡YA DISPONIBLE!';
              badgeEstado.className = 'text-green-400 text-[10px] font-extrabold tracking-widest uppercase font-title border border-green-500/20 bg-green-950/40 px-2 py-0.5 rounded-sm';
            }
            clearInterval(timerInterval);
            return;
          }

          // Calcular tiempos
          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          // Mostrar
          if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
          if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
          if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
          if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
        }

        updateTimer();
        const timerInterval = setInterval(updateTimer, 1000);
      })();
    </script>
  )}
  
