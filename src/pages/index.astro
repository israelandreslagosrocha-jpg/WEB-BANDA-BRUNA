  <!-- Script for form submission -->
  <script>
    const formH = document.getElementById('quote-form-home-mock');
    const feedbackH = document.getElementById('qh-form-feedback');
    const nameInputH = document.getElementById('qh-name');
    const emailInputH = document.getElementById('qh-email');
    const typeInputH = document.getElementById('qh-type');
    const dateInputH = document.getElementById('qh-date');

    const nameErrH = document.getElementById('qh-name-err');
    const emailErrH = document.getElementById('qh-email-err');
    const typeErrH = document.getElementById('qh-type-err');
    const dateErrH = document.getElementById('qh-date-err');

    if (formH) {
      formH.addEventListener('submit', (e) => {
        e.preventDefault();
        
        nameErrH.classList.add('hidden');
        emailErrH.classList.add('hidden');
        typeErrH.classList.add('hidden');
        dateErrH.classList.add('hidden');
        feedbackH.classList.add('hidden');

        let valid = true;

        if (!nameInputH.value.trim()) {
          nameErrH.classList.remove('hidden');
          valid = false;
        }

        if (!emailInputH.value.trim() || !emailInputH.checkValidity()) {
          emailErrH.classList.remove('hidden');
          valid = false;
        }

        if (!typeInputH.value) {
          typeErrH.classList.remove('hidden');
          valid = false;
        }

        if (!dateInputH.value) {
          dateErrH.classList.remove('hidden');
          valid = false;
        }

        if (!valid) return;

        const btn = formH.querySelector('button[type="submit"]');
        const origText = btn.textContent;
        btn.textContent = 'Enviando...';
        btn.disabled = true;

        setTimeout(() => {
          btn.textContent = origText;
          btn.disabled = false;

          feedbackH.textContent = '¡Tu solicitud ha sido enviada con éxito!';
          feedbackH.className = 'text-center text-xs py-2.5 px-4 rounded border bg-green-950/20 border-green-500/20 text-green-400 block';
          
          formH.reset();
        }, 1200);
      });
    }
  </script>

