---
import Layout from '../layouts/Layout.astro';
import { getBandMembers } from '../services/socialApi.js';

const members = getBandMembers();
---

<Layout title="La Banda | Banda Bruna - Historia y Biografía Oficial" description="Conoce la historia oficial de Banda Bruna, sus raíces en la cumbia chilena y rock alternativo, y su trayectoria musical en el sur de Chile.">
  <section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">BIOGRAFÍA</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">LA BANDA</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- Biography block -->
    <div class="prose prose-invert max-w-none text-slate-300 font-light space-y-6 text-base md:text-lg leading-relaxed">
      <p>
        Nacida en la ciudad de <strong>Temuco</strong>, en el corazón del sur de Chile, <strong>Banda Bruna</strong> es la colisión perfecta entre el ritmo contagioso de la cumbia chilena y la energía visceral del rock alternativo y el indie contemporáneo.
      </p>
      <p>
        Desde sus inicios, la banda se propuso romper los moldes de la música tropical tradicional, inyectando guitarras eléctricas crudas, atmósferas espaciales de sintetizadores y un groove sólido que resuena con fuerza tanto en festivales masivos como en escenarios íntimos.
      </p>
      <p>
        Con un repertorio cargado de letras que exploran el amor, la melancolía del sur y la alegría de la fiesta popular, Banda Bruna ha recorrido múltiples comunas de las regiones de La Araucanía, Biobío y Los Ríos, consolidándose como una de las agrupaciones con mayor proyección en la cumbia sureña moderna.
      </p>
      <p>
        Cada concierto en vivo de Banda Bruna es planteado como un espectáculo audiovisual de alta intensidad, diseñado para hacer bailar al público mientras se sumergen en un viaje sónico sofisticado y bailable.
      </p>
    </div>

    <!-- Centered Logo Separator -->
    <div class="flex justify-center my-16 opacity-30">
      <img src="/assets/images/logos/logo_3.webp" alt="Isotipo Banda Bruna" class="h-28 w-auto object-contain" />
    </div>

    <!-- Integrantes Section in banda.astro -->
    <div class="mb-16 overflow-hidden">
      <div class="text-center mb-12">
        <span class="text-gold-bruna text-xs tracking-widest font-semibold uppercase block mb-1">MIEMBROS OFICIALES</span>
        <h2 class="text-2xl font-bold font-title uppercase text-white">NUESTROS INTEGRANTES</h2>
        <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-3"></div>
      </div>

      <!-- Members Slider Container -->
      <div class="relative w-full px-2 md:px-10">
        
        <!-- Viewport -->
        <div class="overflow-hidden w-full">
          <!-- Track -->
          <div id="band-members-track" class="flex transition-transform duration-500 ease-out">
            {members.map(member => (
              <div class="w-full md:w-1/2 lg:w-1/3 flex-shrink-0 px-3 md:px-4 box-border">
                <!-- Card -->
                <div class="relative overflow-hidden rounded-xl border border-white/5 bg-slate-900/40 transition-all duration-300 hover:border-gold-bruna/30 hover:shadow-[0_10px_30px_rgba(212,175,55,0.06)] group flex flex-col h-full">
                  
                  <!-- Image Container (object-contain ensures the image is NEVER cropped) -->
                  <div class="relative w-full aspect-[2/3] overflow-hidden bg-slate-950 flex-shrink-0 border-b border-white/5 flex items-center justify-center">
                    <img 
                      src={member.image} 
                      alt={member.name} 
                      class="w-full h-full object-contain group-hover:scale-102 transition-transform duration-500" 
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent pointer-events-none"></div>
                  </div>
                  
                  <!-- Info Box -->
                  <div class="p-5 flex-grow flex flex-col justify-between bg-slate-900/20">
                    <div>
                      <div class="flex items-center justify-between gap-4 border-b border-white/5 pb-2">
                        <h3 class="font-title font-bold text-sm text-white group-hover:text-gold-bruna transition-colors uppercase leading-snug">
                          {member.name}
                        </h3>
                        {member.instagram && (
                          <a 
                            href={member.instagram} 
                            target="_blank" 
                            rel="noopener" 
                            class="text-slate-400 hover:text-gold-bruna transition-colors p-1 flex-shrink-0" 
                            aria-label={`Instagram de ${member.name}`}
                          >
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                            </svg>
                          </a>
                        )}
                      </div>
                      <span class="text-[9px] font-bold text-gold-bruna uppercase tracking-widest block mt-2">
                        {member.role}
                      </span>
                      <p class="text-[11px] text-slate-400 font-light leading-relaxed mt-2 line-clamp-3 group-hover:text-slate-300 transition-colors">
                        {member.bio}
                      </p>
                    </div>
                  </div>

                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Navigation Arrows -->
        <button id="band-members-prev" class="absolute -left-2 md:-left-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 rounded-full border border-white/10 hover:border-gold-bruna bg-black/60 hover:bg-black/90 text-white hover:text-gold-bruna flex items-center justify-center transition-all cursor-pointer select-none" aria-label="Miembro anterior">
          <span class="text-lg">❮</span>
        </button>
        <button id="band-members-next" class="absolute -right-2 md:-right-4 top-1/2 -translate-y-1/2 z-30 w-10 h-10 rounded-full border border-white/10 hover:border-gold-bruna bg-black/60 hover:bg-black/90 text-white hover:text-gold-bruna flex items-center justify-center transition-all cursor-pointer select-none" aria-label="Miembro siguiente">
          <span class="text-lg">❯</span>
        </button>

      </div>
    </div>

    <!-- Highlight Callout -->
    <div class="bg-slate-900 border border-white/5 rounded-xl p-8 flex flex-col md:flex-row gap-6 items-center">
      <div class="flex-grow">
        <h2 class="font-title font-bold text-xl text-white mb-2">Nuestra Propuesta Artística</h2>
        <p class="text-sm text-slate-400 font-light">
          No somos solo un grupo musical; creamos un canal directo de alegría y energía bailable. Fusionamos instrumentación en vivo de alto calibre con una producción visual moderna que eleva cualquier evento corporativo, festival o celebración privada.
        </p>
      </div>
      <a href="/contrataciones" class="bg-gold-bruna text-black px-6 py-3 rounded font-bold hover:scale-105 transition-all cursor-pointer whitespace-nowrap">
        COTIZAR FECHA
      </a>
    </div>

  </section>

  <!-- Slider logic script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const track = document.getElementById('band-members-track');
      const prevBtn = document.getElementById('band-members-prev');
      const nextBtn = document.getElementById('band-members-next');

      if (track && prevBtn && nextBtn) {
        let currentIndex = 0;
        let autoplayInterval;
        const autoplayDelay = 5000;

        function getVisibleCount() {
          if (window.innerWidth >= 1024) return 3;
          if (window.innerWidth >= 768) return 2;
          return 1;
        }

        function updateSlider() {
          const visibleCount = getVisibleCount();
          const totalItems = track.children.length;
          const maxIndex = Math.max(0, totalItems - visibleCount);

          if (currentIndex > maxIndex) currentIndex = maxIndex;
          if (currentIndex < 0) currentIndex = 0;

          const percentage = -(currentIndex * (100 / visibleCount));
          track.style.transform = `translateX(${percentage}%)`;

          // Button visibility styles
          prevBtn.style.opacity = currentIndex === 0 ? '0.2' : '1';
          prevBtn.style.cursor = currentIndex === 0 ? 'default' : 'pointer';
          prevBtn.style.pointerEvents = currentIndex === 0 ? 'none' : 'auto';

          nextBtn.style.opacity = currentIndex === maxIndex ? '0.2' : '1';
          nextBtn.style.cursor = currentIndex === maxIndex ? 'default' : 'pointer';
          nextBtn.style.pointerEvents = currentIndex === maxIndex ? 'none' : 'auto';
        }

        function startAutoplay() {
          clearInterval(autoplayInterval);
          autoplayInterval = setInterval(() => {
            const visibleCount = getVisibleCount();
            const totalItems = track.children.length;
            const maxIndex = Math.max(0, totalItems - visibleCount);

            if (currentIndex >= maxIndex) {
              currentIndex = 0;
            } else {
              currentIndex++;
            }
            updateSlider();
          }, autoplayDelay);
        }

        prevBtn.addEventListener('click', () => {
          currentIndex--;
          updateSlider();
          startAutoplay();
        });

        nextBtn.addEventListener('click', () => {
          currentIndex++;
          updateSlider();
          startAutoplay();
        });

        window.addEventListener('resize', () => {
          updateSlider();
        });

        // Initialize
        updateSlider();
        startAutoplay();
      }
    });
  </script>
</Layout>
