        modal.classList.remove('hidden');

        const pickerP = document.getElementById('lan-color-principal-picker') as HTMLInputElement;
        const textP = document.getElementById('lan-color-principal') as HTMLInputElement;
        pickerP?.addEventListener('input', (e) => { textP.value = (e.target as HTMLInputElement).value; });
        textP?.addEventListener('change', (e) => { pickerP.value = (e.target as HTMLInputElement).value; });

        const pickerS = document.getElementById('lan-color-secundario-picker') as HTMLInputElement;
        const textS = document.getElementById('lan-color-secundario') as HTMLInputElement;
        pickerS?.addEventListener('input', (e) => { textS.value = (e.target as HTMLInputElement).value; });
        textS?.addEventListener('change', (e) => { pickerS.value = (e.target as HTMLInputElement).value; });

        document.getElementById('btn-modal-cancel')?.addEventListener('click', () => modal.classList.add('hidden'));

        document.getElementById('lanzamiento-form')?.addEventListener('submit', async (e) => {
          e.preventDefault();

          const nombre = (document.getElementById('lan-nombre') as HTMLInputElement).value;
          const slug = (document.getElementById('lan-slug') as HTMLInputElement).value.trim().toLowerCase().replace(/[^a-z0-9-_]/g, '-');
          const tipo = (document.getElementById('lan-tipo') as HTMLSelectElement).value;
          const estado = (document.getElementById('lan-estado') as HTMLSelectElement).value;
          
          const rawLanzamiento = (document.getElementById('lan-fecha-lanzamiento') as HTMLInputElement).value;
          const rawInicio = (document.getElementById('lan-fecha-inicio') as HTMLInputElement).value;
          
          const fecha_lanzamiento = rawLanzamiento ? new Date(rawLanzamiento).toISOString() : new Date().toISOString();
          const fecha_inicio = rawInicio ? new Date(rawInicio).toISOString() : new Date().toISOString();
          
          const mostrar_home = (document.getElementById('lan-mostrar-home') as HTMLInputElement).checked;
          const mostrar_contador = (document.getElementById('lan-mostrar-contador') as HTMLInputElement).checked;
          const mostrar_plataformas = (document.getElementById('lan-mostrar-plataformas') as HTMLInputElement).checked;
          const activar_auto = (document.getElementById('lan-activar-auto') as HTMLInputElement).checked;
          const orden = parseInt((document.getElementById('lan-orden') as HTMLInputElement).value) || 0;
          const titulo = (document.getElementById('lan-titulo') as HTMLInputElement).value;
          const subtitulo = (document.getElementById('lan-subtitulo') as HTMLInputElement).value;
          const descripcion = (document.getElementById('lan-descripcion') as HTMLTextAreaElement).value;
          const bold_text = (document.getElementById('lan-bold-text') as HTMLInputElement).value;
          const color_principal = textP.value;
          const color_secundario = textS.value;
          const historia = (document.getElementById('lan-historia') as HTMLTextAreaElement).value;

          const galeria_images = (document.getElementById('lan-galeria') as HTMLTextAreaElement).value
            .split('\n')
            .map(url => url.trim())
            .filter(url => url.length > 0);

          const making_of_images = (document.getElementById('lan-making') as HTMLTextAreaElement).value
            .split('\n')
            .map(url => url.trim())
            .filter(url => url.length > 0);

          let detras_camaras_videos = [];
          try {
            detras_camaras_videos = JSON.parse((document.getElementById('lan-vids') as HTMLTextAreaElement).value || '[]');
          } catch(err) {
            alert('El campo de Videos Detrás de Cámaras tiene un formato JSON inválido.');
            return;
          }

          const plataformas_links = {
            youtube: (document.getElementById('plat-youtube') as HTMLInputElement).value.trim(),
            spotify: (document.getElementById('plat-spotify') as HTMLInputElement).value.trim(),
            apple_music: (document.getElementById('plat-apple') as HTMLInputElement).value.trim(),
            youtube_music: (document.getElementById('plat-ytmusic') as HTMLInputElement).value.trim(),
            amazon_music: (document.getElementById('plat-amazon') as HTMLInputElement).value.trim(),
            deezer: (document.getElementById('plat-deezer') as HTMLInputElement).value.trim(),
            youtube_views: parseInt((document.getElementById('plat-youtube-views') as HTMLInputElement).value) || null,
            youtube_likes: parseInt((document.getElementById('plat-youtube-likes') as HTMLInputElement).value) || null
          };

          const meta_title = (document.getElementById('lan-meta-title') as HTMLInputElement).value;
          const meta_description = (document.getElementById('lan-meta-desc') as HTMLTextAreaElement).value;
          const keywords = (document.getElementById('lan-keywords') as HTMLInputElement).value;

          const desktopFile = (document.getElementById('lan-img-desktop') as HTMLInputElement).files?.[0];
          const mobileFile = (document.getElementById('lan-img-mobile') as HTMLInputElement).files?.[0];
          const bannerFile = (document.getElementById('lan-img-banner') as HTMLInputElement).files?.[0];

          let imagen_desktop = (document.getElementById('lan-img-desktop-url') as HTMLInputElement).value.trim() || lanzamiento.imagen_desktop;
          let imagen_mobile = (document.getElementById('lan-img-mobile-url') as HTMLInputElement).value.trim() || lanzamiento.imagen_mobile;
          let imagen_banner = (document.getElementById('lan-img-banner-url') as HTMLInputElement).value.trim() || lanzamiento.imagen_banner;

          if (desktopFile) {
            const uploaded = await uploadImageToStorage(desktopFile, 'noticias');
            if (uploaded) imagen_desktop = uploaded;
          }
          if (mobileFile) {
            const uploaded = await uploadImageToStorage(mobileFile, 'noticias');
            if (uploaded) imagen_mobile = uploaded;
          }
          if (bannerFile) {
            const uploaded = await uploadImageToStorage(bannerFile, 'noticias');
            if (uploaded) imagen_banner = uploaded;
          }

          const payload = {
            nombre,
            tipo,
            estado,
            slug,
            titulo,
            subtitulo,
            descripcion,
            bold_text,
            color_principal,
            color_secundario,
            fecha_lanzamiento,
            fecha_inicio,
            mostrar_home,
            mostrar_contador,
            mostrar_plataformas,
            activar_auto,
            orden,
            imagen_desktop,
            imagen_mobile,
            imagen_banner,
            imagen_compartir: imagen_desktop,
            historia,
            galeria_images,
            making_of_images,
            detras_camaras_videos,
            plataformas_links,
            meta_title,
            meta_description,
            keywords,
            updated_at: new Date().toISOString()
          };

          let success = false;
          if (id) {
            const { error } = await supabase.from('lanzamientos').update(payload).eq('id', id);
            if (!error) {
              success = true;
              await logAction('Editó el lanzamiento: "' + nombre + '"');
            } else {
              console.error(error);
              alert('Error al actualizar lanzamiento: ' + error.message);
            }
          } else {
            const { error } = await supabase.from('lanzamientos').insert([payload]);
            if (!error) {
              success = true;
              await logAction('Creó un nuevo lanzamiento: "' + nombre + '"');
            } else {
              console.error(error);
              alert('Error al crear lanzamiento: ' + error.message);
            }
          }

          if (success) {
            modal.classList.add('hidden');
            loadLanzamientos();
          }
        });
      }

      async function deleteLanzamiento(id: string | undefined, name: string | undefined) {
        if (!id || !confirm('¿Estás seguro de que deseas eliminar permanentemente el lanzamiento "' + (name || 'este lanzamiento') + '"?')) return;

        const { error } = await supabase
          .from('lanzamientos')
          .delete()
          .eq('id', id);

        if (!error) {
          await logAction('Eliminó permanentemente el lanzamiento "' + (name || id) + '"');
          loadLanzamientos();
        } else {
          alert('Error al eliminar el lanzamiento.');
        }
      }

      async function openCommentsModal(slug: string | undefined, name: string | undefined) {
        if (!slug) return;
        const modal = document.getElementById('modal-container');
        if (!modal) return;

        modal.innerHTML = `
          <div class="bg-slate-900 border border-white/5 w-full max-w-3xl rounded-2xl p-6 md:p-8 flex flex-col gap-6 max-h-[90vh] overflow-y-auto text-left">
            <div class="flex justify-between items-center border-b border-white/5 pb-3">
              <div>
                <h3 class="font-title font-bold text-base uppercase text-white">💬 Moderación de Opiniones</h3>
                <p class="text-[10px] text-slate-550 mt-0.5">Lanzamiento: <span class="text-gold-bruna uppercase font-bold">${name || slug}</span></p>
              </div>
              <button id="btn-close-comments-modal" class="text-slate-400 hover:text-white text-xs font-bold uppercase tracking-wider bg-slate-950 border border-white/5 hover:border-white/10 px-3 py-1.5 rounded transition-all cursor-pointer">Cerrar</button>
            </div>

            <!-- Listados -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <!-- Pendientes -->
              <div class="flex flex-col gap-4">
                <h4 class="text-[10px] font-extrabold text-amber-400 uppercase tracking-widest flex items-center gap-2">
                  ⚠️ Pendientes de Aprobación
                  <span id="mod-pendientes-count" class="bg-amber-950/60 border border-amber-500/20 px-2 py-0.5 rounded-full text-[9px]">0</span>
                </h4>
                <div id="mod-pendientes-list" class="flex flex-col gap-3 max-h-[50vh] overflow-y-auto pr-1">
                  <p class="text-xs text-slate-500 animate-pulse uppercase">Cargando...</p>
                </div>
              </div>

              <!-- Aprobados -->
              <div class="flex flex-col gap-4">
                <h4 class="text-[10px] font-extrabold text-green-400 uppercase tracking-widest flex items-center gap-2">
                  ✓ Publicados (En Muro)
                  <span id="mod-aprobados-count" class="bg-green-950/60 border border-green-500/20 px-2 py-0.5 rounded-full text-[9px]">0</span>
                </h4>
                <div id="mod-aprobados-list" class="flex flex-col gap-3 max-h-[50vh] overflow-y-auto pr-1">
                  <p class="text-xs text-slate-500 animate-pulse uppercase">Cargando...</p>
                </div>
              </div>
            </div>
          </div>
        `;

        modal.classList.remove('hidden');

        // Cerrar modal
        document.getElementById('btn-close-comments-modal')?.addEventListener('click', () => {
          modal.classList.add('hidden');
        });

        // Cargar datos
        async function fetchComments() {
          const pendientesList = document.getElementById('mod-pendientes-list');
          const aprobadosList = document.getElementById('mod-aprobados-list');
          const pendientesCount = document.getElementById('mod-pendientes-count');
          const aprobadosCount = document.getElementById('mod-aprobados-count');

          if (!pendientesList || !aprobadosList) return;

          const { data, error } = await supabase
            .from('comentarios_lanzamientos')
            .select('*')
            .eq('lanzamiento_slug', slug)
            .order('created_at', { ascending: false });

          if (error) {
            pendientesList.innerHTML = '<p class="text-xs text-red-400">Error al cargar.</p>';
            aprobadosList.innerHTML = '<p class="text-xs text-red-400">Error al cargar.</p>';
            return;
          }

          const pendientes = data.filter((c: any) => !c.aprobado);
          const aprobados = data.filter((c: any) => c.aprobado);

          if (pendientesCount) pendientesCount.textContent = String(pendientes.length);
          if (aprobadosCount) aprobadosCount.textContent = String(aprobados.length);

          // Render Pendientes
          if (pendientes.length === 0) {
            pendientesList.innerHTML = '<p class="text-[10px] text-slate-550 uppercase py-4">No hay comentarios pendientes</p>';
          } else {
            pendientesList.innerHTML = pendientes.map((c: any) => {
              const stars = '★'.repeat(c.calificacion) + '☆'.repeat(5 - c.calificacion);
              return `
                <div class="bg-slate-950 border border-white/5 p-4 rounded-xl flex flex-col gap-2 relative">
                  <div class="flex justify-between items-start">
                    <div>
                      <h5 class="font-bold text-xs text-white uppercase">${c.nombre}</h5>
                      ${c.ciudad ? `<span class="text-[8px] text-slate-500 uppercase font-bold">${c.ciudad}</span>` : ''}
                    </div>
                    <span class="text-gold-bruna text-[10px] font-mono">${stars}</span>
                  </div>
                  <p class="text-xs text-slate-350 leading-tight font-light">${c.comentario}</p>
                  <div class="flex gap-2 justify-end mt-2 pt-2 border-t border-white/5">
                    <button data-mod-approve-id="${c.id}" class="text-[9px] bg-green-500/10 border border-green-500/20 hover:bg-green-500/20 hover:text-green-400 font-bold px-2 py-1 rounded uppercase tracking-wider transition-all cursor-pointer">Aprobar</button>
                    <button data-mod-reject-id="${c.id}" class="text-[9px] bg-red-500/10 border border-red-500/20 hover:bg-red-500/20 hover:text-red-400 font-bold px-2 py-1 rounded uppercase tracking-wider transition-all cursor-pointer">Eliminar</button>
                  </div>
                </div>
              `;
            }).join('');

            // Bind events
            pendientesList.querySelectorAll('[data-mod-approve-id]').forEach(btn => {
              btn.addEventListener('click', async () => {
                const id = (btn as HTMLButtonElement).dataset.modApproveId;
                if (!id) return;
                const { error: err } = await supabase.from('comentarios_lanzamientos').update({ aprobado: true }).eq('id', id);
                if (!err) {
                  await logAction('Aprobó opinión del lanzamiento "' + slug + '"');
                  fetchComments();
                } else {
                  alert('Error al aprobar: ' + err.message);
                }
              });
            });

            pendientesList.querySelectorAll('[data-mod-reject-id]').forEach(btn => {
              btn.addEventListener('click', async () => {
                const id = (btn as HTMLButtonElement).dataset.modRejectId;
                if (!id || !confirm('¿Eliminar permanentemente esta opinión?')) return;
                const { error: err } = await supabase.from('comentarios_lanzamientos').delete().eq('id', id);
                if (!err) {
                  await logAction('Eliminó opinión del lanzamiento "' + slug + '"');
                  fetchComments();
                } else {
                  alert('Error al eliminar: ' + err.message);
                }
              });
            });
          }

          // Render Aprobados
          if (aprobados.length === 0) {
            aprobadosList.innerHTML = '<p class="text-[10px] text-slate-550 uppercase py-4">No hay comentarios publicados</p>';
          } else {
            aprobadosList.innerHTML = aprobados.map((c: any) => {
              const stars = '★'.repeat(c.calificacion) + '☆'.repeat(5 - c.calificacion);
              return `
                <div class="bg-slate-950/60 border border-white/5 p-4 rounded-xl flex flex-col gap-2 relative">
                  <div class="flex justify-between items-start">
                    <div>
                      <h5 class="font-bold text-xs text-white uppercase">${c.nombre}</h5>
                      ${c.ciudad ? `<span class="text-[8px] text-slate-550 uppercase font-bold">${c.ciudad}</span>` : ''}
                    </div>
                    <span class="text-gold-bruna text-[10px] font-mono">${stars}</span>
                  </div>
                  <p class="text-xs text-slate-350 leading-tight font-light">${c.comentario}</p>
                  <div class="flex gap-2 justify-end mt-2 pt-2 border-t border-white/5">
                    <button data-mod-disapprove-id="${c.id}" class="text-[9px] border border-white/10 hover:border-amber-500 hover:text-amber-400 font-bold px-2 py-1 rounded uppercase tracking-wider transition-all cursor-pointer">Ocultar</button>
                    <button data-mod-reject-id="${c.id}" class="text-[9px] bg-red-500/10 border border-red-500/20 hover:bg-red-500/20 hover:text-red-400 font-bold px-2 py-1 rounded uppercase tracking-wider transition-all cursor-pointer">Eliminar</button>
                  </div>
                </div>
              `;
            }).join('');

            // Bind events
            aprobadosList.querySelectorAll('[data-mod-disapprove-id]').forEach(btn => {
              btn.addEventListener('click', async () => {
                const id = (btn as HTMLButtonElement).dataset.modDisapproveId;
                if (!id) return;
                const { error: err } = await supabase.from('comentarios_lanzamientos').update({ aprobado: false }).eq('id', id);
                if (!err) {
                  await logAction('Ocultó opinión del lanzamiento "' + slug + '"');
                  fetchComments();
                } else {
                  alert('Error al ocultar: ' + err.message);
                }
              });
            });

            aprobadosList.querySelectorAll('[data-mod-reject-id]').forEach(btn => {
              btn.addEventListener('click', async () => {
                const id = (btn as HTMLButtonElement).dataset.modRejectId;
                if (!id || !confirm('¿Eliminar permanentemente esta opinión?')) return;
                const { error: err } = await supabase.from('comentarios_lanzamientos').delete().eq('id', id);
                if (!err) {
                  await logAction('Eliminó opinión del lanzamiento "' + slug + '"');
                  fetchComments();
                } else {
                  alert('Error al eliminar: ' + err.message);
                }
              });
            });
          }
        }

        fetchComments();
      }

      // ==========================================
      // LÓGICA DE PESTAÑA: RADIO MONITOR
      // ==========================================
      let isSubtabBound = false;
      async function loadRadioMonitor() {
        // Enlazar sub-pestañas internas solo la primera vez
        if (!isSubtabBound) {
          const subtabBtns = document.querySelectorAll('.subtab-btn');
          const subtabPanes = document.querySelectorAll('.subtab-pane');
          
          subtabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
              const subtab = btn.getAttribute('data-subtab');
              subtabBtns.forEach(b => {
                b.classList.remove('active', 'border-gold-bruna', 'text-gold-bruna');
                b.classList.add('border-transparent', 'text-slate-400');
              });
              btn.classList.add('active', 'border-gold-bruna', 'text-gold-bruna');
              btn.classList.remove('border-transparent', 'text-slate-400');
              
              subtabPanes.forEach(pane => {
                if (pane.id === `subtab-content-${subtab}`) {
                  pane.classList.remove('hidden');
                } else {
                  pane.classList.add('hidden');
                }
              });
            });
          });
          
          // Enlazar buscador de historial
          document.getElementById('history-search-input')?.addEventListener('input', debounce(() => {
            fetchHistory();
          }, 300));

          document.getElementById('history-radio-select')?.addEventListener('change', () => {
            fetchHistory();
          });

          // Enlazar disparador de escaneo
          const btnTrigger = document.getElementById('btn-trigger-scan');
          if (btnTrigger) {
            btnTrigger.addEventListener('click', async () => {
              const origText = btnTrigger.textContent;
              btnTrigger.textContent = '⚡ Escaneando...';
              (btnTrigger as HTMLButtonElement).disabled = true;

              try {
                // Invocamos la Edge Function de Supabase de manera directa y autenticada
                const { data, error } = await supabase.functions.invoke('radio-monitor', {
                  method: 'POST'
                });

                if (error) throw error;
                alert(`Escaneo finalizado. Procesado: ${data.processed || 0} radios. Coincidencias: ${data.results?.filter((r: any) => r.status === 'DETECTION').length || 0}`);
                await logAction('Ejecutó sincronización manual del Radio Monitor');
                loadRadioMonitor(); // Recargar datos
              } catch (err: any) {
                alert(`Error al escanear: ${err.message}`);
              } finally {
                btnTrigger.textContent = origText;
                (btnTrigger as HTMLButtonElement).disabled = false;
              }
            });
          }

          isSubtabBound = true;
        }

        // Carga inicial de datos
        fetchHealth();
        fetchStats();
        fetchLiveAndRecent();
        fetchRadios();
        fetchHistory();
      }

      function debounce(func: Function, wait: number) {
        let timeout: any;
        return function(...args: any[]) {
          clearTimeout(timeout);
          timeout = setTimeout(() => func.apply(null, args), wait);
        };
      }

      async function fetchHealth() {
        const badge = document.getElementById('monitor-health-badge');
        if (!badge) return;
        
        try {
          const res = await fetch('/api/radio/health');
          const data = await res.json();
          if (data.success && data.health) {
            const h = data.health;
            badge.textContent = `Salud: ${h.totalErrors === 0 ? '✓ Óptima' : `⚠️ ${h.totalErrors} Offline`}`;
            badge.className = `text-xs py-1.5 px-3 rounded-full border ${h.totalErrors === 0 ? 'bg-green-950/20 border-green-500/20 text-green-400' : 'bg-red-950/20 border-red-500/20 text-red-400'}`;
          }
        } catch {
          badge.textContent = 'Estado: Desconectado';
        }
      }

      async function fetchStats() {
        try {
          const res = await fetch('/api/radio/stats');
          const data = await res.json();
          if (data.success && data.stats) {
            const s = data.stats;
            document.getElementById('stat-total-plays')!.textContent = s.totalDetections;
            document.getElementById('stat-active-radios')!.textContent = s.activeRadiosCount;
            document.getElementById('stat-offline-radios')!.textContent = s.offlineRadiosCount;
            document.getElementById('stat-last-sync')!.textContent = new Date(data.timestamp).toLocaleTimeString('es-CL');

            // Renderizar ranking de canciones
            const tracksRanking = document.getElementById('stats-tracks-ranking');
            if (tracksRanking) {
              if (s.detectionsByTrack.length === 0) {
                tracksRanking.innerHTML = '<p class="text-xs text-slate-500 py-4 text-center font-light">Sin reproducciones registradas</p>';
              } else {
                tracksRanking.innerHTML = s.detectionsByTrack.map((t: any, idx: number) => `
                  <div class="flex items-center gap-3 bg-slate-950/40 border border-white/5 p-3 rounded-xl">
                    <span class="font-title font-extrabold text-gold-bruna text-sm min-w-[20px]">${idx + 1}</span>
                    <span class="text-xs text-white font-semibold flex-grow truncate">${t.title}</span>
                    <span class="bg-gold-bruna/10 border border-gold-bruna/20 text-gold-bruna text-[10px] font-bold px-2 py-0.5 rounded-full">${t.count} tocadas</span>
                  </div>
                `).join('');
              }
            }

            // Renderizar ranking de radios
            const radiosRanking = document.getElementById('stats-radios-ranking');
            if (radiosRanking) {
              if (s.detectionsByRadio.length === 0) {
                radiosRanking.innerHTML = '<p class="text-xs text-slate-500 py-4 text-center font-light">Sin reproducciones registradas</p>';
              } else {
                radiosRanking.innerHTML = s.detectionsByRadio.map((r: any, idx: number) => `
                  <div class="flex items-center gap-3 bg-slate-950/40 border border-white/5 p-3 rounded-xl">
                    <span class="font-title font-extrabold text-slate-400 text-sm min-w-[20px]">${idx + 1}</span>
                    <span class="text-xs text-white font-semibold flex-grow truncate">${r.name}</span>
                    <span class="bg-slate-900 border border-white/5 text-slate-400 text-[10px] font-bold px-2 py-0.5 rounded-full">${r.count} tocadas</span>
                  </div>
                `).join('');
              }
            }
          }
        } catch {}
      }

      async function fetchLiveAndRecent() {
        const liveContainer = document.getElementById('dashboard-live-container');
        const recentContainer = document.getElementById('dashboard-recent-container');

        if (!liveContainer || !recentContainer) return;

        try {
          // En vivo
          const resLive = await fetch('/api/radio/now');
          const dataLive = await resLive.json();
          const live = dataLive.nowPlaying || [];

          if (live.length === 0) {
            liveContainer.innerHTML = `
              <div class="flex flex-col items-center gap-2 py-6 text-slate-500">
                <span class="text-xl">📡</span>
                <p class="text-xs">No hay reproducciones activas detectadas ahora</p>
              </div>
            `;
          } else {
            liveContainer.innerHTML = live.map((item: any) => `
              <div class="flex items-center gap-4 bg-red-950/10 border border-red-500/20 p-4 rounded-xl relative overflow-hidden group">
                <div class="absolute -right-6 -bottom-6 w-16 h-16 bg-red-500/5 rounded-full blur-xl"></div>
                <img src="${item.radio_logo || '/assets/logo-bruna-gold-glow.png'}" class="w-10 h-10 rounded-lg object-cover border border-white/10 bg-slate-950" />
                <div class="flex-grow min-w-0 text-left">
                  <span class="text-[9px] font-bold text-red-400 uppercase tracking-widest block animate-pulse">EN VIVO EN ${item.radio_name}</span>
                  <h4 class="text-xs font-bold text-white font-title uppercase truncate mt-0.5">${item.title}</h4>
                  <p class="text-[10px] text-gold-bruna truncate font-semibold">${item.artist}</p>
                </div>
              </div>
            `).join('');
          }

          // Historial corto (últimos 5)
          const resRecent = await fetch('/api/radio/history?limit=5');
          const dataRecent = await resRecent.json();
          const history = dataRecent.history || [];

          if (history.length === 0) {
            recentContainer.innerHTML = `
              <div class="flex flex-col items-center gap-2 py-6 text-slate-500">
                <span class="text-xl">🕒</span>
                <p class="text-xs">Sin registros recientes de reproducción</p>
              </div>
            `;
          } else {
            recentContainer.innerHTML = history.map((item: any) => {
              const d = new Date(item.detected_at);
              const timeStr = d.toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' }) + ' ' + d.toLocaleDateString('es-CL');
              return `
                <div class="flex items-center gap-3 bg-slate-950/40 border border-white/5 p-3 rounded-xl hover:border-gold-bruna/10 transition-colors">
                  <img src="${item.radio_logo || '/assets/logo-bruna-gold-glow.png'}" class="w-8 h-8 rounded object-cover border border-white/10 bg-slate-950" />
                  <div class="flex-grow min-w-0 text-left">
                    <h4 class="text-[11px] font-bold text-white truncate leading-tight">${item.title}</h4>
                    <p class="text-[9px] text-slate-500 font-semibold truncate mt-0.5">${item.radio_name} — ${timeStr}</p>
                  </div>
                </div>
              `;
            }).join('');
          }
        } catch {}
      }

      async function fetchRadios() {
        const tbody = document.getElementById('radios-table-body');
        const select = document.getElementById('history-radio-select');
        if (!tbody) return;

        try {
          const res = await fetch('/api/radio/radios?onlyActive=false');
          const data = await res.json();
          const radios = data.radios || [];

          // Actualizar select para filtros
          if (select && select.children.length === 1) {
            select.innerHTML = '<option value="">Todas las Radios</option>' + 
              radios.map((r: any) => `<option value="${r.id}">${r.nombre}</option>`).join('');
          }

          if (radios.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-slate-500">No hay radios registradas en el catálogo</td></tr>';
            return;
          }

          tbody.innerHTML = radios.map((r: any) => {
            const lastQuery = r.ultima_actualizacion ? new Date(r.ultima_actualizacion).toLocaleString('es-CL', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' }) : 'Nunca';
            const statusClass = r.activo 
              ? (r.verificado ? 'bg-green-950/45 border-green-500/20 text-green-400' : 'bg-amber-950/45 border-amber-500/20 text-amber-400')
              : 'bg-red-950/45 border-red-500/20 text-red-400';
            const statusText = r.activo 
              ? (r.verificado ? '✓ ONLINE' : '⚠️ CONSULTADA')
              : '✗ INACTIVA';

            const linkHtml = r.sitio_web ? '<a href="' + r.sitio_web + '" target="_blank" class="text-[10px] text-gold-bruna hover:underline">Visitar sitio web</a>' : '';

            return `
              <tr class="border-b border-white/5 hover:bg-white/[0.01]">
                <td class="p-4 flex items-center gap-3">
                  <img src="${r.logo_url || '/assets/logo-bruna-gold-glow.png'}" class="w-8 h-8 rounded object-cover border border-white/10 bg-slate-950" />
                  <div class="text-left">
                    <span class="font-bold text-white block">${r.nombre}</span>
                    ${linkHtml}
                  </div>
                </td>
                <td class="p-4 text-slate-400 text-left">${r.ciudad || ''}${r.ciudad && r.region ? ', ' : ''}${r.region || ''}</td>
                <td class="p-4 text-slate-400 font-mono text-left">${r.provider_name}</td>
                <td class="p-4 text-slate-400 font-mono text-left">${r.bitrate ? `${r.bitrate} kbps` : 'Desconocido'}</td>
                <td class="p-4 text-left">
                  <span class="text-[9px] font-bold px-2 py-0.5 border rounded ${statusClass}">${statusText}</span>
                </td>
                <td class="p-4 text-slate-450 font-mono text-left">${lastQuery}</td>
              </tr>
            `;
          }).join('');
        } catch {
          tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-red-400">Error al consultar catálogo de radios</td></tr>';
        }
      }

      async function fetchHistory() {
        const tbody = document.getElementById('history-table-body');
        if (!tbody) return;

        const search = (document.getElementById('history-search-input') as HTMLInputElement)?.value || '';
        const radioId = (document.getElementById('history-radio-select') as HTMLSelectElement)?.value || '';

        tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-slate-450 uppercase animate-pulse">Cargando reproducciones históricas...</td></tr>';

        try {
          const url = new URL('/api/radio/history', window.location.origin);
          url.searchParams.set('limit', '50');
          if (search) url.searchParams.set('search', search);
          if (radioId) url.searchParams.set('radioId', radioId);

          const res = await fetch(url.toString());
          const data = await res.json();
          const history = data.history || [];

          if (history.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-slate-500">No se encontraron reproducciones en el historial para esta búsqueda</td></tr>';
            return;
          }

          tbody.innerHTML = history.map((item: any) => {
            const d = new Date(item.detected_at);
            const dateStr = d.toLocaleDateString('es-CL') + ' ' + d.toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' });
            return `
              <tr class="border-b border-white/5 hover:bg-white/[0.01]">
                <td class="p-4 text-slate-400 font-mono text-left">${dateStr}</td>
                <td class="p-4 flex items-center gap-3">
                  <img src="${item.radio_logo || '/assets/logo-bruna-gold-glow.png'}" class="w-6 h-6 rounded object-cover border border-white/10 bg-slate-950" />
                  <span class="font-bold text-white">${item.radio_name}</span>
                </td>
                <td class="p-4 text-gold-bruna font-bold font-title uppercase text-left">${item.title}</td>
                <td class="p-4 text-slate-400 font-semibold text-left">${item.artist}</td>
              </tr>
            `;
          }).join('');
        } catch {
          tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-red-400">Error al consultar el historial de reproducciones</td></tr>';
        }
      }

  });
</script>
</Layout>
