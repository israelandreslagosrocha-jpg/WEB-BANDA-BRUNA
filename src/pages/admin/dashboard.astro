                  <textarea id="lan-meta-desc" rows="2" placeholder="Escribe la descripción meta..." class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none focus:border-gold-bruna/40 resize-none">${lanzamiento.meta_description || ''}</textarea>
