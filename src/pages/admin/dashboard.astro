      async function updateTestimonioApproval(id: string | undefined, approved: boolean) {
        if (!id) return;
        const { error } = await supabase
          .from('testimonios')
          .update({ aprobado: approved })
          .eq('id', id);

        if (!error) {
          const actionText = approved ? 'Aprobó testimonio de cliente para mostrar en la web' : 'Desaprobó testimonio de cliente (ocultado de la web)';
          await logAction(`${actionText} (ID: ${id})`);
          loadTestimonios();
        } else {
          alert('Error al actualizar el testimonio.');
        }
      }

      async function deleteTestimonio(id: string | undefined, name: string | undefined) {
        if (!id || !confirm(`¿Estás seguro de que deseas eliminar permanentemente el testimonio de "${name || 'este cliente'}"?`)) return;
        
        const { error } = await supabase
          .from('testimonios')
          .delete()
          .eq('id', id);

        if (!error) {
          await logAction(`Eliminó permanentemente testimonio de cliente "${name || id}"`);
          loadTestimonios();
        } else {
          alert('Error al eliminar el testimonio.');
        }
      }

