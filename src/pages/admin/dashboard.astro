                <p class="text-[8px] text-slate-600 font-mono mt-1.5">${new Date(item.created_at).toLocaleDateString('es-CL')} ${new Date(item.created_at).toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' })}</p>
