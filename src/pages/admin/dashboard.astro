---
import Layout from '../../layouts/Layout.astro';
import ProductionDashboardTab from '../../components/admin/ProductionDashboardTab.astro';
---

<Layout title="Dashboard de Administración | Banda Bruna" description="Panel de control dinámico oficial de Banda Bruna.">
  <div id="admin-gate-loading" class="min-h-screen flex items-center justify-center bg-slate-950 text-slate-400">
    <div class="text-center">
      <div class="w-10 h-10 border-4 border-gold-bruna border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-xs uppercase tracking-widest font-title font-bold">Verificando Credenciales de Seguridad...</p>
    </div>
  </div>

  <div id="admin-dashboard-container" class="hidden min-h-screen bg-slate-950 text-white">
    <!-- Topbar -->
    <header class="border-b border-white/5 bg-slate-900/60 sticky top-0 z-40 backdrop-blur-md">
      <div class="max-w-[1400px] mx-auto px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
          <img src="/assets/images/logos/logo_main.webp" alt="Logo" class="h-8 w-auto object-contain" />
          <span class="text-xs border-l border-white/10 pl-3 text-gold-bruna uppercase font-bold tracking-widest font-title">Panel de Control</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-slate-450 text-xs hidden sm:inline" id="user-display">contacto@bandabruna.cl</span>
          <button id="btn-logout" class="text-xs bg-slate-950 border border-white/10 hover:border-red-500/40 hover:text-red-400 px-3.5 py-2 rounded transition-all cursor-pointer uppercase tracking-wider font-bold">
            Cerrar Sesión
          </button>
        </div>
      </div>
    </header>

    <div class="max-w-[1400px] mx-auto px-6 py-8 grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar Navigation -->
      <aside class="lg:col-span-1 flex flex-col gap-2">
        <button data-tab-target="noticias" class="tab-btn active w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📰 Noticias & Blog
        </button>
        <button data-tab-target="eventos" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📅 Agenda & Shows
        </button>
        <button data-tab-target="equipo" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          👥 Integrantes & Staff
        </button>
        <button data-tab-target="rider" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📋 Rider Técnico / EPK
        </button>
        <button data-tab-target="produccion-tecnica" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          🏗️ Producción Técnica
        </button>
        <button data-tab-target="config" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          ⚙️ Ajustes & Redes
        </button>
        <button data-tab-target="testimonios" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          ⭐ Testimonios / Reseñas
        </button>
        <button data-tab-target="lanzamientos" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          🚀 Lanzamientos
        </button>
        <button data-tab-target="radio-monitor" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📻 Radio Monitor
        </button>
        <button data-tab-target="logs" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📜 Auditoría / Logs
        </button>
      </aside>

      <!-- Main Content Area -->
      <main class="lg:col-span-3 min-h-[60vh] bg-slate-900/40 border border-white/5 rounded-2xl p-6 md:p-8 relative">
        
        <!-- Tab 1: Noticias -->
        <section id="tab-noticias" class="tab-pane">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Noticias & Publicaciones</h2>
            <button id="btn-new-noticia" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-4 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
              + Nueva Noticia
            </button>
          </div>
          
          <div id="noticias-list" class="flex flex-col gap-4">
            <!-- Dynamic Noticias Rows -->
          </div>
        </section>

        <!-- Tab 2: Eventos -->
        <section id="tab-eventos" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Agenda de Conciertos</h2>
            <button id="btn-new-evento" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-4 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
              + Nuevo Show
            </button>
          </div>
          
          <div id="eventos-list" class="flex flex-col gap-4">
            <!-- Dynamic Eventos Rows -->
          </div>
        </section>

        <!-- Tab 3: Equipo (Integrantes + Staff) -->
        <section id="tab-equipo" class="tab-pane hidden">
          <div class="flex flex-col gap-8">
            <div>
              <div class="flex justify-between items-center mb-4">
                <h2 class="font-title font-bold text-lg uppercase text-white">Músicos / Integrantes</h2>
                <button id="btn-new-integrante" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-3.5 py-1.5 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
                  + Integrante
                </button>
              </div>
              <div id="integrantes-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Dynamic Integrantes Grid -->
              </div>
            </div>

            <div class="border-t border-white/5 pt-8">
              <div class="flex justify-between items-center mb-4">
                <h2 class="font-title font-bold text-lg uppercase text-white">Equipo Técnico (Staff)</h2>
                <button id="btn-new-staff" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-3.5 py-1.5 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
                  + Staff Técnico
                </button>
              </div>
              <div id="staff-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Dynamic Staff Grid -->
              </div>
            </div>
          </div>
        </section>

        <!-- Tab 4: Rider Técnico / EPK -->
        <section id="tab-rider" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Rider Técnico & EPK</h2>
            <button id="btn-pdf-rider" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-4 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer flex items-center gap-1.5">
              📥 Descargar PDF
            </button>
          </div>

          <form id="rider-form" class="flex flex-col gap-6">
            <div class="bg-slate-950/40 border border-white/5 rounded-xl p-5">
              <h3 class="font-title font-bold text-sm text-gold-bruna mb-4 uppercase tracking-wider">Lista de Canales (Input List)</h3>
              <div class="max-h-[350px] overflow-y-auto pr-2 flex flex-col gap-2" id="canales-container">
                <!-- Se inyectarán dinámicamente -->
              </div>
            </div>

            <div class="bg-slate-950/40 border border-white/5 rounded-xl p-5">
              <h3 class="font-title font-bold text-sm text-gold-bruna mb-4 uppercase tracking-wider">Mezclas de Monitoreo</h3>
              <div class="flex flex-col gap-2.5" id="monitores-container">
                <!-- Se inyectarán dinámicamente -->
              </div>
            </div>

            <div class="bg-slate-950/40 border border-white/5 rounded-xl p-5">
              <h3 class="font-title font-bold text-sm text-gold-bruna mb-4 uppercase tracking-wider">Requerimientos Técnicos</h3>
              <div class="flex flex-col gap-4">
                <div class="flex flex-col gap-1.5">
                  <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Requerimientos de Audio (P.A. & FOH) - Salto de línea por ítem</label>
                  <textarea id="req-audio" rows="3" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none focus:border-gold-bruna resize-none"></textarea>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Requerimientos de Monitoreo - Salto de línea por ítem</label>
                  <textarea id="req-monitores" rows="3" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none focus:border-gold-bruna resize-none"></textarea>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Requerimientos de Iluminación - Salto de línea por ítem</label>
                  <textarea id="req-luces" rows="2" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none focus:border-gold-bruna resize-none"></textarea>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Requerimientos de Logística & Camarín - Salto de línea por ítem</label>
                  <textarea id="req-logistica" rows="2" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none focus:border-gold-bruna resize-none"></textarea>
                </div>
              </div>
            </div>

            <!-- DISEÑADOR DE STAGE PLOT -->
            <div class="bg-slate-950/40 border border-white/5 rounded-xl p-5 flex flex-col gap-4">
              <div class="flex justify-between items-center">
                <h3 class="font-title font-bold text-sm text-gold-bruna uppercase tracking-wider">Distribución del Escenario (Stage Plot)</h3>
                <div class="flex gap-2">
                  <select id="stage-element-type" class="bg-slate-950 border border-white/5 rounded px-2.5 py-1.5 text-xs text-white outline-none cursor-pointer">
                    <option value="bateria">🥁 Batería / Timbales</option>
                    <option value="congas">🥁 Congas / Bongos</option>
                    <option value="guiro">🪵 Güiro</option>
                    <option value="teclado">🎹 Teclados</option>
                    <option value="gtr">🎸 Guitarra</option>
                    <option value="bajo">🎸 Bajo</option>
                    <option value="vocal">🎤 Vocal / Micrófono</option>
                    <option value="monitor">🔊 Monitor de Piso</option>
                    <option value="power">⚡ Toma de Corriente</option>
                  </select>
                  <button type="button" id="btn-add-stage-element" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-3.5 py-1.5 rounded text-[10px] font-bold uppercase tracking-wider cursor-pointer">
                    + Añadir
                  </button>
                </div>
              </div>
              
              <p class="text-[10px] text-slate-400">
                Arrastra y coloca los elementos en la cuadrícula para definir su posición exacta en el escenario. Haz clic en un elemento para editar sus detalles (nombre, canal, retorno) o eliminarlo. Los cambios de posición se guardarán al guardar todo el Rider Técnico.
              </p>

              <!-- Escenario Interactivo -->
              <div id="stage-designer-canvas" class="w-full aspect-[16/10] bg-slate-950 border border-white/10 rounded-lg relative overflow-hidden select-none min-h-[300px] shadow-inner shadow-black">
                <!-- Líneas decorativas de fondo -->
                <div class="absolute inset-0 bg-[radial-gradient(#e5a72b05_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none" aria-hidden="true"></div>
                
                <!-- Fondo -->
                <div class="absolute top-2 left-1/2 -translate-x-1/2 text-[8px] text-slate-600 uppercase tracking-widest pointer-events-none">FONDO DEL ESCENARIO (BACK LINE)</div>
                
                <!-- Elementos dinámicos del escenario -->
                <div id="stage-designer-elements" class="absolute inset-0 z-10"></div>
                
                <!-- Frente -->
                <div class="absolute bottom-2 left-1/2 -translate-x-1/2 text-[8px] text-slate-600 uppercase tracking-widest pointer-events-none">FRENTE DEL ESCENARIO (PÚBLICO)</div>
              </div>

              <!-- Panel de Edición Rápida de Elemento (Oculto por defecto) -->
              <div id="stage-element-editor" class="bg-slate-900 border border-white/5 rounded-lg p-4 hidden flex flex-col gap-3">
                <h4 class="font-title font-bold text-xs uppercase text-white flex justify-between items-center">
                  <span>Propiedades del Elemento</span>
                  <button type="button" id="btn-delete-stage-element" class="text-[9px] border border-red-500/20 text-red-400 hover:border-red-500 hover:text-red-300 font-bold py-1 px-2.5 rounded uppercase cursor-pointer">Eliminar Elemento</button>
                </h4>
                
                <input type="hidden" id="edit-el-id" />
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                  <div class="flex flex-col gap-1">
                    <label class="text-[8px] font-bold text-slate-400 uppercase tracking-wider">Nombre del Elemento</label>
                    <input type="text" id="edit-el-name" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none focus:border-gold-bruna" />
                  </div>
                  <div class="flex flex-col gap-1">
                    <label class="text-[8px] font-bold text-slate-400 uppercase tracking-wider">Asignación Canal (Input)</label>
                    <input type="text" id="edit-el-canal" placeholder="ej: CH 13" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none focus:border-gold-bruna" />
                  </div>
                  <div class="flex flex-col gap-1">
                    <label class="text-[8px] font-bold text-slate-400 uppercase tracking-wider">Mezcla Retorno / Monitor</label>
                    <input type="text" id="edit-el-retorno" placeholder="ej: Mon 5" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none focus:border-gold-bruna" />
                  </div>
                </div>
                <div class="flex justify-end mt-1">
                  <button type="button" id="btn-save-stage-element-props" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white font-title font-bold py-1.5 px-4 rounded text-[10px] uppercase tracking-wider cursor-pointer">Aplicar Cambios</button>
                </div>
              </div>
            </div>

            <button type="submit" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white font-title font-bold py-3 rounded text-xs uppercase tracking-widest transition-all w-full cursor-pointer">
              GUARDAR CAMBIOS RIDER TÉCNICO
            </button>
          </form>
        </section>

        <!-- Tab 5: Ajustes Globales & Redes -->
        <section id="tab-config" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Configuración Global del Sitio</h2>
            <div class="flex gap-2">
              <button id="btn-sync-redes" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white px-3.5 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer transition-colors">
                🔄 Sincronizar Redes
              </button>
              <button id="btn-sync-musica" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white px-3.5 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer transition-colors">
                🎵 Sincronizar Música
              </button>
            </div>
          </div>

          <form id="config-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="conf-tel-p" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Teléfono Jaime Cárdenas (Booking)</label>
              <input type="text" id="conf-tel-p" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-tel-s" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Teléfono César Bruna (Dirección)</label>
              <input type="text" id="conf-tel-s" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-email" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Email de Contacto</label>
              <input type="email" id="conf-email" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-spotify" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace Spotify</label>
              <input type="url" id="conf-spotify" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-instagram" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace Instagram</label>
              <input type="url" id="conf-instagram" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-facebook" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace Facebook</label>
              <input type="url" id="conf-facebook" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-youtube" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace YouTube</label>
              <input type="url" id="conf-youtube" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-tiktok" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace TikTok</label>
              <input type="url" id="conf-tiktok" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>

            <!-- Contadores de Estadísticas de Redes / Home -->
            <div class="md:col-span-2 border-t border-white/5 pt-4 mt-2">
              <h3 class="font-title font-bold text-xs uppercase text-gold-bruna mb-1">Métricas y Estadísticas del Sitio (Contadores)</h3>
              <p class="text-[9px] text-slate-450 mb-3">Ajusta los números que se muestran en la sección de estadísticas en la página de inicio. El contador de Facebook se ingresa como número entero (ej: 4900 para mostrar "4,9 mil").</p>
            </div>

            <div class="flex flex-col gap-2">
              <label for="conf-stats-instagram" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Seguidores Instagram</label>
              <input type="number" id="conf-stats-instagram" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-stats-facebook" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Amigos / Seguidores Facebook</label>
              <input type="number" id="conf-stats-facebook" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-stats-youtube" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Suscriptores YouTube</label>
              <input type="number" id="conf-stats-youtube" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-stats-tiktok" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Seguidores TikTok</label>
              <input type="number" id="conf-stats-tiktok" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-stats-trayectoria" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Trayectoria (Cantidad Músicos)</label>
              <input type="number" id="conf-stats-trayectoria" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-stats-escenarios" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Años en Escenarios</label>
              <input type="number" id="conf-stats-escenarios" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-stats-regiones" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Regiones Recorridas</label>
              <input type="number" id="conf-stats-regiones" min="0" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="hidden md:block"></div>

            <button type="submit" class="md:col-span-2 bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white font-title font-bold py-3.5 rounded text-xs uppercase tracking-widest transition-all cursor-pointer">
              GUARDAR CONFIGURACIÓN GENERAL
            </button>
          </form>
        </section>

        <!-- Tab 6: Testimonios / Reseñas de Clientes -->
        <section id="tab-testimonios" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white font-title">Testimonios & Reseñas</h2>
            <div class="text-[10px] text-slate-450 uppercase tracking-widest font-bold bg-slate-900 border border-white/5 py-1.5 px-3.5 rounded-md">
              Autoadministrable
            </div>
          </div>

