      // ==========================================
      // LÓGICA DE PESTAÑA: RIDER TÉCNICO (CON PDF)
      // ==========================================
      async function loadRider() {
        const canalesContainer = document.getElementById('canales-container');
        const monitoresContainer = document.getElementById('monitores-container');
        
        const reqAudio = document.getElementById('req-audio') as HTMLTextAreaElement;
        const reqMonitores = document.getElementById('req-monitores') as HTMLTextAreaElement;
        const reqLuces = document.getElementById('req-luces') as HTMLTextAreaElement;
        const reqLogistica = document.getElementById('req-logistica') as HTMLTextAreaElement;

        if (!canalesContainer || !monitoresContainer || !reqAudio || !reqMonitores || !reqLuces || !reqLogistica) return;

        canalesContainer.innerHTML = '<p class="text-xs text-slate-400 animate-pulse">Cargando canales...</p>';
        monitoresContainer.innerHTML = '<p class="text-xs text-slate-400 animate-pulse">Cargando mezclas...</p>';

        // Cargar Canales
        const { data: canales, error: errCanales } = await supabase
          .from('rider_canales')
          .select('*')
          .order('canal', { ascending: true });

        // Cargar Monitores
        const { data: monitores, error: errMonitores } = await supabase
          .from('rider_monitores')
          .select('*')
          .order('mezcla', { ascending: true });

        // Cargar Requerimientos
        const { data: reqs, error: errReqs } = await supabase
          .from('rider_requerimientos')
          .select('*');

        // Cargar Stage Plot
        const { data: stageData, error: errStage } = await supabase
          .from('rider_stageplot')
          .select('*');

        if (errCanales || !canales) {
          canalesContainer.innerHTML = '<p class="text-xs text-red-400">Error al cargar canales.</p>';
        } else {
          canalesContainer.innerHTML = canales.map((ch: any) => `
            <div class="flex items-center gap-3 bg-slate-900 border border-white/5 p-2 rounded-lg" data-channel-row="${ch.canal}" data-channel-id="${ch.id}">
              <span class="w-8 font-title font-bold text-xs text-gold-bruna pl-2">${ch.canal}</span>
              <input type="text" value="${ch.instrumento}" placeholder="Instrumento" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none w-1/2 focus:border-gold-bruna/50" data-field="instrumento" />
              <input type="text" value="${ch.conexion}" placeholder="Micrófono / DI" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none w-1/2 focus:border-gold-bruna/50" data-field="conexion" />
              <input type="hidden" value="${ch.categoria}" data-field="categoria" />
            </div>
          `).join('');
        }

        if (errMonitores || !monitores) {
          monitoresContainer.innerHTML = '<p class="text-xs text-red-400">Error al cargar mezclas de monitoreo.</p>';
        } else {
          monitoresContainer.innerHTML = monitores.map((m: any) => `
            <div class="flex items-center gap-3 bg-slate-900 border border-white/5 p-2 rounded-lg" data-monitor-row="${m.mezcla}" data-monitor-id="${m.id}">
              <span class="w-8 font-title font-bold text-xs text-gold-bruna pl-2">Mix ${m.mezcla}</span>
              <input type="text" value="${m.envio}" placeholder="Asignación" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none w-1/2 focus:border-gold-bruna/50" data-field="envio" />
              <input type="text" value="${m.sistema}" placeholder="Sistema (ej: IN EAR)" class="bg-slate-950 border border-white/5 rounded p-2 text-xs text-white outline-none w-1/2 focus:border-gold-bruna/50" data-field="sistema" />
            </div>
          `).join('');
        }

        if (errReqs || !reqs) {
          reqAudio.value = '';
          reqMonitores.value = '';
          reqLuces.value = '';
          reqLogistica.value = '';
        } else {
          reqs.forEach((r: any) => {
            const val = (r.items || []).join('\n');
            if (r.categoria === 'audio') reqAudio.value = val;
            if (r.categoria === 'monitores') reqMonitores.value = val;
            if (r.categoria === 'luces') reqLuces.value = val;
            if (r.categoria === 'logistica') reqLogistica.value = val;
          });
        }

        // Cargar Stageplot a la variable global y renderizar
        if (!errStage && stageData) {
          stageElements = stageData;
        } else {
          stageElements = [];
        }
        renderStageElements();
      }

      // Iconos SVG del Stage Plot
      function getStageIconSvg(type: string): string {
        const gold = 'currentColor';
        if (type === 'bateria') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><path d="M4 10h16v6H4zM7 6v4M17 6v4M12 10v6M2 16h20M5 16v4M19 16v4"/></svg>`;
        }
        if (type === 'congas') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><ellipse cx="7" cy="7" rx="3" ry="2"/><ellipse cx="17" cy="7" rx="3" ry="2"/><path d="M4 7v10M10 7v10M14 7v10M20 7v10M4 17h6M14 17h6"/></svg>`;
        }
        if (type === 'guiro') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><rect x="7" y="3" width="10" height="18" rx="2"/><path d="M7 6h10M7 9h10M7 12h10M7 15h10M7 18h10"/></svg>`;
        }
        if (type === 'teclado') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><rect x="2" y="7" width="20" height="10" rx="1"/><path d="M6 7v6M10 7v6M14 7v6M18 7v6M2 13h20"/></svg>`;
        }
        if (type === 'gtr') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><path d="M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M8 16.5L18 6.5M16 4.5l3.5 3.5M14 8.5l1.5-1.5M11.5 11l1.5-1.5"/><circle cx="20" cy="4" r="1"/></svg>`;
        }
        if (type === 'bajo') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><path d="M9 19a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M8 17.5L20 5.5M17 3.5l3.5 3.5M13.5 12l1.5-1.5"/><circle cx="21" cy="3" r="1"/></svg>`;
        }
        if (type === 'vocal') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><rect x="9" y="2" width="6" height="8" rx="3"/><path d="M12 10v9M9 19h6M6 22h12M12 10a4 4 0 0 0 4-4"/></svg>`;
        }
        if (type === 'monitor') {
          return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><path d="M3 6l18-2v14l-18 2V6z"/><circle cx="10" cy="11" r="3"/><circle cx="16" cy="10" r="1"/></svg>`;
        }
        return `<svg class="w-full h-full text-gold-bruna" viewBox="0 0 24 24" fill="none" stroke="${gold}" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 11h8M12 7v8M10 15h4"/></svg>`;
      }

      // Renderizar elementos del Stage Plot
      function renderStageElements() {
        const container = document.getElementById('stage-designer-elements');
        if (!container) return;
        
        container.innerHTML = stageElements.map(el => {
          const icon = getStageIconSvg(el.tipo);
          return `
            <div class="absolute cursor-move flex flex-col items-center group touch-none" 
                 data-stage-el-id="${el.id}" 
                 style="left: ${el.pos_x}%; top: ${el.pos_y}%; transform: translate(-50%, -50%);">
              <div class="w-10 h-10 rounded-full bg-slate-900 border border-white/10 hover:border-gold-bruna flex items-center justify-center p-1.5 shadow transition-colors bg-gradient-to-b from-slate-900 to-slate-950">
                ${icon}
              </div>
              <span class="text-[8px] text-white font-bold bg-black/80 px-1.5 rounded mt-1 truncate max-w-[85px] uppercase font-title leading-tight shadow border border-white/5">${el.nombre}</span>
              ${el.canal ? `<span class="text-[7px] text-gold-bruna font-semibold mt-0.5 leading-none bg-slate-950/80 px-1 rounded border border-white/5">${el.canal}</span>` : ''}
            </div>
          `;
        }).join('');
        
        bindStageDesignerEvents();
      }

      // Eventos de arrastre y edición del Stage Plot
      function bindStageDesignerEvents() {
        const elements = document.querySelectorAll('[data-stage-el-id]');
        const canvas = document.getElementById('stage-designer-canvas');
        if (!canvas) return;

        elements.forEach(el => {
          const handleDragStart = (clientX: number, clientY: number, e: Event) => {
            e.stopPropagation();
            
            const rect = canvas.getBoundingClientRect();
            const targetId = el.getAttribute('data-stage-el-id');
            const item = stageElements.find(item => item.id === targetId);
            if (!item) return;

            const onDragMove = (moveEvent: MouseEvent | TouchEvent) => {
              let moveClientX = 0;
              let moveClientY = 0;
              if (moveEvent instanceof MouseEvent) {
                moveClientX = moveEvent.clientX;
                moveClientY = moveEvent.clientY;
              } else if (moveEvent.touches && moveEvent.touches.length > 0) {
                moveClientX = moveEvent.touches[0].clientX;
                moveClientY = moveEvent.touches[0].clientY;
              }

              // Calcular coordenadas de forma relativa en porcentaje
              let newX = ((moveClientX - rect.left) / rect.width) * 100;
              let newY = ((moveClientY - rect.top) / rect.height) * 100;

              // Limitar bordes
              newX = Math.max(3, Math.min(97, newX));
              newY = Math.max(3, Math.min(97, newY));

              item.pos_x = parseFloat(newX.toFixed(2));
              item.pos_y = parseFloat(newY.toFixed(2));

              // Actualizar estilo
              (el as HTMLElement).style.left = `${item.pos_x}%`;
              (el as HTMLElement).style.top = `${item.pos_y}%`;
            };

            const onDragEnd = () => {
              document.removeEventListener('mousemove', onDragMove);
              document.removeEventListener('mouseup', onDragEnd);
              document.removeEventListener('touchmove', onDragMove);
              document.removeEventListener('touchend', onDragEnd);
            };

            document.addEventListener('mousemove', onDragMove);
            document.addEventListener('mouseup', onDragEnd);
            document.addEventListener('touchmove', onDragMove, { passive: false });
            document.addEventListener('touchend', onDragEnd);
          };

          el.addEventListener('mousedown', (e) => {
            const mouseEvent = e as MouseEvent;
            handleDragStart(mouseEvent.clientX, mouseEvent.clientY, e);
          });

          el.addEventListener('touchstart', (e) => {
            const touchEvent = e as TouchEvent;
            if (touchEvent.touches && touchEvent.touches.length > 0) {
              handleDragStart(touchEvent.touches[0].clientX, touchEvent.touches[0].clientY, e);
            }
          });

          // Al hacer clic, abrir propiedades
          el.addEventListener('click', (e) => {
            e.stopPropagation();
            const targetId = el.getAttribute('data-stage-el-id');
            openStageElementEditor(targetId);
          });
        });

        // Click en fondo del canvas cierra editor
        canvas.addEventListener('click', () => {
          const editor = document.getElementById('stage-element-editor');
          if (editor) editor.classList.add('hidden');
        });
      }

      function openStageElementEditor(id: string | null) {
        const editor = document.getElementById('stage-element-editor');
        const inputId = document.getElementById('edit-el-id') as HTMLInputElement;
        const inputName = document.getElementById('edit-el-name') as HTMLInputElement;
        const inputCanal = document.getElementById('edit-el-canal') as HTMLInputElement;
        const inputRetorno = document.getElementById('edit-el-retorno') as HTMLInputElement;

        if (!editor || !inputId || !inputName || !inputCanal || !inputRetorno) return;

        const item = stageElements.find(el => el.id === id);
        if (!item) return;

        inputId.value = item.id;
        inputName.value = item.nombre;
        inputCanal.value = item.canal || '';
        inputRetorno.value = item.retorno || '';

        editor.classList.remove('hidden');
      }

      // Guardar propiedades del elemento en caliente
      document.getElementById('btn-save-stage-element-props')?.addEventListener('click', () => {
        const editor = document.getElementById('stage-element-editor');
        const id = (document.getElementById('edit-el-id') as HTMLInputElement).value;
        const nombre = (document.getElementById('edit-el-name') as HTMLInputElement).value;
        const canal = (document.getElementById('edit-el-canal') as HTMLInputElement).value;
        const retorno = (document.getElementById('edit-el-retorno') as HTMLInputElement).value;

        const item = stageElements.find(el => el.id === id);
        if (item) {
          item.nombre = nombre;
          item.canal = canal;
          item.retorno = retorno;
          renderStageElements();
        }
        if (editor) editor.classList.add('hidden');
      });

      // Eliminar elemento del canvas
      document.getElementById('btn-delete-stage-element')?.addEventListener('click', () => {
        if (!confirm('¿Estás seguro de que deseas eliminar este instrumento del escenario?')) return;
        const editor = document.getElementById('stage-element-editor');
        const id = (document.getElementById('edit-el-id') as HTMLInputElement).value;

        stageElements = stageElements.filter(el => el.id !== id);
        renderStageElements();
        if (editor) editor.classList.add('hidden');
      });

      // Añadir nuevo elemento al canvas
      document.getElementById('btn-add-stage-element')?.addEventListener('click', () => {
        const selectType = document.getElementById('stage-element-type') as HTMLSelectElement;
        if (!selectType) return;
        
        const type = selectType.value;
        const label = selectType.options[selectType.selectedIndex].text.replace(/^[^\s]+\s+/, ''); // Quitar emoji

        const newItem = {
          id: 'new-' + Math.random().toString(36).substr(2, 9),
          nombre: label,
          tipo: type,
          pos_x: 50.00,
          pos_y: 50.00,
          canal: '',
          retorno: ''
        };

        stageElements.push(newItem);
        renderStageElements();
        openStageElementEditor(newItem.id);
      });

      // Evento submit de todo el Rider Técnico
      document.getElementById('rider-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = e.target.querySelector('button[type="submit"]') as HTMLButtonElement;
        const origText = submitBtn.textContent;
        submitBtn.textContent = 'Guardando cambios...';
        submitBtn.disabled = true;

        try {
          // 1. Guardar Canales
          const channelRows = document.querySelectorAll('[data-channel-row]');
          for (const row of channelRows) {
            const id = row.getAttribute('data-channel-id');
            const instrumento = (row.querySelector('[data-field="instrumento"]') as HTMLInputElement).value;
            const conexion = (row.querySelector('[data-field="conexion"]') as HTMLInputElement).value;
            const categoria = (row.querySelector('[data-field="categoria"]') as HTMLInputElement).value;

            if (id) {
              await supabase.from('rider_canales').update({ instrumento, conexion, categoria }).eq('id', id);
            }
          }

          // 2. Guardar Monitores
          const monitorRows = document.querySelectorAll('[data-monitor-row]');
          for (const row of monitorRows) {
            const id = row.getAttribute('data-monitor-id');
            const envio = (row.querySelector('[data-field="envio"]') as HTMLInputElement).value;
            const sistema = (row.querySelector('[data-field="sistema"]') as HTMLInputElement).value;

            if (id) {
              await supabase.from('rider_monitores').update({ envio, sistema }).eq('id', id);
            }
          }

          // 3. Guardar Requerimientos
          const reqAudio = (document.getElementById('req-audio') as HTMLTextAreaElement).value.split('\n').filter(l => l.trim() !== '');
          const reqMonitores = (document.getElementById('req-monitores') as HTMLTextAreaElement).value.split('\n').filter(l => l.trim() !== '');
          const reqLuces = (document.getElementById('req-luces') as HTMLTextAreaElement).value.split('\n').filter(l => l.trim() !== '');
          const reqLogistica = (document.getElementById('req-logistica') as HTMLTextAreaElement).value.split('\n').filter(l => l.trim() !== '');

          await supabase.from('rider_requerimientos').update({ items: reqAudio }).eq('categoria', 'audio');
          await supabase.from('rider_requerimientos').update({ items: reqMonitores }).eq('categoria', 'monitores');
          await supabase.from('rider_requerimientos').update({ items: reqLuces }).eq('categoria', 'luces');
          await supabase.from('rider_requerimientos').update({ items: reqLogistica }).eq('categoria', 'logistica');

          // 4. Guardar Stageplot (Re-inserción limpia en bloque)
          // Borrar todos los elementos actuales
          await supabase.from('rider_stageplot').delete().neq('id', '00000000-0000-0000-0000-000000000000');
          
          // Insertar los elementos actuales sin el prefijo "new-" en el ID si lo tuvieran
          const itemsToInsert = stageElements.map(el => {
            const item: any = {
              nombre: el.nombre,
              tipo: el.tipo,
              pos_x: el.pos_x,
              pos_y: el.pos_y,
              canal: el.canal || null,
              retorno: el.retorno || null
            };
            // Si el id es un UUID válido y no autogenerado localmente
            if (el.id && !el.id.startsWith('new-')) {
              item.id = el.id;
            }
            return item;
          });

          if (itemsToInsert.length > 0) {
            const { error: insertErr } = await supabase.from('rider_stageplot').insert(itemsToInsert);
            if (insertErr) throw insertErr;
          }

          await logAction('Actualizó especificaciones del Rider Técnico y Stage Plot en Supabase');
          alert('¡Rider Técnico y Stage Plot guardados exitosamente en Supabase!');
          loadRider(); // Recargar datos limpios
        } catch (err) {
          console.error("Error al guardar rider:", err);
          alert('Ocurrió un error al guardar los cambios en Supabase.');
        } finally {
          submitBtn.textContent = origText;
          submitBtn.disabled = false;
        }
      });

      document.getElementById('btn-pdf-rider')?.addEventListener('click', () => {
        const { jsPDF } = (window as any).jspdf;
        const doc = new jsPDF();

        // Estilos PDF Premium
        doc.setFillColor(9, 13, 22); // Fondo oscuro
        doc.rect(0, 0, 210, 297, 'F');
        
        doc.setTextColor(212, 175, 55); // Color dorado Bruna
        doc.setFont('Helvetica', 'bold');
        doc.setFontSize(22);
        doc.text("BANDA BRUNA 2.0", 20, 25);
        
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(14);
        doc.text("RIDER TÉCNICO OFICIAL & INPUT LIST", 20, 35);
        doc.setFontSize(9);
        doc.setFont('Helvetica', 'normal');
        doc.setTextColor(150, 150, 150);
        doc.text("Documento oficial de requerimientos de sonido, mezclas e input list de escenario.", 20, 42);
        doc.line(20, 46, 190, 46); // Divider

        // Seccion Input List
        doc.setTextColor(212, 175, 55);
        doc.setFontSize(11);
        doc.setFont('Helvetica', 'bold');
        doc.text("INPUT LIST (CANALES DE ENTRADA)", 20, 55);
        
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(8);
        doc.setFont('Helvetica', 'normal');

        const channelRows = document.querySelectorAll('[data-channel-row]');
        let yPos = 62;
        channelRows.forEach((row) => {
          const ch = row.getAttribute('data-channel-row');
          const instrumento = (row.querySelector('[data-field="instrumento"]') as HTMLInputElement).value;
          const conexion = (row.querySelector('[data-field="conexion"]') as HTMLInputElement).value;
          
          if (yPos < 280) {
            doc.text(`${ch}. ${instrumento} - ${conexion}`, 20, yPos);
            yPos += 4.5;
          }
        });

        // Crear una nueva página para monitores y requerimientos
        doc.addPage();
        doc.setFillColor(9, 13, 22); // Fondo oscuro
        doc.rect(0, 0, 210, 297, 'F');
        
        doc.setTextColor(212, 175, 55);
        doc.setFont('Helvetica', 'bold');
        doc.setFontSize(12);
        doc.text("MEZCLAS DE MONITOREO Y RETORNO", 20, 25);

        doc.setTextColor(255, 255, 255);
        doc.setFont('Helvetica', 'normal');
        doc.setFontSize(9);
        let yMon = 35;
        const monitorRows = document.querySelectorAll('[data-monitor-row]');
        monitorRows.forEach((row) => {
          const mezcla = row.getAttribute('data-monitor-row');
          const envio = (row.querySelector('[data-field="envio"]') as HTMLInputElement).value;
          const sistema = (row.querySelector('[data-field="sistema"]') as HTMLInputElement).value;
          
          doc.text(`Mezcla ${mezcla}: ${envio} (${sistema})`, 20, yMon);
          yMon += 6;
        });

        yMon += 10;
        doc.setTextColor(212, 175, 55);
        doc.setFont('Helvetica', 'bold');
        doc.text("REQUERIMIENTOS TÉCNICOS ADICIONALES", 20, yMon);
        
        doc.setTextColor(255, 255, 255);
        doc.setFont('Helvetica', 'normal');
        doc.setFontSize(8);
        yMon += 8;

        const reqAudio = (document.getElementById('req-audio') as HTMLTextAreaElement).value;
        const reqMonitores = (document.getElementById('req-monitores') as HTMLTextAreaElement).value;

        doc.setTextColor(212, 175, 55);
        doc.setFont('Helvetica', 'bold');
        doc.text("AUDIO (P.A. & FOH):", 20, yMon);
        doc.setTextColor(255, 255, 255);
        doc.setFont('Helvetica', 'normal');
        yMon += 5;
        const audioLines = doc.splitTextToSize(reqAudio, 170);
        doc.text(audioLines, 20, yMon);

        yMon += (audioLines.length * 4) + 5;
        doc.setTextColor(212, 175, 55);
        doc.setFont('Helvetica', 'bold');
        doc.text("MONITORES & ILUMINACION:", 20, yMon);
        doc.setTextColor(255, 255, 255);
        doc.setFont('Helvetica', 'normal');
        yMon += 5;
        const monLines = doc.splitTextToSize(reqMonitores, 170);
        doc.text(monLines, 20, yMon);

        // Descarga
        doc.save("Rider_Tecnico_Banda_Bruna.pdf");
        logAction('Descargó el documento de Rider Técnico en PDF');
      });

      // ==========================================
      // LÓGICA DE PESTAÑA: AJUSTES GLOBALES
      // ==========================================
      async function loadConfig() {
        const { data, error } = await supabase.from('configuracion').select('*').eq('id', 1).single();
        if (error || !data) return;

        (document.getElementById('conf-tel-p') as HTMLInputElement).value = data.telefono_principal || '';
        (document.getElementById('conf-tel-s') as HTMLInputElement).value = data.telefono_secundario || '';
        (document.getElementById('conf-email') as HTMLInputElement).value = data.email_contacto || '';
        (document.getElementById('conf-spotify') as HTMLInputElement).value = data.spotify || '';
        (document.getElementById('conf-instagram') as HTMLInputElement).value = data.instagram || '';
        (document.getElementById('conf-facebook') as HTMLInputElement).value = data.facebook || '';
        (document.getElementById('conf-youtube') as HTMLInputElement).value = data.youtube || '';
        (document.getElementById('conf-tiktok') as HTMLInputElement).value = data.tiktok || '';
      }

      document.getElementById('config-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const telP = (document.getElementById('conf-tel-p') as HTMLInputElement).value;
        const telS = (document.getElementById('conf-tel-s') as HTMLInputElement).value;
        const email = (document.getElementById('conf-email') as HTMLInputElement).value;
        const spotify = (document.getElementById('conf-spotify') as HTMLInputElement).value;
        const instagram = (document.getElementById('conf-instagram') as HTMLInputElement).value;
        const facebook = (document.getElementById('conf-facebook') as HTMLInputElement).value;
        const youtube = (document.getElementById('conf-youtube') as HTMLInputElement).value;
        const tiktok = (document.getElementById('conf-tiktok') as HTMLInputElement).value;

        const payload = {
          telefono_principal: telP,
          telefono_secundario: telS,
          email_contacto: email,
          spotify,
          instagram,
          facebook,
          youtube,
          tiktok
        };

        const { error } = await supabase.from('configuracion').update(payload).eq('id', 1);
        if (!error) {
          await logAction('Actualizó los Ajustes de Configuración Global y Redes Sociales');
          alert('Configuración guardada exitosamente.');
          loadConfig();
        } else {
          alert('Error al actualizar configuración.');
        }
      });

      // Botones de simulación de sincronización de plataformas
      document.getElementById('btn-sync-redes')?.addEventListener('click', async () => {
        const btn = document.getElementById('btn-sync-redes') as HTMLButtonElement;
        const text = btn.textContent;
        btn.textContent = '🔄 Sincronizando...';
        btn.disabled = true;

        setTimeout(async () => {
          btn.textContent = text;
          btn.disabled = false;
          await logAction('Ejecutó sincronización forzada de seguidores y posts de Redes Sociales');
          alert('Sincronización de redes completada. Seguidores de Instagram, TikTok y Facebook actualizados.');
        }, 1500);
      });

      document.getElementById('btn-sync-musica')?.addEventListener('click', async () => {
        const btn = document.getElementById('btn-sync-musica') as HTMLButtonElement;
        const text = btn.textContent;
        btn.textContent = '🎵 Sincronizando...';
        btn.disabled = true;

        setTimeout(async () => {
          btn.textContent = text;
          btn.disabled = false;
          await logAction('Ejecutó sincronización forzada de lanzamientos y catálogo de audio en plataformas');
          alert('Sincronización de plataformas de streaming finalizada. Spotify y YouTube Music actualizados.');
        }, 1500);
      });

      // ==========================================
      // LÓGICA DE PESTAÑA: AUDITORÍA (LOGS)
      // ==========================================
      async function loadLogs() {
        const tbody = document.getElementById('logs-table-body');
        if (!tbody) return;
        tbody.innerHTML = '<tr><td colspan="3" class="p-4 text-slate-450 uppercase animate-pulse">Cargando bitácora de auditoría...</td></tr>';

        const { data, error } = await supabase
          .from('logs_actividad')
          .select('*')
          .order('created_at', { ascending: false })
          .limit(50);

        if (error || !data) {
          tbody.innerHTML = '<tr><td colspan="3" class="p-4 text-red-400">Error al cargar bitácora.</td></tr>';
          return;
        }

        if (data.length === 0) {
          tbody.innerHTML = '<tr><td colspan="3" class="p-4 text-slate-500 text-center">No hay registros de actividad aún.</td></tr>';
          return;
        }

        tbody.innerHTML = data.map(log => {
          const d = new Date(log.created_at);
          const dateStr = d.toLocaleDateString('es-CL') + ' ' + d.toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' });
          return `
            <tr class="border-b border-white/5 hover:bg-white/[0.01]">
              <td class="p-4 text-slate-400 font-mono">${dateStr}</td>
              <td class="p-4 font-bold text-white">${log.usuario_email}</td>
              <td class="p-4 text-gold-bruna font-medium">${log.accion}</td>
            </tr>
          `;
        }).join('');
      }

    });
  </script>
</Layout>
