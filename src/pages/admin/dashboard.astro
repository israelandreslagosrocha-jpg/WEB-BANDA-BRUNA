              <div class="flex gap-2 w-full md:w-auto justify-end">
                <button data-approve-testimonio-id="${item.id}" class="text-[10px] bg-green-950/20 border border-green-500/20 hover:border-green-500 hover:text-green-450 text-green-400 font-bold py-1.5 px-3 rounded uppercase transition-colors cursor-pointer">Aprobar</button>
                <button data-delete-testimonio-id="${item.id}" data-testimonio-name="${item.nombre_cliente}" class="text-[10px] border border-red-500/20 hover:border-red-500 hover:text-red-400 font-bold py-1.5 px-3 rounded uppercase transition-colors cursor-pointer">Eliminar</button>
              </div>
