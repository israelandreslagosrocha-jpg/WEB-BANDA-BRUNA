        (document.getElementById('conf-stats-youtube') as HTMLInputElement).value = data.cant_youtube !== undefined && data.cant_youtube !== null ? data.cant_youtube : 576;
        (document.getElementById('conf-stats-tiktok') as HTMLInputElement).value = data.cant_tiktok !== undefined && data.cant_tiktok !== null ? data.cant_tiktok : 1092;
        (document.getElementById('conf-stats-trayectoria') as HTMLInputElement).value = data.cant_trayectoria !== undefined && data.cant_trayectoria !== null ? data.cant_trayectoria : 15;
        (document.getElementById('conf-stats-escenarios') as HTMLInputElement).value = data.cant_escenarios !== undefined && data.cant_escenarios !== null ? data.cant_escenarios : 10;
        (document.getElementById('conf-stats-regiones') as HTMLInputElement).value = data.cant_regiones !== undefined && data.cant_regiones !== null ? data.cant_regiones : 5;
      }

