  <!-- PDF Generator Core Script CDN (Loaded dynamically) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" is:inline></script>

  <script>
    import { supabase } from '../../services/supabaseClient.js';

    let loggedInUserEmail = '';
    let stageElements = [] as any[];

    document.addEventListener('DOMContentLoaded', async () => {
      // 1. AUTENTICACIÓN: Verificar acceso seguro y correo exacto
      const { data: { session } } = await supabase.auth.getSession();
      const emailsAutorizados = ['contacto@bandabruna.cl'];
      
      if (!session || !session.user || !session.user.email || !emailsAutorizados.includes(session.user.email)) {
        // Redirigir a login
        window.location.href = '/admin';
        return;
      }

      loggedInUserEmail = session.user.email;
      const isTecnico = false;
      
      const userDisplay = document.getElementById('user-display');
      if (userDisplay) userDisplay.textContent = loggedInUserEmail;
      
      // Mostrar Panel
      const gateLoading = document.getElementById('admin-gate-loading');
      const dashboardContainer = document.getElementById('admin-dashboard-container');
      if (gateLoading) gateLoading.classList.add('hidden');
      if (dashboardContainer) dashboardContainer.classList.remove('hidden');

      // Logout handler
      document.getElementById('btn-logout')?.addEventListener('click', async () => {
        // Registrar log de salida
        try {
          await supabase.from('logs_actividad').insert([
            { usuario_email: loggedInUserEmail, accion: 'Cerró sesión del panel' }
          ]);
        } catch(e){}

        await supabase.auth.signOut();
        window.location.href = '/admin';
      });

      // 2. NAVEGACIÓN ENTRE PESTAÑAS
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabPanes = document.querySelectorAll('.tab-pane');

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-tab-target');
          
          tabBtns.forEach(b => b.classList.remove('active', 'border-gold-bruna', 'text-gold-bruna'));
          btn.classList.add('active', 'border-gold-bruna', 'text-gold-bruna');

          tabPanes.forEach(pane => {
            if (pane.id === `tab-${target}`) {
              pane.classList.remove('hidden');
            } else {
              pane.classList.add('hidden');
            }
          });

          // Cargar datos según la pestaña activa
          if (target === 'noticias') loadNoticias();
          if (target === 'eventos') loadEventos();
          if (target === 'equipo') loadEquipo();
          if (target === 'rider') loadRider();
          if (target === 'produccion-tecnica') {
            if (typeof window.loadProduccionTecnica === 'function') {
              window.loadProduccionTecnica();
            }
          }
          if (target === 'config') loadConfig();
          if (target === 'testimonios') loadTestimonios();
          if (target === 'lanzamientos') loadLanzamientos();
          if (target === 'logs') loadLogs();
          if (target === 'radio-monitor') loadRadioMonitor();
        });
      });

      // Cargar primera pestaña según el rol
      if (isTecnico) {
        // Ocultar botones de pestañas que no corresponden
        document.querySelectorAll('.tab-btn').forEach(btn => {
          const target = btn.getAttribute('data-tab-target');
          if (target !== 'rider' && target !== 'produccion-tecnica') {
            (btn as HTMLElement).style.display = 'none';
          }
        });

        // Forzar a activar pestaña de rider
        const riderBtn = document.querySelector('[data-tab-target="rider"]') as HTMLButtonElement | null;
        if (riderBtn) {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active', 'border-gold-bruna', 'text-gold-bruna'));
          document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
          
          riderBtn.classList.add('active', 'border-gold-bruna', 'text-gold-bruna');
          const tabRider = document.getElementById('tab-rider');
          if (tabRider) tabRider.classList.remove('hidden');
        }
        loadRider();
      } else {
        loadNoticias();
      }

      // 3. UTILERÍAS: Conversor de imágenes a WebP en el navegador
      async function convertToWebp(file: File): Promise<Blob> {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = function(event) {
            const img = new Image();
            img.onload = function() {
              const canvas = document.createElement('canvas');
              canvas.width = img.width;
              canvas.height = img.height;
              const ctx = canvas.getContext('2d');
              if (ctx) {
                ctx.drawImage(img, 0, 0);
                canvas.toBlob((blob) => {
                  if (blob) {
                    resolve(blob);
                  } else {
                    reject(new Error('Canvas conversion to Blob failed'));
                  }
                }, 'image/webp', 0.85); // Calidad optimizada
              } else {
                reject(new Error('Canvas context could not be created'));
              }
            };
            img.onerror = () => reject(new Error('Image failed to load'));
            img.src = event.target?.result as string;
          };
          reader.onerror = () => reject(new Error('FileReader failed'));
          reader.readAsDataURL(file);
        });
      }

      async function uploadImageToStorage(file: File, bucket: string): Promise<string | null> {
        try {
          // Convertir a WebP
          const webpBlob = await convertToWebp(file);
          const fileName = `${Date.now()}_${Math.random().toString(36).substr(2, 9)}.webp`;
          
          const { data, error } = await supabase.storage
            .from(bucket)
            .upload(fileName, webpBlob, {
              contentType: 'image/webp'
            });

          if (error) throw error;
          
          // Generar URL pública
          const { data: { publicUrl } } = supabase.storage
            .from(bucket)
            .getPublicUrl(fileName);

          return publicUrl;
        } catch (err) {
          console.error('Error al subir imagen:', err);
          alert('Hubo un error al procesar y subir tu imagen. Intenta de nuevo.');
          return null;
        }
      }

      // Helper para auditoría rápida
      async function logAction(actionText: string) {
        try {
          await supabase.from('logs_actividad').insert([
            { usuario_email: loggedInUserEmail, accion: actionText }
          ]);
        } catch(e) {
          console.error(e);
        }
      }

      // ==========================================
      // LÓGICA DE PESTAÑA: NOTICIAS
      // ==========================================
      async function loadNoticias() {
        const listDiv = document.getElementById('noticias-list');
        if (!listDiv) return;
        listDiv.innerHTML = '<p class="text-xs text-slate-450 uppercase animate-pulse">Cargando noticias...</p>';

        const { data, error } = await supabase
          .from('noticias')
          .select('*')
          .order('created_at', { ascending: false });

        if (error || !data) {
          listDiv.innerHTML = '<p class="text-xs text-red-400">Error al cargar noticias de Supabase.</p>';
          return;
        }

        if (data.length === 0) {
          listDiv.innerHTML = '<p class="text-xs text-slate-500 py-6 text-center">No hay noticias registradas. Haz clic en "Nueva Noticia" para empezar.</p>';
          return;
        }

        listDiv.innerHTML = data.map(item => `
          <div class="bg-slate-900 border border-white/5 p-4 rounded-xl flex justify-between items-center gap-4">
            <div class="flex items-center gap-4">
              ${item.imagen_principal ? `<img src="${item.imagen_principal}" class="w-12 h-12 rounded object-cover border border-white/10" />` : '<div class="w-12 h-12 bg-slate-950 rounded flex items-center justify-center text-xs text-slate-500">📰</div>'}
              <div>
                <h4 class="font-title font-bold text-sm text-white uppercase">${item.titulo}</h4>
                <p class="text-[10px] text-slate-500 mt-1">${new Date(item.created_at).toLocaleDateString('es-CL')} — Slug: <span class="text-gold-bruna">${item.slug}</span></p>
              </div>
            </div>
            <div class="flex gap-2">
              <button data-edit-noticia-id="${item.id}" class="btn-edit text-[10px] border border-white/10 hover:border-gold-bruna hover:text-gold-bruna font-bold py-1.5 px-3 rounded uppercase transition-colors cursor-pointer">Editar</button>
              <button data-delete-noticia-id="${item.id}" class="btn-delete text-[10px] border border-red-500/20 hover:border-red-500 hover:text-red-400 font-bold py-1.5 px-3 rounded uppercase transition-colors cursor-pointer">Borrar</button>
            </div>
          </div>
        `).join('');

        // Bind events
        document.querySelectorAll('[data-edit-noticia-id]').forEach(btn => {
          btn.addEventListener('click', () => openNoticiaModal((btn as HTMLButtonElement).dataset.editNoticiaId));
        });
        document.querySelectorAll('[data-delete-noticia-id]').forEach(btn => {
          btn.addEventListener('click', () => deleteNoticia((btn as HTMLButtonElement).dataset.deleteNoticiaId));
        });
      }

      document.getElementById('btn-new-noticia')?.addEventListener('click', () => openNoticiaModal());

      async function openNoticiaModal(id?: string) {
        const modal = document.getElementById('modal-container');
        if (!modal) return;

        let noticia = { titulo: '', slug: '', resumen: '', contenido: '', imagen_principal: '' };

        if (id) {
          const { data } = await supabase.from('noticias').select('*').eq('id', id).single();
          if (data) noticia = data;
        }

        modal.innerHTML = `
          <div class="bg-slate-900 border border-white/5 w-full max-w-lg rounded-2xl p-6 md:p-8 flex flex-col gap-5 max-h-[90vh] overflow-y-auto">
            <h3 class="font-title font-bold text-lg uppercase text-white">${id ? 'Editar Noticia' : 'Crear Nueva Noticia'}</h3>
            
            <form id="noticia-form" class="flex flex-col gap-4">
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Título</label>
                <input type="text" id="not-title" value="${noticia.titulo}" required class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Slug (Dirección URL única)</label>
                <input type="text" id="not-slug" value="${noticia.slug}" required placeholder="ej: gira-invierno-2026" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Resumen</label>
                <input type="text" id="not-summary" value="${noticia.resumen || ''}" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Contenido del artículo</label>
                <textarea id="not-content" rows="6" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none resize-none">${noticia.contenido || ''}</textarea>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Imagen Principal (Subir Archivo)</label>
                <input type="file" id="not-image" accept="image/*" class="bg-slate-950 border border-white/5 rounded p-2 text-white text-xs" />
                ${noticia.imagen_principal ? `<p class="text-[9px] text-slate-450 mt-1">Imagen actual: <a href="${noticia.imagen_principal}" target="_blank" class="text-gold-bruna underline">Ver imagen</a></p>` : ''}
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">O URL de la Imagen</label>
                <input type="url" id="not-image-url" value="${noticia.imagen_principal || ''}" placeholder="https://ejemplo.com/imagen.webp" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>

              <div class="flex gap-3 mt-2 justify-end">
                <button type="button" id="btn-modal-cancel" class="border border-white/10 hover:border-white/20 text-white font-bold py-2.5 px-4 rounded text-xs uppercase cursor-pointer">Cancelar</button>
                <button type="submit" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black font-bold py-2.5 px-6 rounded text-xs uppercase cursor-pointer">Guardar</button>
              </div>
            </form>
          </div>
        `;

        modal.classList.remove('hidden');

        // Close modal event
        document.getElementById('btn-modal-cancel')?.addEventListener('click', () => modal.classList.add('hidden'));

        // Guardar noticia
        document.getElementById('noticia-form')?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const title = (document.getElementById('not-title') as HTMLInputElement).value;
          const slug = (document.getElementById('not-slug') as HTMLInputElement).value;
          const summary = (document.getElementById('not-summary') as HTMLInputElement).value;
          const content = (document.getElementById('not-content') as HTMLTextAreaElement).value;
          const fileInput = document.getElementById('not-image') as HTMLInputElement;
          const urlInput = document.getElementById('not-image-url') as HTMLInputElement;

          let imgUrl = urlInput.value.trim() || noticia.imagen_principal;

          if (fileInput.files && fileInput.files[0]) {
            const uploaded = await uploadImageToStorage(fileInput.files[0], 'noticias');
            if (uploaded) {
              imgUrl = uploaded;
            } else {
              return;
            }
          }

          const payload = {
            titulo: title,
            slug,
            resumen: summary,
            contenido: content,
            imagen_principal: imgUrl
          };

          let success = false;
          if (id) {
            const { error } = await supabase.from('noticias').update(payload).eq('id', id);
            if (!error) {
              success = true;
              await logAction(`Editó la noticia: "${title}"`);
            }
          } else {
            const { error } = await supabase.from('noticias').insert([payload]);
            if (!error) {
              success = true;
              await logAction(`Creó la noticia: "${title}"`);
            }
          }

          if (success) {
            modal.classList.add('hidden');
            loadNoticias();
          } else {
            alert('Error al guardar en la base de datos de Supabase. Revisa las credenciales o RLS.');
          }
        });
