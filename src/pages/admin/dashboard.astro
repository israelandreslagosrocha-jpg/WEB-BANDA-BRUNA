---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dashboard de Administración | Banda Bruna" description="Panel de control dinámico oficial de Banda Bruna.">
  <div id="admin-gate-loading" class="min-h-screen flex items-center justify-center bg-slate-950 text-slate-400">
    <div class="text-center">
      <div class="w-10 h-10 border-4 border-gold-bruna border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-xs uppercase tracking-widest font-title font-bold">Verificando Credenciales de Seguridad...</p>
    </div>
  </div>

  <div id="admin-dashboard-container" class="hidden min-h-screen bg-slate-950 text-white">
    <!-- Topbar -->
    <header class="border-b border-white/5 bg-slate-900/60 sticky top-0 z-40 backdrop-blur-md">
      <div class="max-w-[1400px] mx-auto px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
          <img src="/assets/images/logos/logo_main.webp" alt="Logo" class="h-8 w-auto object-contain" />
          <span class="text-xs border-l border-white/10 pl-3 text-gold-bruna uppercase font-bold tracking-widest font-title">Panel de Control</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-slate-450 text-xs hidden sm:inline" id="user-display">contacto@bandabruna.cl</span>
          <button id="btn-logout" class="text-xs bg-slate-950 border border-white/10 hover:border-red-500/40 hover:text-red-400 px-3.5 py-2 rounded transition-all cursor-pointer uppercase tracking-wider font-bold">
            Cerrar Sesión
          </button>
        </div>
      </div>
    </header>

    <div class="max-w-[1400px] mx-auto px-6 py-8 grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar Navigation -->
      <aside class="lg:col-span-1 flex flex-col gap-2">
        <button data-tab-target="noticias" class="tab-btn active w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📰 Noticias & Blog
        </button>
        <button data-tab-target="eventos" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📅 Agenda & Shows
        </button>
        <button data-tab-target="equipo" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          👥 Integrantes & Staff
        </button>
        <button data-tab-target="rider" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📋 Rider Técnico / EPK
        </button>
        <button data-tab-target="config" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          ⚙️ Ajustes & Redes
        </button>
        <button data-tab-target="logs" class="tab-btn w-full text-left bg-slate-900/40 border border-white/5 hover:border-gold-bruna/20 hover:text-gold-bruna px-4 py-3 rounded-lg text-xs font-bold tracking-widest uppercase transition-all flex items-center gap-3">
          📜 Auditoría / Logs
        </button>
      </aside>

      <!-- Main Content Area -->
      <main class="lg:col-span-3 min-h-[60vh] bg-slate-900/40 border border-white/5 rounded-2xl p-6 md:p-8 relative">
        
        <!-- Tab 1: Noticias -->
        <section id="tab-noticias" class="tab-pane">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Noticias & Publicaciones</h2>
            <button id="btn-new-noticia" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-4 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
              + Nueva Noticia
            </button>
          </div>
          
          <div id="noticias-list" class="flex flex-col gap-4">
            <!-- Dynamic Noticias Rows -->
          </div>
        </section>

        <!-- Tab 2: Eventos -->
        <section id="tab-eventos" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Agenda de Conciertos</h2>
            <button id="btn-new-evento" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-4 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
              + Nuevo Show
            </button>
          </div>
          
          <div id="eventos-list" class="flex flex-col gap-4">
            <!-- Dynamic Eventos Rows -->
          </div>
        </section>

        <!-- Tab 3: Equipo (Integrantes + Staff) -->
        <section id="tab-equipo" class="tab-pane hidden">
          <div class="flex flex-col gap-8">
            <div>
              <div class="flex justify-between items-center mb-4">
                <h2 class="font-title font-bold text-lg uppercase text-white">Músicos / Integrantes</h2>
                <button id="btn-new-integrante" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-3.5 py-1.5 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
                  + Integrante
                </button>
              </div>
              <div id="integrantes-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Dynamic Integrantes Grid -->
              </div>
            </div>

            <div class="border-t border-white/5 pt-8">
              <div class="flex justify-between items-center mb-4">
                <h2 class="font-title font-bold text-lg uppercase text-white">Equipo Técnico (Staff)</h2>
                <button id="btn-new-staff" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-3.5 py-1.5 rounded text-xs font-bold uppercase tracking-wider cursor-pointer">
                  + Staff Técnico
                </button>
              </div>
              <div id="staff-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Dynamic Staff Grid -->
              </div>
            </div>
          </div>
        </section>

        <!-- Tab 4: Rider Técnico / EPK -->
        <section id="tab-rider" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Rider Técnico & EPK</h2>
            <button id="btn-pdf-rider" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-4 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer flex items-center gap-1.5">
              📥 Descargar PDF
            </button>
          </div>

          <form id="rider-form" class="flex flex-col gap-6">
            <div class="flex flex-col gap-2">
              <label class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Listado de Canales / Microfonía (Input List)</label>
              <textarea id="rider-input-list" rows="6" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna resize-none" placeholder="1. Bombo - Shure Beta 52&#10;2. Caja - Shure SM57..."></textarea>
            </div>

            <div class="flex flex-col gap-2">
              <label class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Requerimientos de Monitoreo / Mezclas</label>
              <textarea id="rider-monitores" rows="4" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna resize-none" placeholder="Mezcla 1: Bronces (In-ears)&#10;Mezcla 2: Voz Principal (Wedge)..."></textarea>
            </div>

            <button type="submit" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white font-title font-bold py-3 rounded text-xs uppercase tracking-widest transition-all w-full cursor-pointer">
              GUARDAR CAMBIOS RIDER TÉCNICO
            </button>
          </form>
        </section>

        <!-- Tab 5: Ajustes Globales & Redes -->
        <section id="tab-config" class="tab-pane hidden">
          <div class="flex justify-between items-center mb-6">
            <h2 class="font-title font-bold text-xl uppercase text-white">Configuración Global del Sitio</h2>
            <div class="flex gap-2">
              <button id="btn-sync-redes" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white px-3.5 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer transition-colors">
                🔄 Sincronizar Redes
              </button>
              <button id="btn-sync-musica" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white px-3.5 py-2 rounded text-xs font-bold uppercase tracking-wider cursor-pointer transition-colors">
                🎵 Sincronizar Música
              </button>
            </div>
          </div>

          <form id="config-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="conf-tel-p" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Teléfono Jaime Cárdenas (Booking)</label>
              <input type="text" id="conf-tel-p" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-tel-s" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Teléfono César Bruna (Dirección)</label>
              <input type="text" id="conf-tel-s" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-email" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Email de Contacto</label>
              <input type="email" id="conf-email" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-spotify" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace Spotify</label>
              <input type="url" id="conf-spotify" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-instagram" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace Instagram</label>
              <input type="url" id="conf-instagram" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-facebook" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace Facebook</label>
              <input type="url" id="conf-facebook" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-youtube" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace YouTube</label>
              <input type="url" id="conf-youtube" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="conf-tiktok" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Enlace TikTok</label>
              <input type="url" id="conf-tiktok" class="bg-slate-950 border border-white/5 rounded p-3 text-white text-xs outline-none focus:border-gold-bruna" />
            </div>

            <button type="submit" class="md:col-span-2 bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white font-title font-bold py-3.5 rounded text-xs uppercase tracking-widest transition-all cursor-pointer">
              GUARDAR CONFIGURACIÓN GENERAL
            </button>
          </form>
        </section>

        <!-- Tab 6: Auditoría / Logs -->
        <section id="tab-logs" class="tab-pane hidden">
          <h2 class="font-title font-bold text-xl uppercase text-white mb-6">Historial de Auditoría</h2>
          
          <div class="overflow-x-auto border border-white/5 rounded-xl bg-slate-950/40">
            <table class="w-full text-left text-xs border-collapse">
              <thead>
                <tr class="border-b border-white/5 bg-slate-950/80 text-slate-400">
                  <th class="p-4 uppercase font-bold tracking-wider">Fecha / Hora</th>
                  <th class="p-4 uppercase font-bold tracking-wider">Usuario</th>
                  <th class="p-4 uppercase font-bold tracking-wider">Acción Realizada</th>
                </tr>
              </thead>
              <tbody id="logs-table-body">
                <!-- Dynamic Logs -->
              </tbody>
            </table>
          </div>
        </section>

      </main>
    </div>
  </div>

  <!-- Form Modals -->
  <div id="modal-container" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-6">
    <!-- Dynamic Modal content gets injected here -->
  </div>

  <!-- PDF Generator Core Script CDN (Loaded dynamically) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" is:inline></script>

  <script>
    import { supabase } from '../../services/supabaseClient.js';

    let loggedInUserEmail = '';

    document.addEventListener('DOMContentLoaded', async () => {
      // 1. AUTENTICACIÓN: Verificar acceso seguro y correo exacto
      const { data: { session } } = await supabase.auth.getSession();
      
      if (!session || !session.user || session.user.email !== 'contacto@bandabruna.cl') {
        // Redirigir a login
        window.location.href = '/admin';
        return;
      }

      loggedInUserEmail = session.user.email;
      
      // Mostrar Panel
      const gateLoading = document.getElementById('admin-gate-loading');
      const dashboardContainer = document.getElementById('admin-dashboard-container');
      if (gateLoading) gateLoading.classList.add('hidden');
      if (dashboardContainer) dashboardContainer.classList.remove('hidden');

      // Logout handler
      document.getElementById('btn-logout')?.addEventListener('click', async () => {
        // Registrar log de salida
        try {
          await supabase.from('logs_actividad').insert([
            { usuario_email: loggedInUserEmail, accion: 'Cerró sesión del panel' }
          ]);
        } catch(e){}

        await supabase.auth.signOut();
        window.location.href = '/admin';
      });

      // 2. NAVEGACIÓN ENTRE PESTAÑAS
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabPanes = document.querySelectorAll('.tab-pane');

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-tab-target');
          
          tabBtns.forEach(b => b.classList.remove('active', 'border-gold-bruna', 'text-gold-bruna'));
          btn.classList.add('active', 'border-gold-bruna', 'text-gold-bruna');

          tabPanes.forEach(pane => {
            if (pane.id === `tab-${target}`) {
              pane.classList.remove('hidden');
            } else {
              pane.classList.add('hidden');
            }
          });

          // Cargar datos según la pestaña activa
          if (target === 'noticias') loadNoticias();
          if (target === 'eventos') loadEventos();
          if (target === 'equipo') loadEquipo();
          if (target === 'rider') loadRider();
          if (target === 'config') loadConfig();
          if (target === 'logs') loadLogs();
        });
      });

      // Cargar primera pestaña al iniciar
      loadNoticias();

      // 3. UTILERÍAS: Conversor de imágenes a WebP en el navegador
      async function convertToWebp(file: File): Promise<Blob> {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = function(event) {
            const img = new Image();
            img.onload = function() {
              const canvas = document.createElement('canvas');
              canvas.width = img.width;
              canvas.height = img.height;
              const ctx = canvas.getContext('2d');
              if (ctx) {
                ctx.drawImage(img, 0, 0);
                canvas.toBlob((blob) => {
                  if (blob) {
                    resolve(blob);
                  } else {
                    reject(new Error('Canvas conversion to Blob failed'));
                  }
                }, 'image/webp', 0.85); // Calidad optimizada
              } else {
                reject(new Error('Canvas context could not be created'));
              }
            };
            img.onerror = () => reject(new Error('Image failed to load'));
            img.src = event.target?.result as string;
          };
          reader.onerror = () => reject(new Error('FileReader failed'));
          reader.readAsDataURL(file);
        });
      }

      async function uploadImageToStorage(file: File, bucket: string): Promise<string | null> {
        try {
          // Convertir a WebP
          const webpBlob = await convertToWebp(file);
          const fileName = `${Date.now()}_${Math.random().toString(36).substr(2, 9)}.webp`;
          
          const { data, error } = await supabase.storage
            .from(bucket)
            .upload(fileName, webpBlob, {
              contentType: 'image/webp'
            });

          if (error) throw error;
          
          // Generar URL pública
          const { data: { publicUrl } } = supabase.storage
            .from(bucket)
            .getPublicUrl(fileName);

          return publicUrl;
        } catch (err) {
          console.error('Error al subir imagen:', err);
          alert('Hubo un error al procesar y subir tu imagen. Intenta de nuevo.');
          return null;
        }
      }

      // Helper para auditoría rápida
      async function logAction(actionText: string) {
        try {
          await supabase.from('logs_actividad').insert([
            { usuario_email: loggedInUserEmail, accion: actionText }
          ]);
        } catch(e) {
          console.error(e);
        }
      }

      // ==========================================
      // LÓGICA DE PESTAÑA: NOTICIAS
      // ==========================================
      async function loadNoticias() {
        const listDiv = document.getElementById('noticias-list');
        if (!listDiv) return;
        listDiv.innerHTML = '<p class="text-xs text-slate-450 uppercase animate-pulse">Cargando noticias...</p>';

        const { data, error } = await supabase
          .from('noticias')
          .select('*')
          .order('created_at', { ascending: false });

        if (error || !data) {
          listDiv.innerHTML = '<p class="text-xs text-red-400">Error al cargar noticias de Supabase.</p>';
          return;
        }

        if (data.length === 0) {
          listDiv.innerHTML = '<p class="text-xs text-slate-500 py-6 text-center">No hay noticias registradas. Haz clic en "Nueva Noticia" para empezar.</p>';
          return;
        }

        listDiv.innerHTML = data.map(item => `
          <div class="bg-slate-900 border border-white/5 p-4 rounded-xl flex justify-between items-center gap-4">
            <div class="flex items-center gap-4">
              ${item.imagen_principal ? `<img src="${item.imagen_principal}" class="w-12 h-12 rounded object-cover border border-white/10" />` : '<div class="w-12 h-12 bg-slate-950 rounded flex items-center justify-center text-xs text-slate-500">📰</div>'}
              <div>
                <h4 class="font-title font-bold text-sm text-white uppercase">${item.titulo}</h4>
                <p class="text-[10px] text-slate-500 mt-1">${new Date(item.created_at).toLocaleDateString('es-CL')} — Slug: <span class="text-gold-bruna">${item.slug}</span></p>
              </div>
            </div>
            <div class="flex gap-2">
              <button data-edit-noticia-id="${item.id}" class="btn-edit text-[10px] border border-white/10 hover:border-gold-bruna hover:text-gold-bruna font-bold py-1.5 px-3 rounded uppercase transition-colors cursor-pointer">Editar</button>
              <button data-delete-noticia-id="${item.id}" class="btn-delete text-[10px] border border-red-500/20 hover:border-red-500 hover:text-red-400 font-bold py-1.5 px-3 rounded uppercase transition-colors cursor-pointer">Borrar</button>
            </div>
          </div>
        `).join('');

        // Bind events
        document.querySelectorAll('[data-edit-noticia-id]').forEach(btn => {
          btn.addEventListener('click', () => openNoticiaModal((btn as HTMLButtonElement).dataset.editNoticiaId));
        });
        document.querySelectorAll('[data-delete-noticia-id]').forEach(btn => {
          btn.addEventListener('click', () => deleteNoticia((btn as HTMLButtonElement).dataset.deleteNoticiaId));
        });
      }

      document.getElementById('btn-new-noticia')?.addEventListener('click', () => openNoticiaModal());

      async function openNoticiaModal(id?: string) {
        const modal = document.getElementById('modal-container');
        if (!modal) return;

        let noticia = { titulo: '', slug: '', resumen: '', contenido: '', imagen_principal: '' };

        if (id) {
          const { data } = await supabase.from('noticias').select('*').eq('id', id).single();
          if (data) noticia = data;
        }

        modal.innerHTML = `
          <div class="bg-slate-900 border border-white/5 w-full max-w-lg rounded-2xl p-6 md:p-8 flex flex-col gap-5 max-h-[90vh] overflow-y-auto">
            <h3 class="font-title font-bold text-lg uppercase text-white">${id ? 'Editar Noticia' : 'Crear Nueva Noticia'}</h3>
            
            <form id="noticia-form" class="flex flex-col gap-4">
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Título</label>
                <input type="text" id="not-title" value="${noticia.titulo}" required class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Slug (Dirección URL única)</label>
                <input type="text" id="not-slug" value="${noticia.slug}" required placeholder="ej: gira-invierno-2026" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Resumen</label>
                <input type="text" id="not-summary" value="${noticia.resumen || ''}" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Contenido del artículo</label>
                <textarea id="not-content" rows="6" class="bg-slate-950 border border-white/5 rounded p-2.5 text-white text-xs outline-none resize-none">${noticia.contenido || ''}</textarea>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Imagen Principal</label>
                <input type="file" id="not-image" accept="image/*" class="bg-slate-950 border border-white/5 rounded p-2 text-white text-xs" />
                ${noticia.imagen_principal ? `<p class="text-[9px] text-slate-450 mt-1">Imagen actual: <a href="${noticia.imagen_principal}" target="_blank" class="text-gold-bruna underline">Ver imagen</a></p>` : ''}
              </div>

              <div class="flex gap-3 mt-2 justify-end">
                <button type="button" id="btn-modal-cancel" class="border border-white/10 hover:border-white/20 text-white font-bold py-2.5 px-4 rounded text-xs uppercase cursor-pointer">Cancelar</button>
                <button type="submit" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black font-bold py-2.5 px-6 rounded text-xs uppercase cursor-pointer">Guardar</button>
              </div>
            </form>
          </div>
        `;

        modal.classList.remove('hidden');

        // Close modal event
        document.getElementById('btn-modal-cancel')?.addEventListener('click', () => modal.classList.add('hidden'));

        // Guardar noticia
        document.getElementById('noticia-form')?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const title = (document.getElementById('not-title') as HTMLInputElement).value;
          const slug = (document.getElementById('not-slug') as HTMLInputElement).value;
          const summary = (document.getElementById('not-summary') as HTMLInputElement).value;
          const content = (document.getElementById('not-content') as HTMLTextAreaElement).value;
          const fileInput = document.getElementById('not-image') as HTMLInputElement;

          let imgUrl = noticia.imagen_principal;

          if (fileInput.files && fileInput.files[0]) {
            const uploaded = await uploadImageToStorage(fileInput.files[0], 'noticias');
            if (uploaded) imgUrl = uploaded;
          }

          const payload = {
            titulo: title,
            slug,
            resumen: summary,
            contenido: content,
            imagen_principal: imgUrl
          };

          let success = false;
          if (id) {
            const { error } = await supabase.from('noticias').update(payload).eq('id', id);
            if (!error) {
              success = true;
              await logAction(`Editó la noticia: "${title}"`);
            }
          } else {
            const { error } = await supabase.from('noticias').insert([payload]);
            if (!error) {
              success = true;
              await logAction(`Creó la noticia: "${title}"`);
            }
          }

          if (success) {
            modal.classList.add('hidden');
            loadNoticias();
          } else {
            alert('Error al guardar en la base de datos de Supabase. Revisa las credenciales o RLS.');
          }
        });
      }

