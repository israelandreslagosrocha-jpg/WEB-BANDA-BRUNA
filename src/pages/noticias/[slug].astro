---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../services/supabaseClient.js';
import { getNews } from '../../services/socialApi.js';

export async function getStaticPaths() {
  const { data: newsList } = await supabase
    .from('noticias')
    .select('*')
    .eq('publicado', true);

  const defaultNews = getNews();

  const allNews = newsList && newsList.length > 0
    ? newsList.map((news: any) => {
        const d = new Date(news.created_at);
        const formattedDate = d.toLocaleDateString('es-CL', {
          day: '2-digit',
          month: 'short',
          year: 'numeric'
        });

        return {
          id: news.id,
          slug: news.slug,
          title: news.titulo,
          summary: news.resumen || '',
          content: news.contenido || '',
          image: news.imagen_principal || '/assets/images/default_news.webp',
          category: news.enlace_externo ? 'Externo' : 'Noticia',
          publishedAt: formattedDate,
          gallery: news.gallery || [],
          videos: news.videos || []
        };
      })
    : defaultNews;

  return allNews.map((news: any) => ({
    params: { slug: news.slug },
    props: { news },
  }));
}

const { news } = Astro.props;
---

<Layout 
  title={`${news.title} | Banda Bruna`} 
  description={news.summary}
>
  <article class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <!-- Breadcrumbs / Back button -->
    <div class="mb-8 md:mb-12 flex items-center justify-between">
      <a 
        href="/noticias" 
        class="inline-flex items-center gap-2 text-xs md:text-sm text-slate-400 hover:text-gold-bruna transition-colors font-medium group"
      >
        <span class="group-hover:-translate-x-1 transition-transform">←</span> Volver a Noticias
      </a>
      <div class="text-xs text-slate-500 font-semibold uppercase tracking-widest hidden sm:block">
        BANDA BRUNA &bull; NOTICIAS
      </div>
    </div>

    <!-- Header info -->
    <header class="mb-8 md:mb-12 text-center md:text-left">
      <div class="flex items-center justify-center md:justify-start gap-3 mb-4">
        <span class="bg-gold-bruna/10 text-gold-bruna text-[10px] font-extrabold px-2.5 py-1 rounded tracking-widest uppercase font-title border border-gold-bruna/20">
          {news.category}
        </span>
        <span class="text-xs text-slate-400 font-semibold">{news.publishedAt}</span>
      </div>
      
      <h1 class="font-title font-extrabold text-3xl md:text-5xl text-white leading-tight mb-4">
        {news.title}
      </h1>
      
      <div class="w-16 h-0.5 bg-gold-bruna mt-6 hidden md:block"></div>
    </header>

    <!-- Featured Image -->
    {news.image && (
      <div class="w-full rounded-2xl overflow-hidden border border-white/5 shadow-2xl relative bg-slate-950 mb-10 md:mb-14">
        <img 
          src={news.image} 
          alt={news.title} 
          class="w-full h-auto max-h-[500px] object-cover object-center"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/20 to-transparent"></div>
      </div>
    )}

    <!-- Content -->
    <div class="max-w-3xl mx-auto">
      <div class="text-slate-300 font-light leading-relaxed text-base md:text-lg whitespace-pre-line space-y-6">
        {news.content}
      </div>

      <!-- Galería de Fotos (Slider) -->
      {news.gallery && news.gallery.length > 0 && (
        <div class="mt-16 md:mt-24 border-t border-white/5 pt-12 md:pt-16">
          <div class="text-center mb-10">
            <span class="text-gold-bruna text-[10px] tracking-widest font-extrabold uppercase block mb-1">GALERÍA</span>
            <h3 class="text-2xl font-bold font-title uppercase text-white">REGISTRO FOTOGRÁFICO</h3>
            <div class="w-8 h-0.5 bg-gold-bruna mx-auto mt-3"></div>
          </div>

          <!-- Slider Container -->
          <div class="relative max-w-2xl mx-auto rounded-2xl overflow-hidden border border-white/10 bg-slate-950/80 shadow-2xl group/slider">
            <div class="relative aspect-video overflow-hidden">
              {news.gallery.map((imgUrl, index) => (
                <div 
                  class={`absolute inset-0 transition-all duration-700 ease-in-out ${index === 0 ? 'opacity-100 scale-100 z-10' : 'opacity-0 scale-95 z-0'}`}
                  data-gallery-slide={index}
                >
                  <img 
                    src={imgUrl} 
                    alt={`Foto ${index + 1} de la noticia`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                  <!-- Glassy Caption/Indicator -->
                  <div class="absolute bottom-4 right-4 px-3 py-1 rounded-full bg-black/60 backdrop-blur-md border border-white/10 text-[10px] text-slate-300 font-semibold tracking-wider">
                    {index + 1} / {news.gallery.length}
                  </div>
                </div>
              ))}
            </div>

            <!-- Controls -->
            <button 
              id="gallery-prev" 
              class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full border border-white/10 hover:border-gold-bruna bg-black/60 hover:bg-black/90 text-white hover:text-gold-bruna flex items-center justify-center transition-all cursor-pointer select-none opacity-0 group-hover/slider:opacity-100 focus:opacity-100"
              aria-label="Foto anterior"
            >
              ←
            </button>
            <button 
              id="gallery-next" 
              class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full border border-white/10 hover:border-gold-bruna bg-black/60 hover:bg-black/90 text-white hover:text-gold-bruna flex items-center justify-center transition-all cursor-pointer select-none opacity-0 group-hover/slider:opacity-100 focus:opacity-100"
              aria-label="Foto siguiente"
            >
              →
            </button>

            <!-- Indicators (dots) -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 flex gap-1.5 py-1 px-2.5 rounded-full bg-black/40 backdrop-blur-sm border border-white/5">
              {news.gallery.map((_, index) => (
                <button 
                  class={`w-1.5 h-1.5 rounded-full transition-all duration-300 ${index === 0 ? 'bg-gold-bruna scale-125' : 'bg-white/30 hover:bg-white/60'}`}
                  data-gallery-indicator={index}
                  aria-label={`Ir a foto ${index + 1}`}
                />
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Videos Adicionales (Cloudinary) -->
      {news.videos && news.videos.length > 0 && (
        <div class="mt-16 md:mt-24 border-t border-white/5 pt-12 md:pt-16">
          <div class="text-center mb-10">
            <span class="text-gold-bruna text-[10px] tracking-widest font-extrabold uppercase block mb-1">DETRÁS DE CÁMARAS</span>
            <h3 class="text-2xl font-bold font-title uppercase text-white">REGISTRO EN VIDEO</h3>
            <div class="w-8 h-0.5 bg-gold-bruna mx-auto mt-3"></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-2xl mx-auto">
            {news.videos.map((vidUrl, index) => (
              <div class="relative w-full aspect-[9/16] max-w-[325px] mx-auto bg-slate-950/60 rounded-2xl overflow-hidden border border-white/5 p-1.5 shadow-xl hover:border-gold-bruna/20 transition-all group">
                <video 
                  src={vidUrl} 
                  controls 
                  preload="metadata"
                  class="w-full h-full rounded-xl object-cover"
                  title={`Video de detrás de cámaras ${index + 1}`}
                >
                  <track kind="captions" src="/assets/captions.vtt" srclang="es" label="Español" default />
                  Tu navegador no soporta la reproducción de video.
                </video>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- TikTok Embed Section -->
      {news.tiktoks && news.tiktoks.length > 0 && (
        <div class="mt-16 md:mt-24 border-t border-white/5 pt-12 md:pt-16">
          <div class="text-center mb-10">
            <span class="text-gold-bruna text-[10px] tracking-widest font-extrabold uppercase block mb-1">CONTENIDO MULTIMEDIA</span>
            <h3 class="text-2xl font-bold font-title uppercase text-white">VIDEOS RELACIONADOS</h3>
            <div class="w-8 h-0.5 bg-gold-bruna mx-auto mt-3"></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-2xl mx-auto">
            {news.tiktoks.map((tiktokId) => (
              <div class="relative w-full aspect-[9/16] max-w-[325px] mx-auto bg-slate-950/60 rounded-2xl overflow-hidden border border-white/5 p-1.5 shadow-xl hover:border-gold-bruna/20 transition-all group">
                <iframe
                  src={`https://www.tiktok.com/embed/v2/${tiktokId}`}
                  class="w-full h-full rounded-xl"
                  style="border: none;"
                  allowfullscreen
                  scrolling="no"
                  title="TikTok Video Player"
                />
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Bottom Nav -->
      <div class="mt-16 pt-8 border-t border-white/5 flex justify-center">
        <a 
          href="/noticias" 
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-gold-bruna/30 hover:border-gold-bruna text-gold-bruna hover:bg-gold-bruna/5 text-sm font-semibold transition-all cursor-pointer group"
        >
          <span class="group-hover:-translate-x-1 transition-transform">←</span> Volver a Noticias
        </a>
      </div>
    </div>

  </article>
</Layout>

<script>
  function setupGallery() {
    const prevBtn = document.getElementById('gallery-prev');
    const nextBtn = document.getElementById('gallery-next');
    const slides = document.querySelectorAll('[data-gallery-slide]');
    const indicators = document.querySelectorAll('[data-gallery-indicator]');
    
    if (slides.length === 0) return;
    
    let currentIndex = 0;
    
    function goToSlide(index) {
      // Handle wrap-around
      if (index < 0) {
        index = slides.length - 1;
      } else if (index >= slides.length) {
        index = 0;
      }
      
      // Update slides classes
      slides.forEach((slide, idx) => {
        if (idx === index) {
          slide.classList.remove('opacity-0', 'scale-95', 'z-0');
          slide.classList.add('opacity-100', 'scale-100', 'z-10');
        } else {
          slide.classList.remove('opacity-100', 'scale-100', 'z-10');
          slide.classList.add('opacity-0', 'scale-95', 'z-0');
        }
      });
      
      // Update indicators
      indicators.forEach((indicator, idx) => {
        if (idx === index) {
          indicator.classList.remove('bg-white/30', 'scale-100');
          indicator.classList.add('bg-gold-bruna', 'scale-125');
        } else {
          indicator.classList.remove('bg-gold-bruna', 'scale-125');
          indicator.classList.add('bg-white/30', 'scale-100');
        }
      });
      
      currentIndex = index;
    }
    
    if (prevBtn) {
      const newPrev = prevBtn.cloneNode(true);
      prevBtn.parentNode.replaceChild(newPrev, prevBtn);
      newPrev.addEventListener('click', () => goToSlide(currentIndex - 1));
    }
    
    if (nextBtn) {
      const newNext = nextBtn.cloneNode(true);
      nextBtn.parentNode.replaceChild(newNext, nextBtn);
      newNext.addEventListener('click', () => goToSlide(currentIndex + 1));
    }
    
    indicators.forEach((indicator, idx) => {
      const newInd = indicator.cloneNode(true);
      indicator.parentNode.replaceChild(newInd, indicator);
      newInd.addEventListener('click', () => goToSlide(idx));
    });

    // Touch support (swipe)
    const sliderContainer = document.querySelector('.group\\/slider');
    if (sliderContainer) {
      let startX = 0;
      sliderContainer.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
      }, { passive: true });

      sliderContainer.addEventListener('touchend', (e) => {
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;
        if (Math.abs(diff) > 50) { // threshold
          if (diff > 0) {
            goToSlide(currentIndex + 1); // swipe left -> next
          } else {
            goToSlide(currentIndex - 1); // swipe right -> prev
          }
        }
      }, { passive: true });
    }
  }

  // Setup on page load & after swap/view transitions
  document.addEventListener('DOMContentLoaded', setupGallery);
  document.addEventListener('astro:after-swap', setupGallery);
</script>
