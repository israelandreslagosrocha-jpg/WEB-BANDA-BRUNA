---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Galería | Banda Bruna - Fotos de Conciertos y Escenarios" description="Explora la galería oficial de fotos de Banda Bruna: presentaciones en vivo, interacción con el público y escenarios en festivales de Chile.">
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">REGISTRO FOTOGRÁFICO</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">GALERÍA</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      <div class="relative aspect-square rounded-xl overflow-hidden border border-white/5 group bg-slate-900">
        <img src="assets/images/hero.png" alt="Concierto Banda Bruna 1" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      </div>
      <div class="relative aspect-square rounded-xl overflow-hidden border border-white/5 group bg-slate-900">
        <img src="assets/images/album.png" alt="Concierto Banda Bruna 2" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      </div>
      <div class="relative aspect-square rounded-xl overflow-hidden border border-white/5 group bg-slate-900">
        <img src="assets/images/hero.png" alt="Concierto Banda Bruna 3" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      </div>
      <div class="relative aspect-square rounded-xl overflow-hidden border border-white/5 group bg-slate-900">
        <img src="assets/images/album.png" alt="Concierto Banda Bruna 4" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      </div>
      <div class="relative aspect-square rounded-xl overflow-hidden border border-white/5 group bg-slate-900">
        <img src="assets/images/hero.png" alt="Concierto Banda Bruna 5" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      </div>
      <div class="relative aspect-square rounded-xl overflow-hidden border border-white/5 group bg-slate-900">
        <img src="assets/images/album.png" alt="Concierto Banda Bruna 6" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
      </div>
    </div>

  </section>
</Layout>
