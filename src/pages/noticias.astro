---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../services/supabaseClient.js';
import { getNews } from '../services/socialApi.js';

// Cargar noticias publicadas desde Supabase, ordenadas por fecha descendente
const { data: dbNews } = await supabase
  .from('noticias')
  .select('*')
  .eq('publicado', true)
  .order('created_at', { ascending: false });

const defaultNews = getNews().map(item => ({
  id: item.slug,
  slug: item.slug,
  title: item.title,
  summary: item.summary,
  image: item.image,
  category: item.category,
  publishedAt: item.publishedAt
}));

const newsList = dbNews && dbNews.length > 0
  ? dbNews.map((item: any) => {
      const d = new Date(item.created_at);
      const formattedDate = d.toLocaleDateString('es-CL', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      });

      return {
        id: item.id,
        slug: item.slug,
        title: item.titulo,
        summary: item.resumen || '',
        image: item.imagen_principal || '/assets/images/default_news.webp',
        category: item.enlace_externo ? 'Externo' : 'Noticia',
        publishedAt: formattedDate
      };
    })
  : defaultNews;
---

<Layout title="Noticias | Banda Bruna - Blog y Novedades Oficiales" description="Entérate de las últimas noticias sobre Banda Bruna: nuevos lanzamientos, colaboraciones musicales, hitos y giras de conciertos.">
  <section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">BOLETÍN</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold font-title uppercase">NOTICIAS</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- Blog grid listing -->
    <div class="flex flex-col gap-8">
      {newsList.map(news => (
        <a href={`/noticias/${news.slug}`} class="block group">
          <article class="bg-slate-900/60 border border-white/5 hover:border-gold-bruna/50 rounded-xl overflow-hidden transition-all duration-300 flex flex-col md:flex-row gap-6 p-5 md:p-6 hover:shadow-xl hover:shadow-gold-bruna/5">
            {news.image && (
              <div class="w-full md:w-56 h-48 md:h-auto overflow-hidden rounded-lg shrink-0 relative bg-slate-950">
                <img
                  src={news.image}
                  alt={news.title}
                  class="w-full h-full object-cover object-center group-hover:scale-103 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
              </div>
            )}
            
            <div class="flex flex-col justify-between flex-1">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <span class="bg-gold-bruna/10 text-gold-bruna text-[10px] font-extrabold px-2 py-0.5 rounded tracking-widest uppercase font-title border border-gold-bruna/20">
                    {news.category}
                  </span>
                  <span class="text-xs text-slate-400 font-semibold">{news.publishedAt}</span>
                </div>
                
                <h2 class="font-title font-bold text-xl md:text-2xl text-white group-hover:text-gold-bruna transition-colors mb-2 leading-snug">
                  {news.title}
                </h2>
                
                <p class="text-sm text-slate-400 font-light leading-relaxed mb-4">
                  {news.summary}
                </p>
              </div>

              <div class="pt-4 border-t border-white/5 flex justify-end items-center">
                <span class="text-xs text-gold-bruna font-semibold group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                  Leer artículo completo <span class="text-sm">→</span>
                </span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>

  </section>
</Layout>
