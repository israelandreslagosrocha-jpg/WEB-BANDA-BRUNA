---
import Layout from '../layouts/Layout.astro';
import { getVideoPlaylists } from '../services/socialApi.js';

const playlists = getVideoPlaylists();
---

<Layout title="Vídeos | Banda Bruna - Videoclips Oficiales y Presentaciones en Vivo" description="Disfruta de la videoteca de Banda Bruna: presentaciones destacadas, videoclips de YouTube y Reels oficiales de Facebook.">
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">AUDIOVISUAL</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">GALERÍA DE VIDEOS</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- 1. Video Destacado en Vivo (Facebook) -->
    <div class="mb-20">
      <div class="bg-slate-900/60 border border-white/5 rounded-2xl p-6 md:p-8 backdrop-blur-md shadow-2xl flex flex-col lg:flex-row gap-8 items-center">
        
        <!-- Facebook Reel Embed (aspect-[9/16] vertical mobile frame) -->
        <div class="w-full lg:w-1/2 flex justify-center">
          <div class="w-full max-w-[340px] aspect-[9/16] rounded-xl overflow-hidden bg-black border border-white/10 shadow-lg relative">
            <iframe 
              src="https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2Freel%2F918184277458701&show_text=0&width=340" 
              width="100%" 
              height="100%" 
              style="border:none;overflow:hidden;position:absolute;top:0;left:0;" 
              scrolling="no" 
              frameborder="0" 
              allowfullscreen="true" 
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
            ></iframe>
          </div>
        </div>

        <!-- Description Box -->
        <div class="w-full lg:w-1/2 flex flex-col justify-center text-left">
          <span class="text-[10px] tracking-widest font-bold text-gold-bruna uppercase block mb-1.5">PRESENTACIÓN DESTACADA</span>
          <h2 class="font-title font-bold text-2xl text-white uppercase leading-snug mb-3">
            La Energía del Show en Vivo
          </h2>
          <p class="text-xs text-slate-300 font-light leading-relaxed mb-6">
            Una muestra auténtica de Banda Bruna sobre el escenario. Experimenta la potencia del sonido en vivo, la alegría contagiosa y la respuesta vibrante del público sureño que define cada una de nuestras fechas.
          </p>
          <div class="flex flex-wrap gap-4">
            <a 
              href="https://www.facebook.com/reel/918184277458701" 
              target="_blank" 
              rel="noopener" 
              class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs px-5 py-2.5 rounded hover:scale-102 transition-all flex items-center gap-2 uppercase"
            >
              <span>Ver en Facebook</span>
              <span>🌐</span>
            </a>
            <a 
              href="/contrataciones" 
              class="border border-white/10 hover:border-gold-bruna bg-transparent hover:bg-white/5 text-white font-bold text-xs px-5 py-2.5 rounded transition-all uppercase"
            >
              Cotizar Show
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- Section loops for playlists categories -->
    <div class="flex flex-col gap-20">
      
      <!-- 2. Canal de YouTube Oficial -->
      <div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[10px] tracking-widest font-bold uppercase block mb-1">VIDEOCLIPS & LIVE SESSIONS</span>
            <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide">
              Canal Oficial de YouTube
            </h2>
          </div>
          <a 
            href="https://www.youtube.com/@bandabrunaoficial" 
            target="_blank" 
            rel="noopener" 
            class="text-red-500 hover:text-red-400 text-xs font-bold hover:underline tracking-wider uppercase mt-3 md:mt-0 flex items-center gap-1.5"
          >
            Ir al canal de YouTube (Suscribirse) →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {playlists.youtube.map(video => (
            <a 
              href={video.url} 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900/60 border border-white/5 hover:border-gold-bruna rounded-xl p-4 group block transition-all hover:translate-y-[-4px] shadow-lg"
            >
              <div class="aspect-video bg-black rounded-lg overflow-hidden mb-4 relative flex items-center justify-center border border-white/5">
                <img 
                  src={video.thumbnail} 
                  alt={video.title} 
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" 
                />
                <!-- Play button overlay -->
                <div class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/30 transition-colors">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center font-bold shadow-lg group-hover:scale-110 transition-transform pl-0.5">▶</div>
                </div>
                <span class="absolute bottom-2 right-2 bg-black/85 text-white text-[9px] font-bold px-1.5 py-0.5 rounded font-mono">
                  {video.duration}
                </span>
              </div>
              <h3 class="font-semibold text-white group-hover:text-gold-bruna transition-colors text-xs line-clamp-2 leading-snug">{video.title}</h3>
              <span class="text-[9px] text-slate-500 font-bold block mt-2 uppercase tracking-widest">{video.category}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- 3. Facebook Reels & Clips Cortos -->
      <div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[10px] tracking-widest font-bold uppercase block mb-1">REELS & CONTENIDO VERTICAL</span>
            <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide">
              Facebook Reels & Clips
            </h2>
          </div>
          <a 
            href="https://www.facebook.com/bandabruna/reels/" 
            target="_blank" 
            rel="noopener" 
            class="text-blue-500 hover:text-blue-400 text-xs font-bold hover:underline tracking-wider uppercase mt-3 md:mt-0 flex items-center gap-1.5"
          >
            Ver Reels en Facebook →
          </a>
        </div>

        <!-- Vertical Reels Cards Grid (Portrait aspect-[9/16] simulating mobile screens) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {playlists.facebook.slice(1).map(reel => (
            <a 
              href={reel.url} 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900/60 border border-white/5 hover:border-blue-500 rounded-xl overflow-hidden group block transition-all hover:translate-y-[-4px] shadow-lg relative flex flex-col justify-end aspect-[9/15]"
            >
              <!-- Reel Cover/Placeholder with Gradient -->
              <div class="absolute inset-0 bg-slate-950 flex items-center justify-center">
                <!-- Decorative Icon simulating Reel background -->
                <svg class="w-12 h-12 text-white/5 group-hover:scale-110 transition-transform duration-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M4 4h16v16H4V4zm2 2v12h12V6H6zm3 2.5l5 3.5-5 3.5v-7z"/>
                </svg>
              </div>
              
              <!-- Dark gradient mask over image -->
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent z-10"></div>
              
              <!-- Floating play icon and category badge -->
              <div class="absolute top-3 left-3 z-20 bg-blue-600/90 text-white font-bold text-[8px] px-2 py-0.5 rounded-sm tracking-wider uppercase">
                REEL
              </div>
              <div class="absolute top-3 right-3 z-20 text-[10px] text-white/80 bg-black/40 px-1.5 py-0.5 rounded font-mono">
                {reel.duration}
              </div>

              <!-- Content Box aligned to the bottom -->
              <div class="p-4 z-20 text-left">
                <div class="flex items-center gap-1.5 text-white/90 text-[10px] font-bold mb-1">
                  <span>🎬</span>
                  <span class="truncate">banda_bruna</span>
                </div>
                <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors text-xs line-clamp-2 leading-snug">{reel.title}</h3>
                <span class="text-[9px] text-slate-400 block mt-2">Ver Reel en Facebook →</span>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>

  </section>
</Layout>
