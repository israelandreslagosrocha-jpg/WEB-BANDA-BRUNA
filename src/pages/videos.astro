---
import Layout from '../layouts/Layout.astro';
import { getVideoPlaylists } from '../services/socialApi.js';

const playlists = getVideoPlaylists();
---

<Layout title="Vídeos | Banda Bruna - Videoclips Oficiales y Presentaciones en Vivo" description="Disfruta de la videoteca de Banda Bruna: presentaciones destacadas, videoclips de YouTube y Reels oficiales de Facebook.">
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">AUDIOVISUAL</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">GALERÍA DE VIDEOS</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- 1. Video Destacado en Vivo (Facebook Video Showcase) -->
    <div class="mb-20">
      <div class="bg-slate-900/60 border border-white/5 rounded-2xl p-6 md:p-8 backdrop-blur-md shadow-2xl flex flex-col lg:flex-row gap-8 items-center">
        
        <!-- Large Video Player Carousel Container -->
        <div class="w-full lg:w-3/5 aspect-video rounded-xl overflow-hidden bg-black border border-white/10 shadow-lg relative group">
          <!-- Slide wrapper -->
          <div id="video-carousel" class="flex w-full h-full transition-transform duration-500 ease-in-out" style="transform: translateX(0%);">
            <!-- Slide 1 -->
            <div class="w-full h-full shrink-0 relative flex items-center justify-center">
              <video 
                src="https://res.cloudinary.com/dhgifjpkh/video/upload/v1781905596/2.9K_views_119_reactions_Algo_de_lo_que_fue_Puerto_Saavedra_este_fin_de_semana_Gracias_a_todo_ese_lindo_Pu%CC%81blico_Este_sa%CC%81b_b0gyk9.mp4" 
                class="w-full h-full object-cover bg-slate-950" 
                controls 
                preload="metadata"
                playsinline
                aria-label="Presentación en vivo de Banda Bruna - Puerto Saavedra"
              >
                <track kind="captions" src="/assets/captions.vtt" srclang="es" label="Español" default />
              </video>
            </div>
            <!-- Slide 2 -->
            <div class="w-full h-full shrink-0 relative flex items-center justify-center">
              <video 
                src="https://res.cloudinary.com/dhgifjpkh/video/upload/v1782411607/WhatsApp_Video_2026-06-24_at_12.56.26_PM_oqdkzs.mp4" 
                class="w-full h-full object-cover bg-slate-950" 
                controls 
                preload="metadata"
                playsinline
                aria-label="Presentación en vivo de Banda Bruna - Show en Vivo 2"
              >
                <track kind="captions" src="/assets/captions.vtt" srclang="es" label="Español" default />
              </video>
            </div>
          </div>

          <!-- Carousel Controls (Arrows) -->
          <button id="prev-video" class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-8 h-8 rounded-full bg-black/60 hover:bg-black/90 text-white flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10 select-none" aria-label="Video anterior">❮</button>
          <button id="next-video" class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-8 h-8 rounded-full bg-black/60 hover:bg-black/90 text-white flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 cursor-pointer border border-white/10 select-none" aria-label="Siguiente video">❯</button>
          
          <!-- Slide indicators (dots) -->
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex gap-2">
            <button class="w-2 h-2 rounded-full bg-white/40 hover:bg-white transition-all cursor-pointer" data-slide="0" aria-label="Video 1"></button>
            <button class="w-2 h-2 rounded-full bg-white/40 hover:bg-white transition-all cursor-pointer" data-slide="1" aria-label="Video 2"></button>
          </div>
        </div>

        <!-- Description Box -->
        <div class="w-full lg:w-2/5 flex flex-col justify-center text-left">
          <span class="text-[10px] tracking-widest font-bold text-gold-bruna uppercase block mb-1.5 font-title">PRESENTACIÓN DESTACADA</span>
          <h2 id="featured-video-title" class="font-title font-bold text-2xl text-white uppercase leading-snug mb-3">
            La Energía del Show en Vivo
          </h2>
          <p class="text-xs text-slate-300 font-light leading-relaxed mb-6">
            Una muestra auténtica de Banda Bruna sobre el escenario. Experimenta la potencia del sonido en vivo, la alegría contagiosa y la respuesta vibrante del público sureño que define cada una de nuestras fechas.
          </p>
          <div class="flex flex-wrap gap-4">
            <a 
              id="fb-video-link"
              href="https://www.facebook.com/reel/918184277458701" 
              target="_blank" 
              rel="noopener" 
              class="bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs px-5 py-2.5 rounded hover:scale-102 transition-all flex items-center gap-2 uppercase cursor-pointer"
            >
              <span>Ver en Facebook</span>
              <span>🌐</span>
            </a>
            <a 
              href="/contrataciones" 
              class="border border-white/10 hover:border-gold-bruna bg-transparent hover:bg-white/5 text-white font-bold text-xs px-5 py-2.5 rounded transition-all uppercase cursor-pointer"
            >
              Cotizar Show
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- Section loops for playlists categories -->
    <div class="flex flex-col gap-20">
      
      <!-- 2. Canal de YouTube Oficial -->
      <div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[10px] tracking-widest font-bold uppercase block mb-1">VIDEOCLIPS & LIVE SESSIONS</span>
            <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide">
              Canal Oficial de YouTube
            </h2>
          </div>
          <a 
            href="https://www.youtube.com/@bandabrunaoficial" 
            target="_blank" 
            rel="noopener" 
            class="text-red-500 hover:text-red-400 text-xs font-bold hover:underline tracking-wider uppercase mt-3 md:mt-0 flex items-center gap-1.5"
          >
            Ir al canal de YouTube (Suscribirse) →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {playlists.youtube.map(video => (
            <a 
              href={video.url} 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900/60 border border-white/5 hover:border-gold-bruna rounded-xl p-4 group block transition-all hover:translate-y-[-4px] shadow-lg"
            >
              <div class="aspect-video bg-black rounded-lg overflow-hidden mb-4 relative flex items-center justify-center border border-white/5">
                <img 
                  src={video.thumbnail} 
                  alt={video.title} 
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" 
                />
                <!-- Play button overlay -->
                <div class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/30 transition-colors">
                  <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center font-bold shadow-lg group-hover:scale-110 transition-transform pl-0.5">▶</div>
                </div>
                <span class="absolute bottom-2 right-2 bg-black/85 text-white text-[9px] font-bold px-1.5 py-0.5 rounded font-mono">
                  {video.duration}
                </span>
              </div>
              <h3 class="font-semibold text-white group-hover:text-gold-bruna transition-colors text-xs line-clamp-2 leading-snug">{video.title}</h3>
              <span class="text-[9px] text-slate-500 font-bold block mt-2 uppercase tracking-widest">{video.category}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- 3. Facebook Reels & Clips Cortos -->
      <div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[10px] tracking-widest font-bold uppercase block mb-1">REELS & CONTENIDO VERTICAL</span>
            <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide">
              Facebook Reels & Clips
            </h2>
          </div>
          <a 
            href="https://www.facebook.com/bandabruna/reels/" 
            target="_blank" 
            rel="noopener" 
            class="text-blue-500 hover:text-blue-400 text-xs font-bold hover:underline tracking-wider uppercase mt-3 md:mt-0 flex items-center gap-1.5"
          >
            Ver Reels en Facebook →
          </a>
        </div>

        <!-- Vertical Reels Cards Grid (Portrait aspect-[9/15] simulating mobile screens) -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
          {playlists.facebook.map(reel => (
            <a 
              href={reel.url} 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900/60 border border-white/5 hover:border-blue-500 rounded-xl overflow-hidden group block transition-all hover:translate-y-[-4px] shadow-lg relative flex flex-col justify-end aspect-[9/15]"
            >
              <!-- Reel Cover Image -->
              <img 
                src={reel.thumbnail} 
                alt={reel.title} 
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                loading="lazy"
              />
              
              <!-- Dark gradient mask over image -->
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/45 to-black/10 z-10"></div>
              
              <!-- Play button overlay in the center -->
              <div class="absolute inset-0 flex items-center justify-center z-20 pointer-events-none">
                <div class="w-10 h-10 bg-white/10 backdrop-blur-sm border border-white/25 text-white rounded-full flex items-center justify-center font-bold shadow-lg group-hover:scale-110 group-hover:bg-blue-600 group-hover:border-blue-500 transition-all duration-300">
                  <svg class="w-4 h-4 fill-current ml-0.5" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              
              <!-- Floating play icon and category badge -->
              <div class="absolute top-3 left-3 z-20 bg-blue-600/90 text-white font-bold text-[8px] px-2 py-0.5 rounded-sm tracking-wider uppercase">
                REEL
              </div>
              <div class="absolute top-3 right-3 z-20 text-[10px] text-white/80 bg-black/40 px-1.5 py-0.5 rounded font-mono">
                {reel.duration}
              </div>

              <!-- Content Box aligned to the bottom -->
              <div class="p-4 z-20 text-left">
                <div class="flex items-center gap-1.5 text-white/90 text-[10px] font-bold mb-1">
                  <span>🎬</span>
                  <span class="truncate">banda_bruna</span>
                </div>
                <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors text-xs line-clamp-3 leading-snug">{reel.title}</h3>
                <span class="text-[9px] text-slate-400 block mt-2">Ver Reel en Facebook →</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 4. Instagram Reels & Clips -->
      <div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[10px] tracking-widest font-bold uppercase block mb-1">REELS & CONTENIDO VERTICAL</span>
            <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide">
              Instagram Reels & Clips
            </h2>
          </div>
          <a 
            href="https://www.instagram.com/banda_bruna/" 
            target="_blank" 
            rel="noopener" 
            class="text-[#E1306C] hover:text-[#f7528a] text-xs font-bold hover:underline tracking-wider uppercase mt-3 md:mt-0 flex items-center gap-1.5"
          >
            Ver Reels en Instagram →
          </a>
        </div>

        <!-- Vertical Reels Cards Grid (Portrait aspect-[9/15] simulating mobile screens) -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
          {playlists.instagram.map(reel => (
            <a 
              href={reel.url} 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900/60 border border-white/5 hover:border-[#E1306C] rounded-xl overflow-hidden group block transition-all hover:translate-y-[-4px] shadow-lg relative flex flex-col justify-end aspect-[9/15]"
            >
              <!-- Reel Cover Image -->
              <img 
                src={reel.thumbnail} 
                alt={reel.title} 
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                loading="lazy"
              />
              
              <!-- Dark gradient mask over image -->
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/45 to-black/10 z-10"></div>
              
              <!-- Play button overlay in the center -->
              <div class="absolute inset-0 flex items-center justify-center z-20 pointer-events-none">
                <div class="w-10 h-10 bg-white/10 backdrop-blur-sm border border-white/25 text-white rounded-full flex items-center justify-center font-bold shadow-lg group-hover:scale-110 group-hover:bg-[#E1306C] group-hover:border-[#E1306C] transition-all duration-300">
                  <svg class="w-4 h-4 fill-current ml-0.5" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              
              <!-- Floating play icon and category badge -->
              <div class="absolute top-3 left-3 z-20 bg-[#E1306C]/90 text-white font-bold text-[8px] px-2 py-0.5 rounded-sm tracking-wider uppercase">
                REEL
              </div>
              <div class="absolute top-3 right-3 z-20 text-[10px] text-white/80 bg-black/40 px-1.5 py-0.5 rounded font-mono">
                {reel.duration}
              </div>

              <!-- Content Box aligned to the bottom -->
              <div class="p-4 z-20 text-left">
                <div class="flex items-center gap-1.5 text-white/90 text-[10px] font-bold mb-1">
                  <span>📸</span>
                  <span class="truncate">banda_bruna</span>
                </div>
                <h3 class="font-semibold text-white group-hover:text-[#E1306C] transition-colors text-xs line-clamp-3 leading-snug">{reel.title}</h3>
                <span class="text-[9px] text-slate-400 block mt-2">Ver Reel en Instagram →</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 5. TikTok Oficial & Clips Cortos -->
      <div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[10px] tracking-widest font-bold uppercase block mb-1">TIKTOK VIDEOS & TRENDS</span>
            <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide">
              TikTok Oficial & Clips
            </h2>
          </div>
          <a 
            href="https://www.tiktok.com/@bandabrunaoficial" 
            target="_blank" 
            rel="noopener" 
            class="text-[#FE2C55] hover:text-[#ff4e72] text-xs font-bold hover:underline tracking-wider uppercase mt-3 md:mt-0 flex items-center gap-1.5"
          >
            Ver en TikTok →
          </a>
        </div>

        <!-- Vertical TikTok Cards Grid (Portrait aspect-[9/15] simulating mobile screens) -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
          {playlists.tiktok.map(video => (
            <a 
              href={video.url} 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900/60 border border-white/5 hover:border-[#FE2C55] rounded-xl overflow-hidden group block transition-all hover:translate-y-[-4px] shadow-lg relative flex flex-col justify-end aspect-[9/15]"
            >
              <!-- Video Cover Image -->
              <img 
                src={video.thumbnail} 
                alt={video.title} 
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                loading="lazy"
              />
              
              <!-- Dark gradient mask over image -->
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/45 to-black/10 z-10"></div>
              
              <!-- Play button overlay in the center -->
              <div class="absolute inset-0 flex items-center justify-center z-20 pointer-events-none">
                <div class="w-10 h-10 bg-white/10 backdrop-blur-sm border border-white/25 text-white rounded-full flex items-center justify-center font-bold shadow-lg group-hover:scale-110 group-hover:bg-[#FE2C55] group-hover:border-[#FE2C55] transition-all duration-300">
                  <svg class="w-4 h-4 fill-current ml-0.5" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              
              <!-- Floating play icon and category badge -->
              <div class="absolute top-3 left-3 z-20 bg-[#FE2C55]/90 text-white font-bold text-[8px] px-2 py-0.5 rounded-sm tracking-wider uppercase">
                TIKTOK
              </div>
              <div class="absolute top-3 right-3 z-20 text-[10px] text-white/80 bg-black/40 px-1.5 py-0.5 rounded font-mono">
                {video.duration}
              </div>

              <!-- Content Box aligned to the bottom -->
              <div class="p-4 z-20 text-left">
                <div class="flex items-center gap-1.5 text-white/90 text-[10px] font-bold mb-1">
                  <span>🎵</span>
                  <span class="truncate">bandabrunaoficial</span>
                </div>
                <h3 class="font-semibold text-white group-hover:text-[#FE2C55] transition-colors text-xs line-clamp-3 leading-snug">{video.title}</h3>
                <span class="text-[9px] text-slate-400 block mt-2">Ver Video en TikTok →</span>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>

  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const carousel = document.getElementById('video-carousel');
      const prevBtn = document.getElementById('prev-video');
      const nextBtn = document.getElementById('next-video');
      const dots = document.querySelectorAll('[data-slide]');
      const videos = document.querySelectorAll('#video-carousel video') as NodeListOf<HTMLVideoElement>;
      const videoTitle = document.getElementById('featured-video-title');
      const fbBtn = document.getElementById('fb-video-link') as HTMLAnchorElement;

      let currentSlide = 0;

      const titles = [
        "La Energía del Show en Vivo",
        "Show Masivo en el Escenario"
      ];
      
      const fbLinks = [
        "https://www.facebook.com/reel/918184277458701",
        "https://www.facebook.com/bandabruna"
      ];

      function updateCarousel(index: number) {
        // Pausar todos los videos
        videos.forEach(vid => vid.pause());

        currentSlide = index;
        if (carousel) {
          carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
        }

        // Actualizar dots
        dots.forEach((dot, idx) => {
          if (idx === currentSlide) {
            dot.classList.add('bg-white');
            dot.classList.remove('bg-white/40');
          } else {
            dot.classList.remove('bg-white');
            dot.classList.add('bg-white/40');
          }
        });

        // Actualizar título y link de FB
        if (videoTitle) {
          videoTitle.textContent = titles[currentSlide];
        }
        if (fbBtn) {
          fbBtn.href = fbLinks[currentSlide];
        }
      }

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener('click', () => {
          let index = currentSlide - 1;
          if (index < 0) index = videos.length - 1;
          updateCarousel(index);
        });

        nextBtn.addEventListener('click', () => {
          let index = currentSlide + 1;
          if (index >= videos.length) index = 0;
          updateCarousel(index);
        });
      }

      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          updateCarousel(idx);
        });
      });

      // Inicializar primer estado
      updateCarousel(0);
    });
  </script>
</Layout>
