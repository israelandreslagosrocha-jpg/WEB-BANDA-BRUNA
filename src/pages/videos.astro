---
import Layout from '../layouts/Layout.astro';
import { getVideoPlaylists } from '../services/socialApi.js';

const playlists = getVideoPlaylists();
---

<Layout title="Vídeos | Banda Bruna - Videoclips Oficiales y Presentaciones en Vivo" description="Disfruta de la videoteca de Banda Bruna: videoclips oficiales, actuaciones en vivo, backstage y teasers de lanzamientos.">
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">AUDIOVISUAL</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">GALERÍA DE VIDEOS</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- Section loops for playlists categories -->
    <div class="flex flex-col gap-16">
      
      <!-- Category 1: Official videoclips -->
      <div>
        <h2 class="font-title font-bold text-2xl mb-6 text-white border-b border-white/5 pb-2 uppercase tracking-wide">
          Videoclips Oficiales
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {playlists.videoclips.map(video => (
            <a href={video.url} target="_blank" rel="noopener" class="bg-slate-900 border border-white/5 hover:border-gold-bruna rounded-lg p-4 group block transition-all hover:translate-y-[-3px]">
              <div class="aspect-video bg-black rounded overflow-hidden mb-3 relative flex items-center justify-center border border-white/5">
                <!-- Icon to represent video -->
                <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center text-white group-hover:scale-110 transition-transform">
                  <span class="text-xs pl-0.5">▶</span>
                </div>
                <span class="absolute bottom-2 right-2 bg-black/80 text-white text-[10px] font-semibold px-1.5 py-0.5 rounded font-mono">
                  {video.duration}
                </span>
              </div>
              <h3 class="font-semibold text-white group-hover:text-gold-bruna transition-colors text-sm">{video.title}</h3>
              <span class="text-[11px] text-slate-500 font-semibold block mt-1 uppercase tracking-wide">{video.category}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Category 2: Live performances -->
      <div>
        <h2 class="font-title font-bold text-2xl mb-6 text-white border-b border-white/5 pb-2 uppercase tracking-wide">
          Presentaciones En Vivo
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {playlists.envivo.map(video => (
            <a href={video.url} target="_blank" rel="noopener" class="bg-slate-900 border border-white/5 hover:border-gold-bruna rounded-lg p-4 group block transition-all hover:translate-y-[-3px]">
              <div class="aspect-video bg-black rounded overflow-hidden mb-3 relative flex items-center justify-center border border-white/5">
                <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center text-white group-hover:scale-110 transition-transform">
                  <span class="text-xs pl-0.5">▶</span>
                </div>
                <span class="absolute bottom-2 right-2 bg-black/80 text-white text-[10px] font-semibold px-1.5 py-0.5 rounded font-mono">
                  {video.duration}
                </span>
              </div>
              <h3 class="font-semibold text-white group-hover:text-gold-bruna transition-colors text-base">{video.title}</h3>
              <span class="text-[11px] text-slate-500 font-semibold block mt-1 uppercase tracking-wide">{video.category}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Category 3: Backstage & Promo -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h2 class="font-title font-bold text-xl mb-6 text-white border-b border-white/5 pb-2 uppercase tracking-wide">
            Backstage / Tras Bambalinas
          </h2>
          <div class="flex flex-col gap-4">
            {playlists.backstage.map(video => (
              <a href={video.url} target="_blank" rel="noopener" class="bg-slate-900 border border-white/5 hover:border-gold-bruna rounded-lg p-3 group flex gap-4 items-center transition-colors">
                <div class="w-20 aspect-video bg-black rounded overflow-hidden relative flex-shrink-0 flex items-center justify-center border border-white/5">
                  <span class="text-xs text-red-600">▶</span>
                </div>
                <div>
                  <h3 class="font-semibold text-white text-sm group-hover:text-gold-bruna transition-colors line-clamp-1">{video.title}</h3>
                  <span class="text-[10px] text-slate-500 mt-1 block">{video.duration} mins</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div>
          <h2 class="font-title font-bold text-xl mb-6 text-white border-b border-white/5 pb-2 uppercase tracking-wide">
            Promocionales & Teasers
          </h2>
          <div class="flex flex-col gap-4">
            {playlists.promocionales.map(video => (
              <a href={video.url} target="_blank" rel="noopener" class="bg-slate-900 border border-white/5 hover:border-gold-bruna rounded-lg p-3 group flex gap-4 items-center transition-colors">
                <div class="w-20 aspect-video bg-black rounded overflow-hidden relative flex-shrink-0 flex items-center justify-center border border-white/5">
                  <span class="text-xs text-red-600">▶</span>
                </div>
                <div>
                  <h3 class="font-semibold text-white text-sm group-hover:text-gold-bruna transition-colors line-clamp-1">{video.title}</h3>
                  <span class="text-[10px] text-slate-500 mt-1 block">{video.duration} mins</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

    </div>

  </section>
</Layout>
