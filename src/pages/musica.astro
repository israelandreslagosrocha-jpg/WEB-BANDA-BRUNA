---
import Layout from '../layouts/Layout.astro';
import { getSpotifyAlbum } from '../services/socialApi.js';

const spotifyData = getSpotifyAlbum();

// Lanzamientos oficiales con sus portadas cuadradas originales
const discographyReleases = [
  {
    title: "Ahogado en un Bar",
    year: "2026",
    type: "Single & Videoclip",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1783052331/compressed_BANDA_BRUNA_-_AHOGADO_EN_UN_BAR_mgwlvi.webp",
    link: "/ahogado-en-un-bar",
    spotifyUrl: "https://open.spotify.com/intl-es/album/44B8oavHkAoN0QreYYnGsi"
  },
  {
    title: "Te Juro",
    year: "2025",
    type: "Single",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1784425904/compressed_BB_Te_Juro_vlzmnd.webp",
    link: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D",
    spotifyUrl: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D"
  },
  {
    title: "Luna Amiga",
    year: "2025",
    type: "Single & Videoclip",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1784425903/compressed_BB_Luna_Amiga_gwcdtz.webp",
    link: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D",
    spotifyUrl: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D"
  },
  {
    title: "No sufriré por nadie",
    year: "2025",
    type: "Single",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1784425901/compressed_BB_no_sufrire_por_nadie_lz0foh.webp",
    link: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D",
    spotifyUrl: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D"
  },
  {
    title: "Para no verte más",
    year: "2025",
    type: "Single",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1784425901/compressed_BB_para_no_verte_mas_jypafa.webp",
    link: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D",
    spotifyUrl: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D"
  },
  {
    title: "La boda del chupacabras",
    year: "2025",
    type: "Single",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1784425900/compressed_BB_-_La_boda_del_chupacabras_pubr58.webp",
    link: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D",
    spotifyUrl: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D"
  },
  {
    title: "Agonía",
    year: "2025",
    type: "Single & Sesión",
    cover: "https://res.cloudinary.com/dhgifjpkh/image/upload/v1784425900/compressed_BB_-_Agonia_dib6tk.webp",
    link: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D",
    spotifyUrl: "https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D"
  }
];
---

<Layout title="Música | Banda Bruna - Discografía y Plataformas de Streaming" description="Escucha a Banda Bruna. Catálogo de canciones, reproductor de Spotify oficial, y enlaces a YouTube Music, Apple Music y Deezer.">
  <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">DISCOGRAFÍA</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold font-title uppercase">NUESTRA MÚSICA</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <!-- 1. Reproductor de Spotify (Izquierda) + Temas Más Escuchados y Plataformas (Derecha) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Spotify Embed (Left) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <h2 class="font-title font-bold text-2xl mb-2 text-white uppercase">Perfil de Artista en Spotify</h2>
        <div class="bg-slate-900 border border-white/5 rounded-xl p-4 shadow-xl">
          <iframe 
            src={spotifyData.spotifyEmbedUrl} 
            width="100%" 
            height="380" 
            allowfullscreen="" 
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
            loading="lazy"
            style="border-radius: 8px; border: 0;"
          ></iframe>
        </div>
      </div>

      <!-- Top Tracks & Platforms (Right) -->
      <div class="lg:col-span-5 flex flex-col gap-8">
        
        <div>
          <h2 class="font-title font-bold text-2xl mb-4 text-white uppercase">Temas Más Escuchados</h2>
          <ol class="flex flex-col gap-3 list-none p-0 m-0">
            {spotifyData.topTracks.map((track, idx) => (
              <li class="bg-slate-900 border border-white/5 hover:border-gold-bruna p-4 rounded-lg flex items-center justify-between transition-colors">
                <div class="flex items-center gap-3">
                  <span class="text-gold-bruna font-title font-bold text-sm">0{idx + 1}</span>
                  <div>
                    <span class="font-semibold text-white block text-sm">{track.title}</span>
                  </div>
                </div>
                <span class="text-xs text-slate-500 font-semibold">{track.duration}</span>
              </li>
            ))}
          </ol>
        </div>

        <div>
          <h2 class="font-title font-bold text-lg mb-4 text-white uppercase">Plataformas Digitales</h2>
          <div class="grid grid-cols-2 gap-4">
            <a 
              href="https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-green-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-green-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-green-500 fill-current" viewBox="0 0 24 24">
                <path d="M12.012 0C5.378 0 0 5.378 0 12.012c0 6.634 5.378 12.01 12.012 12.01 6.634 0 12.012-5.376 12.012-12.01C24.024 5.378 18.646 0 12.012 0zm5.503 17.324c-.216.353-.677.464-1.03.248-2.88-1.76-6.502-2.158-10.77-1.182-.405.093-.814-.162-.907-.567-.093-.404.162-.814.567-.907 4.675-1.07 8.67-.613 11.892 1.357.353.214.464.676.248 1.03zm1.47-3.265c-.273.444-.855.59-1.3.315-3.3-2.025-8.326-2.613-12.216-1.433-.497.15-1.025-.13-1.176-.628-.15-.497.13-1.026.628-1.176 4.444-1.348 9.97-.687 13.75 1.632.443.272.59.854.314 1.29zm.126-3.414C15.54 8.528 9.645 8.332 6.22 9.372c-.55.167-1.127-.145-1.293-.695-.167-.55.145-1.127.695-1.293 3.924-1.19 10.435-.972 14.55 1.47.495.293.657.93.364 1.425-.293.495-.93.657-1.425.364z"/>
              </svg>
              <span>Spotify</span>
            </a>
            <a 
              href="https://youtube.com/@bandabrunaoficial" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-red-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-red-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-red-500 fill-current" viewBox="0 0 24 24">
                <path d="M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 17.52c-3.048 0-5.52-2.472-5.52-5.52S8.952 6.48 12 6.48s5.52 2.472 5.52 5.52-2.472 5.52-5.52 5.52zm0-9.6c-2.256 0-4.08 1.824-4.08 4.08s1.824 4.08 4.08 4.08 4.08-1.824 4.08-4.08-1.824-4.08-4.08-4.08zm-1.44 5.952V9.768l3.6 2.064-3.6 2.064z"/>
              </svg>
              <span>YouTube Music</span>
            </a>
            <a 
              href="https://music.apple.com/cl/artist/banda-bruna/1828449193" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-pink-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-pink-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-pink-500 fill-current" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.334 11.23a3.52 3.52 0 0 1-.35 1.57c-.244.477-.557.9-.94 1.27-.37.36-.78.61-.95.61-.25 0-.48-.12-.87-.39-.42-.29-.86-.44-1.31-.44-.45 0-.87.14-1.28.43-.37.26-.6.38-.85.38-.17 0-.58-.25-.95-.61a5.05 5.05 0 0 1-.94-1.27c-.29-.55-.44-1.16-.44-1.8 0-1.18.42-2.13 1.25-2.85.64-.56 1.4-.87 2.27-.87.49 0 .97.15 1.45.44.3.18.51.27.65.27.13 0 .34-.09.64-.27.52-.32 1.05-.48 1.57-.48.91 0 1.69.34 2.33 1.02.34.36.6.79.78 1.27a4.19 4.19 0 0 0-2.06 3.65zm-.5-5.91c.01.27-.05.54-.18.8a2.53 2.53 0 0 1-.9 1.05c-.39.26-.78.39-1.18.39-.06 0-.15 0-.25-.01a2.43 2.43 0 0 1 .15-1.07c.14-.38.38-.72.7-1.01.32-.29.7-.49 1.15-.6.18-.04.35-.06.51-.06.01.17 0 .34 0 .51z"/>
              </svg>
              <span>Apple Music</span>
            </a>
            <a 
              href="https://www.deezer.com/mx/artist/337478561" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-blue-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-blue-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-blue-500 fill-current" viewBox="0 0 24 24">
                <path d="M1.333 16h4V13.333h-4V16zm5.334 0h4V10.667h-4V16zm5.333 0h4V8H12v8zm5.333 0h4V5.333h-4V16zm5.334 0h4V2.667h-4V16zM1.333 21.333h4V18.667h-4v2.666zm5.334 0h4V18.667h-4v2.666zm5.333 0h4V18.667h-4v2.666zm5.333 0h4V18.667h-4v2.666zm5.334 0h4V18.667h-4v2.666z"/>
              </svg>
              <span>Deezer</span>
            </a>
          </div>
        </div>

      </div>

    </div>

    <!-- 2. Slide Dinámico de Portadas de Lanzamientos (Ubicado justo debajo del reproductor y los temas más escuchados) -->
    <div class="mt-20 border-t border-white/5 pt-12">
      <div class="flex items-center justify-between mb-8 px-1">
        <div>
          <span class="text-gold-bruna text-xs tracking-widest font-bold uppercase block mb-1">CATÁLOGO & DISCOGRAFÍA</span>
          <h2 class="font-title font-bold text-2xl text-white uppercase tracking-wide flex items-center gap-2">
            <span class="w-1.5 h-6 bg-gold-bruna block rounded-sm"></span>
            Todos los Lanzamientos
          </h2>
        </div>

        <!-- Controles de navegación manual del slider -->
        <div class="flex gap-2">
          <button 
            id="releases-prev"
            class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center hover:bg-gold-bruna hover:text-black hover:border-gold-bruna transition-all active:scale-90 cursor-pointer text-slate-400 hover:text-black bg-slate-900/60"
            aria-label="Lanzamientos anteriores"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button 
            id="releases-next"
            class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center hover:bg-gold-bruna hover:text-black hover:border-gold-bruna transition-all active:scale-90 cursor-pointer text-slate-400 hover:text-black bg-slate-900/60"
            aria-label="Lanzamientos siguientes"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>

      <!-- Carrusel deslizable horizontal de Fotos Cuadradas -->
      <div 
        id="releases-slider"
        class="flex gap-6 overflow-x-auto scrollbar-none snap-x snap-mandatory pb-6 px-1 scroll-smooth"
      >
        {discographyReleases.map((release) => (
          <div 
            class="flex-shrink-0 w-[210px] sm:w-[240px] md:w-[260px] bg-slate-900/80 border border-white/5 rounded-xl overflow-hidden group snap-start transition-all hover:border-gold-bruna/40 hover:shadow-xl hover:shadow-gold-bruna/5 flex flex-col justify-between"
          >
            <!-- Foto Cuadrada (aspect-square) -->
            <a 
              href={release.link} 
              target={release.link.startsWith('http') ? '_blank' : '_self'} 
              rel="noopener" 
              class="relative w-full aspect-square overflow-hidden bg-black block cursor-pointer"
            >
              <img 
                src={release.cover} 
                alt={`Portada de ${release.title}`} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                loading="lazy"
              />
              <!-- Badge del Año en la esquina superior derecha -->
              <div class="absolute top-3 right-3 bg-black/80 backdrop-blur-md border border-white/10 text-gold-bruna text-[11px] font-bold font-mono px-2.5 py-0.5 rounded-md shadow-md">
                {release.year}
              </div>
              <!-- Overlay con botón play al pasar el mouse -->
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-gold-bruna text-black flex items-center justify-center font-bold shadow-lg transform group-hover:scale-110 transition-transform pl-0.5">
                  ▶
                </div>
              </div>
            </a>

            <!-- Pie de foto: Título y Año -->
            <div class="p-4 flex flex-col justify-between flex-grow">
              <div>
                <span class="text-[10px] font-bold text-gold-bruna tracking-widest uppercase block mb-1 font-title">
                  {release.type}
                </span>
                <h3 class="font-bold text-white text-sm sm:text-base group-hover:text-gold-bruna transition-colors line-clamp-1 leading-snug">
                  {release.title}
                </h3>
              </div>
              <div class="mt-3 pt-3 border-t border-white/5 flex items-center justify-between">
                <span class="text-xs text-slate-400 font-mono font-semibold">{release.year}</span>
                <a 
                  href={release.spotifyUrl} 
                  target="_blank" 
                  rel="noopener" 
                  class="text-[10px] text-green-400 hover:text-green-300 font-bold uppercase tracking-wider flex items-center gap-1"
                >
                  <span>Escuchar</span>
                  <span>🎧</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>
</Layout>

<style is:global>
  /* Ocultar barra de scroll para navegadores */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  function initMusicSlider() {
    const prevBtn = document.getElementById('releases-prev');
    const nextBtn = document.getElementById('releases-next');
    const slider = document.getElementById('releases-slider');

    if (slider && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        const scrollAmount = slider.clientWidth * 0.75;
        slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        const scrollAmount = slider.clientWidth * 0.75;
        slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initMusicSlider);
  document.addEventListener('astro:after-swap', initMusicSlider);
</script>
