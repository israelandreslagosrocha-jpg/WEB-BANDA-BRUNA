---
import Layout from '../layouts/Layout.astro';
import { getSpotifyAlbum } from '../services/socialApi.js';

const spotifyData = getSpotifyAlbum();
---

<Layout title="Música | Banda Bruna - Discografía y Plataformas de Streaming" description="Escucha a Banda Bruna. Catálogo de canciones, reproductor de Spotify oficial, y enlaces a YouTube Music, Apple Music y Deezer.">
  <section class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">DISCOGRAFÍA</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">NUESTRA MÚSICA</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Spotify Embed (Left) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <h2 class="font-title font-bold text-2xl mb-2 text-white uppercase">Perfil de Artista en Spotify</h2>
        <div class="bg-slate-900 border border-white/5 rounded-xl p-4 shadow-xl">
          <iframe 
            src={spotifyData.spotifyEmbedUrl} 
            width="100%" 
            height="380" 
            allowfullscreen="" 
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
            loading="lazy"
            style="border-radius: 8px; border: 0;"
          ></iframe>
        </div>
      </div>

      <!-- Top Tracks & Platforms (Right) -->
      <div class="lg:col-span-5 flex flex-col gap-8">
        
        <div>
          <h2 class="font-title font-bold text-2xl mb-4 text-white uppercase">Temas Más Escuchados</h2>
          <ol class="flex flex-col gap-3 list-none p-0 m-0">
            {spotifyData.topTracks.map((track, idx) => (
              <li class="bg-slate-900 border border-white/5 hover:border-gold-bruna p-4 rounded-lg flex items-center justify-between transition-colors">
                <div class="flex items-center gap-3">
                  <span class="text-gold-bruna font-title font-bold text-sm">0{idx + 1}</span>
                  <div>
                    <span class="font-semibold text-white block text-sm">{track.title}</span>
                    <span class="text-[10px] text-slate-500 font-medium">{track.playCount} reproducciones</span>
                  </div>
                </div>
                <span class="text-xs text-slate-500 font-semibold">{track.duration}</span>
              </li>
            ))}
          </ol>
        </div>

        <div>
          <h2 class="font-title font-bold text-lg mb-4 text-white uppercase">Plataformas Digitales</h2>
          <div class="grid grid-cols-2 gap-4">
            <a 
              href="https://open.spotify.com/intl-es/artist/3QpgBBp8CypsMEM5rgWo7D" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-green-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-green-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-green-500 fill-current" viewBox="0 0 24 24">
                <path d="M12.012 0C5.378 0 0 5.378 0 12.012c0 6.634 5.378 12.01 12.012 12.01 6.634 0 12.012-5.376 12.012-12.01C24.024 5.378 18.646 0 12.012 0zm5.503 17.324c-.216.353-.677.464-1.03.248-2.88-1.76-6.502-2.158-10.77-1.182-.405.093-.814-.162-.907-.567-.093-.404.162-.814.567-.907 4.675-1.07 8.67-.613 11.892 1.357.353.214.464.676.248 1.03zm1.47-3.265c-.273.444-.855.59-1.3.315-3.3-2.025-8.326-2.613-12.216-1.433-.497.15-1.025-.13-1.176-.628-.15-.497.13-1.026.628-1.176 4.444-1.348 9.97-.687 13.75 1.632.443.272.59.854.314 1.29zm.126-3.414C15.54 8.528 9.645 8.332 6.22 9.372c-.55.167-1.127-.145-1.293-.695-.167-.55.145-1.127.695-1.293 3.924-1.19 10.435-.972 14.55 1.47.495.293.657.93.364 1.425-.293.495-.93.657-1.425.364z"/>
              </svg>
              <span>Spotify</span>
            </a>
            <a 
              href="https://youtube.com/@bandabrunaoficial" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-red-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-red-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-red-500 fill-current" viewBox="0 0 24 24">
                <path d="M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 17.52c-3.048 0-5.52-2.472-5.52-5.52S8.952 6.48 12 6.48s5.52 2.472 5.52 5.52-2.472 5.52-5.52 5.52zm0-9.6c-2.256 0-4.08 1.824-4.08 4.08s1.824 4.08 4.08 4.08 4.08-1.824 4.08-4.08-1.824-4.08-4.08-4.08zm-1.44 5.952V9.768l3.6 2.064-3.6 2.064z"/>
              </svg>
              <span>YouTube Music</span>
            </a>
            <a 
              href="https://music.apple.com/cl/artist/banda-bruna/1828449193" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-pink-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-pink-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-pink-500 fill-current" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.334 11.23a3.52 3.52 0 0 1-.35 1.57c-.244.477-.557.9-.94 1.27-.37.36-.78.61-.95.61-.25 0-.48-.12-.87-.39-.42-.29-.86-.44-1.31-.44-.45 0-.87.14-1.28.43-.37.26-.6.38-.85.38-.17 0-.58-.25-.95-.61a5.05 5.05 0 0 1-.94-1.27c-.29-.55-.44-1.16-.44-1.8 0-1.18.42-2.13 1.25-2.85.64-.56 1.4-.87 2.27-.87.49 0 .97.15 1.45.44.3.18.51.27.65.27.13 0 .34-.09.64-.27.52-.32 1.05-.48 1.57-.48.91 0 1.69.34 2.33 1.02.34.36.6.79.78 1.27a4.19 4.19 0 0 0-2.06 3.65zm-.5-5.91c.01.27-.05.54-.18.8a2.53 2.53 0 0 1-.9 1.05c-.39.26-.78.39-1.18.39-.06 0-.15 0-.25-.01a2.43 2.43 0 0 1 .15-1.07c.14-.38.38-.72.7-1.01.32-.29.7-.49 1.15-.6.18-.04.35-.06.51-.06.01.17 0 .34 0 .51z"/>
              </svg>
              <span>Apple Music</span>
            </a>
            <a 
              href="https://www.deezer.com/mx/artist/337478561" 
              target="_blank" 
              rel="noopener" 
              class="bg-slate-900 border border-white/5 hover:border-blue-500 p-4 rounded-xl flex items-center justify-center gap-3 text-xs font-bold text-white transition-all hover:translate-y-[-2px] shadow-lg hover:shadow-blue-500/10 cursor-pointer uppercase"
            >
              <svg class="w-5 h-5 text-blue-500 fill-current" viewBox="0 0 24 24">
                <path d="M1.333 16h4V13.333h-4V16zm5.334 0h4V10.667h-4V16zm5.333 0h4V8H12v8zm5.333 0h4V5.333h-4V16zm5.334 0h4V2.667h-4V16zM1.333 21.333h4V18.667h-4v2.666zm5.334 0h4V18.667h-4v2.666zm5.333 0h4V18.667h-4v2.666zm5.333 0h4V18.667h-4v2.666zm5.334 0h4V18.667h-4v2.666z"/>
              </svg>
              <span>Deezer</span>
            </a>
          </div>
        </div>

      </div>

    </div>

  </section>
</Layout>
