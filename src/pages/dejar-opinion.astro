---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dejar Opinión | Banda Bruna" description="Comparte tu experiencia tras contratarnos. Tu opinión nos ayuda a seguir entregando un show de primer nivel en todo Chile.">
  <section class="max-w-2xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-12">
      <span class="text-gold-bruna text-xs tracking-[0.2em] font-extrabold uppercase block mb-1">EVALUACIÓN DE SHOW</span>
      <h1 class="text-3xl md:text-4xl font-extrabold font-title uppercase">DEJA TU OPINIÓN</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
      <p class="text-xs text-slate-400 font-light mt-4 max-w-md mx-auto">
        Tu reseña nos ayuda a seguir mejorando y sirve como respaldo para futuras contrataciones municipales y privadas en todo Chile.
      </p>
    </div>

    <!-- Form Container -->
    <div id="opinion-form-container" class="bg-slate-900 border border-white/5 rounded-2xl p-6 md:p-8 shadow-xl text-left relative overflow-hidden">
      <!-- Chile stripes design at the top -->
      <div class="absolute top-0 left-0 w-full h-[3px] flex">
        <div class="h-full w-1/3 bg-blue-600"></div>
        <div class="h-full w-1/3 bg-white"></div>
        <div class="h-full w-1/3 bg-red-600"></div>
      </div>

      <form id="opinion-form" class="flex flex-col gap-6" novalidate>
        
        <!-- Nombre -->
        <div class="flex flex-col gap-2">
          <label for="op-name" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Nombre Completo *</label>
          <input 
            type="text" 
            id="op-name" 
            name="name" 
            placeholder="ej: Jaime Valenzuela" 
            required
            class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
          />
          <span class="text-[10px] text-red-400 hidden" id="op-name-err">Por favor ingresa tu nombre.</span>
        </div>

        <!-- Cargo y Empresa -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="op-role" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Cargo / Función (Opcional)</label>
            <input 
              type="text" 
              id="op-role" 
              name="role" 
              placeholder="ej: Encargado de Cultura" 
              class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="op-org" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Organización / Comuna / Empresa (Opcional)</label>
            <input 
              type="text" 
              id="op-org" 
              name="org" 
              placeholder="ej: Ilustre Municipalidad / Empresa" 
              class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
            />
          </div>
        </div>

        <!-- Calificación (Estrellas) -->
        <div class="flex flex-col gap-2">
          <label class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Calificación de la Experiencia *</label>
          <div class="flex gap-2.5 items-center mt-1 select-none">
            <div id="star-rating" class="flex gap-1">
              <button type="button" data-value="1" class="star-btn text-2xl text-gold-bruna cursor-pointer transition-transform hover:scale-110">★</button>
              <button type="button" data-value="2" class="star-btn text-2xl text-gold-bruna cursor-pointer transition-transform hover:scale-110">★</button>
              <button type="button" data-value="3" class="star-btn text-2xl text-gold-bruna cursor-pointer transition-transform hover:scale-110">★</button>
              <button type="button" data-value="4" class="star-btn text-2xl text-gold-bruna cursor-pointer transition-transform hover:scale-110">★</button>
              <button type="button" data-value="5" class="star-btn text-2xl text-gold-bruna cursor-pointer transition-transform hover:scale-110">★</button>
            </div>
            <span id="rating-description" class="text-[10px] text-gold-bruna font-bold uppercase tracking-widest ml-2">Excelente (5/5)</span>
            <input type="hidden" id="op-rating" name="rating" value="5" />
          </div>
        </div>

        <!-- Comentario -->
        <div class="flex flex-col gap-2">
          <label for="op-message" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Tu Opinión / Comentario *</label>
          <textarea 
            id="op-message" 
            name="message" 
            rows="5" 
            placeholder="Escribe aquí tu experiencia con la banda, puntualidad, show técnico, respuesta del público, etc." 
            required
            class="bg-slate-950 border border-white/5 rounded-md p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors resize-none"
          ></textarea>
          <span class="text-[10px] text-red-400 hidden" id="op-message-err">Por favor escribe un comentario (mínimo 10 caracteres).</span>
        </div>

        <!-- Status Feedback -->
        <span id="form-feedback" class="hidden"></span>

        <!-- Submit Button -->
        <button 
          type="submit" 
          id="btn-submit-opinion"
          class="bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black py-3.5 rounded font-extrabold text-xs tracking-widest uppercase transition-all shadow-lg hover:shadow-gold-bruna/10 active:scale-[0.98] cursor-pointer"
        >
          ENVIAR OPINIÓN PARA REVISIÓN
        </button>

      </form>
    </div>

    <!-- Success Panel (Hidden by default) -->
    <div id="success-opinion-panel" class="hidden bg-slate-900 border border-white/5 rounded-2xl p-8 md:p-10 shadow-xl text-center relative overflow-hidden">
      <!-- Chile stripes design at the top -->
      <div class="absolute top-0 left-0 w-full h-[3px] flex">
        <div class="h-full w-1/3 bg-blue-600"></div>
        <div class="h-full w-1/3 bg-white"></div>
        <div class="h-full w-1/3 bg-red-600"></div>
      </div>
      
      <div class="w-16 h-16 rounded-full bg-green-950/30 border border-green-500/20 text-green-400 flex items-center justify-center text-3xl font-extrabold mx-auto mb-6">
        ✓
      </div>
      <h2 class="font-title font-extrabold text-2xl text-white uppercase tracking-wider mb-3">
        ¡MUCHAS GRACIAS POR TU TIEMPO!
      </h2>
      <p class="text-xs text-slate-300 font-light leading-relaxed max-w-md mx-auto mb-8">
        Tu reseña se ha registrado correctamente. Una vez que el administrador la revise y apruebe, aparecerá publicada en nuestra web oficial.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-slate-950 border border-white/10 hover:border-gold-bruna hover:text-gold-bruna text-white font-title font-bold py-2.5 px-6 rounded text-xs uppercase tracking-wider transition-colors cursor-pointer">
          Ir al Inicio
        </a>
        <a href="/contrataciones" class="bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black font-title font-bold py-2.5 px-6 rounded text-xs uppercase tracking-wider cursor-pointer">
          Volver a Cotizar
        </a>
      </div>
    </div>

  </section>

  <script>
    import { supabase } from '../services/supabaseClient.js';

    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('opinion-form') as HTMLFormElement | null;
      const stars = document.querySelectorAll('#star-rating .star-btn');
      const ratingDesc = document.getElementById('rating-description');
      const ratingInput = document.getElementById('op-rating') as HTMLInputElement | null;

      if (!form) return;

      // 1. GESTIÓN INTERACTIVA DE ESTRELLAS DE CALIFICACIÓN
      const ratingTexts = {
        1: 'Deficiente (1/5)',
        2: 'Regular (2/5)',
        3: 'Bueno (3/5)',
        4: 'Muy Bueno (4/5)',
        5: 'Excelente (5/5)'
      } as Record<number, string>;

      function updateStars(value: number) {
        if (ratingInput) ratingInput.value = value.toString();
        if (ratingDesc) ratingDesc.textContent = ratingTexts[value] || `${value}/5`;

        stars.forEach((star, idx) => {
          const s = star as HTMLButtonElement;
          const starValue = idx + 1;
          if (starValue <= value) {
            s.classList.add('text-gold-bruna');
            s.classList.remove('text-slate-650');
            s.style.opacity = '1';
          } else {
            s.classList.remove('text-gold-bruna');
            s.classList.add('text-slate-650');
            s.style.opacity = '0.35';
          }
        });
      }

      stars.forEach(star => {
        star.addEventListener('click', (e) => {
          const btn = star as HTMLButtonElement;
          const val = parseInt(btn.dataset.value || '5', 10);
          updateStars(val);
        });
      });

      // Inicializar con 5 estrellas
      updateStars(5);

      // 2. ENVÍO DE FORMULARIO A SUPABASE
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const nameInput = document.getElementById('op-name') as HTMLInputElement;
        const roleInput = document.getElementById('op-role') as HTMLInputElement;
        const orgInput = document.getElementById('op-org') as HTMLInputElement;
        const msgInput = document.getElementById('op-message') as HTMLTextAreaElement;
        
        const nameErr = document.getElementById('op-name-err');
        const msgErr = document.getElementById('op-message-err');
        const feedback = document.getElementById('form-feedback');
        const btnSubmit = document.getElementById('btn-submit-opinion') as HTMLButtonElement;

        // Reset errors
        nameInput.classList.remove('border-red-500');
        msgInput.classList.remove('border-red-500');
        if (nameErr) nameErr.classList.add('hidden');
        if (msgErr) msgErr.classList.add('hidden');
        if (feedback) {
          feedback.className = 'hidden';
          feedback.textContent = '';
        }

        let hasError = false;

        // Validation
        if (!nameInput.value.trim()) {
          nameInput.classList.add('border-red-500');
          if (nameErr) nameErr.classList.remove('hidden');
          hasError = true;
        }

        if (!msgInput.value.trim() || msgInput.value.trim().length < 10) {
          msgInput.classList.add('border-red-500');
          if (msgErr) msgErr.classList.remove('hidden');
          hasError = true;
        }

        if (hasError) return;

        // Disable button & loading feedback
        const origText = btnSubmit.textContent;
        btnSubmit.textContent = '⏱ ENVIANDO COMENTARIO...';
        btnSubmit.disabled = true;

        const payload = {
          nombre_cliente: nameInput.value.trim(),
          cargo_cliente: roleInput.value.trim() || null,
          organizacion_cliente: orgInput.value.trim() || null,
          contenido: msgInput.value.trim(),
          calificacion: parseInt(ratingInput?.value || '5', 10),
          aprobado: false // Siempre inician como falsos hasta que se aprueben
        };

        try {
          const { error } = await supabase
            .from('testimonios')
            .insert([payload]);

          if (error) throw error;

          // Mostrar panel de éxito
          const formContainer = document.getElementById('opinion-form-container');
          const successContainer = document.getElementById('success-opinion-panel');
          if (formContainer) formContainer.classList.add('hidden');
          if (successContainer) successContainer.classList.remove('hidden');
          
          form.reset();
          updateStars(5);

        } catch (err: any) {
          console.error("Error al guardar testimonio:", err);
          btnSubmit.textContent = origText;
          btnSubmit.disabled = false;

          if (feedback) {
            feedback.textContent = 'Hubo un error de conexión con el servidor al registrar tu comentario. Por favor, vuelve a intentarlo.';
            feedback.className = 'text-center text-xs py-3 px-4 rounded border bg-red-950/20 border-red-500/20 text-red-400 block';
          }
        }
      });
    });
  </script>
</Layout>
