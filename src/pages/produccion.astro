---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../services/supabaseClient.js';
import ProfileSelector from '../components/production/ProfileSelector.astro';
import InteractiveStageViewer from '../components/production/InteractiveStageViewer.astro';
import InputListTable from '../components/production/InputListTable.astro';
import BacklineGrid from '../components/production/BacklineGrid.astro';

// Cargar la lista inicial de Layouts (Versiones) desde Supabase para renderizar el select
const { data: dbLayouts } = await supabase
  .from('stage_layouts')
  .select('*')
  .eq('activo', true)
  .order('nombre', { ascending: true });

const layouts = dbLayouts || [];
const defaultLayoutId = layouts.length > 0 ? layouts[0].id : '';
---

<Layout 
  title="Portal de Producción Técnica | Banda Bruna" 
  description="Plataforma técnica profesional de Banda Bruna para productores, iluminadores, sonidistas y stage managers. Planta de luces interactiva, input list, backline y descargas oficiales."
>
  <!-- Selector de Perfil Inicial (Overlay) -->
  <ProfileSelector />

  <div class="min-h-screen bg-[#020617] text-white">
    <!-- Hero Técnico -->
    <header class="relative overflow-hidden py-24 border-b border-white/5 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-950/20 via-[#020617] to-[#020617]">
      <div class="absolute inset-0 bg-[radial-gradient(#ffffff02_1px,transparent_1px)] [background-size:20px_20px] pointer-events-none"></div>
      
      <!-- Fondo decorativo con fotos oficiales del montaje técnico provistas por el usuario -->
      <div class="absolute inset-0 z-0 opacity-10 flex gap-4 overflow-hidden pointer-events-none select-none">
        <img src="https://res.cloudinary.com/dhgifjpkh/image/upload/v1782874578/WhatsApp_Image_2026-06-30_at_5.17.55_PM_wz8whh.jpg" alt="Montaje Luces 1" class="w-1/3 object-cover blur-sm scale-105" />
        <img src="https://res.cloudinary.com/dhgifjpkh/image/upload/v1782874578/WhatsApp_Image_2026-06-30_at_5.17.54_PM_ifxiik.jpg" alt="Montaje Luces 2" class="w-1/3 object-cover blur-sm scale-105" />
        <img src="https://res.cloudinary.com/dhgifjpkh/image/upload/v1782874578/WhatsApp_Image_2026-06-30_at_5.17.54_PM_1_w5o086.jpg" alt="Montaje Luces 3" class="w-1/3 object-cover blur-sm scale-105" />
      </div>

      <div class="max-w-[1200px] mx-auto px-6 relative z-10 text-center flex flex-col items-center">
        <span class="text-gold-bruna text-[10px] tracking-widest font-extrabold uppercase bg-gold-bruna/5 border border-gold-bruna/10 px-4 py-1.5 rounded-full mb-4 animate-pulse">
          Ficha Técnica & Rider Oficial 2026
        </span>
        <h1 class="text-4xl md:text-6xl font-extrabold font-title uppercase tracking-tight max-w-3xl">
          PRODUCCIÓN TÉCNICA
        </h1>
        <p class="text-xs md:text-sm text-slate-400 mt-4 max-w-xl leading-relaxed">
          Toda la información del espectáculo organizada para facilitar el trabajo de productores, iluminadores, sonidistas y equipos de montaje en vivo.
        </p>

        <!-- CTA Directo para Omitir / Descargas -->
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <a href="#sec-descargas" class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-widest transition-transform hover:scale-[1.03] text-center font-title shadow-lg shadow-gold-bruna/10">
            Descargar Rider PDF
          </a>
          <a href="#sec-iluminacion" class="bg-slate-900 border border-white/10 hover:border-gold-bruna/30 text-white px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-widest transition-transform hover:scale-[1.03] text-center font-title">
            Ver Iluminación
          </a>
          <a href="#sec-audio" class="bg-slate-900 border border-white/10 hover:border-gold-bruna/30 text-white px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-widest transition-transform hover:scale-[1.03] text-center font-title">
            Ver Audio Patch
          </a>
        </div>
      </div>
    </header>

    <!-- Barra de Control de Layouts (Versiones) -->
    <div class="sticky top-0 z-40 bg-slate-950/80 border-b border-white/5 backdrop-blur-md py-4">
      <div class="max-w-[1200px] mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-ping"></div>
          <span class="text-xs font-bold text-slate-350 uppercase tracking-widest">Montaje Técnico Activo</span>
        </div>
        <div class="flex items-center gap-3">
          <label for="layout-select" class="text-[9px] font-bold text-slate-400 uppercase tracking-wider font-mono">Seleccionar Versión del Show:</label>
          <select id="layout-select" class="bg-slate-900 border border-white/10 rounded-lg px-4 py-2 text-xs text-gold-bruna font-bold outline-none cursor-pointer focus:border-gold-bruna min-w-[200px]">
            {layouts.map(l => (
              <option value={l.id}>{l.nombre}</option>
            ))}
          </select>
        </div>
      </div>
    </div>

    <!-- Contenedor Principal de la Ficha -->
    <main class="max-w-[1200px] mx-auto px-6 py-12 flex flex-col gap-16">

      <!-- Sección 1: Planta de Luces Interactiva -->
      <section id="sec-iluminacion" data-production-section class="flex flex-col gap-6 scroll-mt-24">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-2 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[9px] font-bold tracking-widest uppercase font-mono block mb-1">ILUMINADORES & DISEÑADORES</span>
            <h2 class="text-2xl font-bold font-title uppercase text-white">Planta de Luces e Infraestructura</h2>
          </div>
          <p class="text-xs text-slate-450 max-w-sm">Visor interactivo con puentes suspendidos, DMX patch, marcas y modelos de fixtures.</p>
        </div>
        
        <!-- Visor Interactivo -->
        <InteractiveStageViewer />
      </section>

      <!-- Sección 2: Audio & Input List -->
      <section id="sec-audio" data-production-section class="flex flex-col gap-6 scroll-mt-24">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-2 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[9px] font-bold tracking-widest uppercase font-mono block mb-1">SONIDISTAS & MONITORES</span>
            <h2 class="text-2xl font-bold font-title uppercase text-white">Input List & Mezcla en Sala</h2>
          </div>
          <p class="text-xs text-slate-450 max-w-sm">Lista de canales de audio ordenados para mezcla en vivo, micrófonos sugeridos y asignaciones.</p>
        </div>

        <InputListTable />
      </section>

      <!-- Sección 3: Backline Técnico -->
      <section id="sec-backline" data-production-section class="flex flex-col gap-6 scroll-mt-24">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-2 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[9px] font-bold tracking-widest uppercase font-mono block mb-1">STAGE MANAGERS & MONTAJE</span>
            <h2 class="text-2xl font-bold font-title uppercase text-white">Backline Técnico Requerido</h2>
          </div>
          <p class="text-xs text-slate-450 max-w-sm">Listado de instrumentos, amplificación de guitarras, bajo y atriles necesarios en escenario.</p>
        </div>

        <BacklineGrid />
      </section>

      <!-- Sección 4: Efectos Especiales -->
      <section id="sec-efectos" data-production-section class="flex flex-col gap-6 scroll-mt-24">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-2 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[9px] font-bold tracking-widest uppercase font-mono block mb-1">EFECTOS VISUALES & PYRO</span>
            <h2 class="text-2xl font-bold font-title uppercase text-white">Efectos Especiales (FX)</h2>
          </div>
          <p class="text-xs text-slate-450 max-w-sm">Máquinas de humo vertical, chispas frías y pirotecnia requeridas para la atmósfera del espectáculo.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="fx-cards-container">
          <!-- Se inyectarán dinámicamente -->
        </div>
      </section>

      <!-- Sección 5: Zona de Descargas -->
      <section id="sec-descargas" data-production-section class="flex flex-col gap-6 scroll-mt-24">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-2 border-b border-white/5 pb-4">
          <div>
            <span class="text-gold-bruna text-[9px] font-bold tracking-widest uppercase font-mono block mb-1">DOCUMENTACIÓN OFICIAL</span>
            <h2 class="text-2xl font-bold font-title uppercase text-white">Descargas de Fichas Técnicas</h2>
          </div>
          <p class="text-xs text-slate-450 max-w-sm">Obtén los archivos PDF y material de soporte en alta resolución para el festival o recinto.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="downloads-grid-container">
          <!-- Dinámico -->
        </div>
      </section>

    </main>

    <!-- Footer Técnico de Producción -->
    <footer class="bg-slate-950 border-t border-white/5 py-12 text-center text-xs text-slate-500 font-mono">
      <div class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
          <span class="text-white font-bold block mb-1">DIRECCIÓN TÉCNICA BANDA BRUNA</span>
          <span>Contacto Técnico: contacto@bandabruna.cl • Temuco, Chile</span>
        </div>
        <div class="text-[9px] uppercase tracking-widest">
          Plataforma de Producción Profesional v2.0
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script>
  import { supabase } from '../services/supabaseClient.js';

  let currentLayoutId = '{defaultLayoutId}';

  document.addEventListener('DOMContentLoaded', async () => {
    const select = document.getElementById('layout-select') as HTMLSelectElement;

    // Animaciones iniciales con GSAP (Scroll reveal y fade in suave)
    if (typeof gsap !== 'undefined') {
      gsap.from('header h1', { opacity: 0, y: 30, duration: 1.2, ease: 'power3.out' });
      gsap.from('header p', { opacity: 0, y: 20, duration: 1.2, delay: 0.3, ease: 'power3.out' });
      gsap.from('header .flex', { opacity: 0, y: 15, duration: 1, delay: 0.5, ease: 'power3.out' });
    }

    if (select) {
      currentLayoutId = select.value;
      
      // Lanzar evento inicial para que el visor interactivo y tabla se actualicen
      dispatchLayoutChanged();

      select.addEventListener('change', (e) => {
        currentLayoutId = (e.target as HTMLSelectElement).value;
        dispatchLayoutChanged();
        loadLayoutSpecifics();
      });
      
      await loadLayoutSpecifics();
    }
  });

  function dispatchLayoutChanged() {
    const event = new CustomEvent('production-layout-changed', {
      detail: { layoutId: currentLayoutId }
    });
    document.dispatchEvent(event);
  }

  // Cargar datos específicos del layout (Descargas, FX, etc.)
  async function loadLayoutSpecifics() {
    await loadEffects();
    await loadDownloads();
  }

  // Cargar Efectos Especiales (FX) del layout
  async function loadEffects() {
    const container = document.getElementById('fx-cards-container');
    if (!container) return;

    container.innerHTML = '<p class="text-xs text-slate-450 uppercase animate-pulse">Cargando efectos...</p>';

    const { data, error } = await supabase
      .from('lighting_effects')
      .select('*')
      .eq('layout_id', currentLayoutId);

    // Agrupar por nombre de efecto para resumirlos en cards
    if (!error && data && data.length > 0) {
      const summary = {};
      data.forEach(item => {
        if (!summary[item.nombre]) {
          summary[item.nombre] = {
            cantidad: 0,
            desc: item.descripcion || 'Máquinas de efectos especiales distribuidas en escenario.'
          };
        }
        summary[item.nombre].cantidad += item.cantidad;
      });

      container.innerHTML = Object.keys(summary).map(name => `
        <div class="bg-slate-950/60 border border-white/5 p-5 rounded-2xl flex flex-col justify-between hover:border-gold-bruna/20 transition-all group">
          <div>
            <div class="flex justify-between items-center mb-4">
              <span class="text-2xl">💨</span>
              <span class="bg-gold-bruna/10 border border-gold-bruna/25 text-gold-bruna text-[9px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider font-mono">
                Req: ${summary[name].cantidad} Unidades
              </span>
            </div>
            <h4 class="font-title font-bold text-sm text-white uppercase mb-2">${name}</h4>
            <p class="text-xs text-slate-400 leading-relaxed">${summary[name].desc}</p>
          </div>
        </div>
      `).join('');
    } else {
      // Fallback estático
      container.innerHTML = `
        <div class="bg-slate-950/60 border border-white/5 p-5 rounded-2xl flex flex-col justify-between hover:border-gold-bruna/20 transition-all group">
          <div>
            <div class="flex justify-between items-center mb-4">
              <span class="text-2xl">⚡</span>
              <span class="bg-gold-bruna/10 border border-gold-bruna/25 text-gold-bruna text-[9px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider font-mono">
                Req: 4 Unidades
              </span>
            </div>
            <h4 class="font-title font-bold text-sm text-white uppercase mb-2">Spark (Chispa Fría)</h4>
            <p class="text-xs text-slate-400 leading-relaxed">Máquinas de chispa fría posicionadas en la boca del escenario para momentos destacados.</p>
          </div>
        </div>
        <div class="bg-slate-950/60 border border-white/5 p-5 rounded-2xl flex flex-col justify-between hover:border-gold-bruna/20 transition-all group">
          <div>
            <div class="flex justify-between items-center mb-4">
              <span class="text-2xl">💨</span>
              <span class="bg-gold-bruna/10 border border-gold-bruna/25 text-gold-bruna text-[9px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider font-mono">
                Req: 4 Unidades
              </span>
            </div>
            <h4 class="font-title font-bold text-sm text-white uppercase mb-2">Smoke (Humo Vertical)</h4>
            <p class="text-xs text-slate-400 leading-relaxed">Máquinas de humo vertical con iluminación LED situadas detrás de las tarimas.</p>
          </div>
        </div>
        <div class="bg-slate-950/60 border border-white/5 p-5 rounded-2xl flex flex-col justify-between hover:border-gold-bruna/20 transition-all group">
          <div>
            <div class="flex justify-between items-center mb-4">
              <span class="text-2xl">🌬️</span>
              <span class="bg-gold-bruna/10 border border-gold-bruna/25 text-gold-bruna text-[9px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider font-mono">
                Req: 1 Unidad
              </span>
            </div>
            <h4 class="font-title font-bold text-sm text-white uppercase mb-2">Hazer (Humo Ambiente)</h4>
            <p class="text-xs text-slate-400 leading-relaxed">Máquina de humo Hazer de flujo continuo colocada en el centro trasero del escenario.</p>
          </div>
        </div>
      `;
    }
  }

  // Cargar Documentos de Descarga del layout
  async function loadDownloads() {
    const container = document.getElementById('downloads-grid-container');
    if (!container) return;

    container.innerHTML = '<p class="text-xs text-slate-450 uppercase animate-pulse">Cargando descargas...</p>';

    const { data, error } = await supabase
      .from('downloads')
      .select('*')
      .or(`layout_id.eq.${currentLayoutId},layout_id.is.null`)
      .order('orden', { ascending: true });

    if (!error && data && data.length > 0) {
      container.innerHTML = data.map(d => `
        <div class="bg-slate-950/60 border border-white/5 p-5 rounded-2xl flex flex-col justify-between hover:border-gold-bruna/20 transition-all group">
          <div class="mb-4">
            <span class="text-[9px] text-slate-500 font-mono uppercase tracking-wider block mb-1">${d.categoria}</span>
            <h4 class="font-title font-bold text-sm text-white uppercase">${d.titulo}</h4>
          </div>
          <a 
            href="${d.pdf_url || d.imagen_url || '#'}" 
            download 
            class="w-full text-center bg-slate-900 hover:bg-slate-800 border border-white/10 hover:border-gold-bruna/30 text-white font-semibold py-2.5 rounded-lg text-xs transition-colors cursor-pointer uppercase tracking-wider font-title"
          >
            Descargar Archivo ➔
          </a>
        </div>
      `).join('');
    } else {
      container.innerHTML = `
        <p class="text-xs text-slate-500 italic xl:col-span-3 text-center py-6">No hay archivos adicionales configurados para descargar en esta versión.</p>
      `;
    }
  }
</script>
