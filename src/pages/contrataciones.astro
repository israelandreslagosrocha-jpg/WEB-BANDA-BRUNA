---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../services/supabaseClient.js';

// Cargar testimonios aprobados
const { data: dbTestimonios } = await supabase
  .from('testimonios')
  .select('*')
  .eq('aprobado', true)
  .order('created_at', { ascending: false });

const testimonios = dbTestimonios || [];
---

<Layout title="Contrataciones | Banda Bruna - Cotización de Eventos y Shows" description="Contrata a Banda Bruna para tu festival municipal, fiesta costumbrista, boda o evento corporativo. Formulario de cotización rápido y WhatsApp directo.">
  <section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">BOOKING COMERCIAL</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold font-title uppercase">CONTRATA LA EXPERIENCIA</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 gap-12">
      
      <!-- Aggressive CTAs cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="https://wa.me/56990021689" target="_blank" rel="noopener" class="bg-slate-900 border border-white/5 hover:border-green-500 rounded-xl p-6 flex justify-between items-center transition-colors group cursor-pointer">
          <div>
            <span class="text-[10px] text-slate-500 font-bold uppercase tracking-wider block mb-1">WHATSAPP DIRECTO</span>
            <span class="text-white font-bold text-lg block">+56 9 9002 1689</span>
          </div>
          <span class="text-xs text-green-400 font-bold border border-green-500/20 px-3 py-1.5 rounded bg-green-950/20 group-hover:bg-green-500 group-hover:text-black transition-colors">COTIZAR POR WHATSAPP</span>
        </a>

        <a href="mailto:contacto@bandabruna.cl" class="bg-slate-900 border border-white/5 hover:border-gold-bruna rounded-xl p-6 flex justify-between items-center transition-colors group cursor-pointer">
          <div>
            <span class="text-[10px] text-slate-500 font-bold uppercase tracking-wider block mb-1">CORREO BOOKING</span>
            <span class="text-white font-bold text-lg block">contacto@bandabruna.cl</span>
          </div>
          <span class="text-xs text-gold-bruna font-bold border border-gold-bruna/20 px-3 py-1.5 rounded bg-amber-950/20 group-hover:bg-gold-bruna group-hover:text-black transition-colors">COTIZAR POR EMAIL</span>
        </a>
      </div>

      <!-- Extended booking Form Wrapper -->
      <div id="booking-form-container" class="bg-slate-900 border border-white/5 rounded-xl p-6 md:p-8 shadow-xl">
        <h2 class="font-title font-bold text-2xl text-white mb-6 uppercase border-b border-white/5 pb-3">Formulario de Cotización de Shows</h2>
        
        <form id="quote-form-extended" class="flex flex-col gap-6" novalidate>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="ext-name" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Nombre del Contacto / Productor</label>
              <input 
                type="text" 
                id="ext-name" 
                name="name" 
                placeholder="Ingresa tu nombre completo" 
                required
                class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
              />
              <span class="text-[10px] text-red-400 hidden" id="ext-name-err">Por favor ingresa tu nombre.</span>
            </div>
            
            <div class="flex flex-col gap-2">
              <label for="ext-phone" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Teléfono de Contacto</label>
              <input 
                type="tel" 
                id="ext-phone" 
                name="phone" 
                placeholder="+56 9 1234 5678" 
                required
                autocomplete="tel"
                inputmode="tel"
                class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
              />
              <span class="text-[10px] text-red-400 hidden" id="ext-phone-err">Por favor ingresa tu teléfono.</span>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="ext-email" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Correo Electrónico</label>
              <input 
                type="email" 
                id="ext-email" 
                name="email" 
                placeholder="ejemplo@correo.com" 
                required
                autocomplete="email"
                inputmode="email"
                class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
              />
              <span class="text-[10px] text-red-400 hidden" id="ext-email-err">Por favor ingresa un correo válido.</span>
            </div>
            
            <div class="flex flex-col gap-2">
              <label for="ext-type" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Tipo de Evento</label>
              <select 
                id="ext-type" 
                name="event-type"
                class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors cursor-pointer"
              >
                <option value="municipal">Festival Municipal / Show Público</option>
                <option value="costumbrista">Fiesta Costumbrista</option>
                <option value="corporativo">Evento Corporativo / Empresa</option>
                <option value="matrimonio">Matrimonio / Fiesta Privada</option>
                <option value="otro">Otro tipo de espectáculo</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="ext-date" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Fecha Tentativa del Evento</label>
              <input 
                type="date" 
                id="ext-date" 
                name="event-date"
                required
                class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors cursor-pointer"
              />
              <span class="text-[10px] text-red-400 hidden" id="ext-date-err">Por favor selecciona la fecha.</span>
            </div>
            
            <div class="flex flex-col gap-2">
              <label for="ext-city" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Ciudad / Comuna del Evento</label>
              <input 
                type="text" 
                id="ext-city" 
                name="city" 
                placeholder="Ej: Temuco, Valdivia, Osorno" 
                required
                class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors"
              />
              <span class="text-[10px] text-red-400 hidden" id="ext-city-err">Por favor ingresa la comuna.</span>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="ext-message" class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Detalles del Requerimiento / Horarios / Duración</label>
            <textarea 
              id="ext-message" 
              name="message" 
              rows="5" 
              placeholder="Indica detalles del escenario, amplificación (si la provee el productor), duración estimada del show..."
              class="bg-slate-950 border border-white/5 rounded p-3 text-white text-sm outline-none hover:border-white/15 focus:border-gold-bruna focus:bg-slate-950/80 transition-colors resize-none"
            ></textarea>
          </div>

          <button type="submit" class="bg-gradient-to-r from-gold-bruna to-gold-bruna-hover text-black font-bold py-3.5 rounded text-sm hover:scale-102 hover:shadow-lg hover:shadow-gold-bruna/20 transition-all cursor-pointer">
            ENVIAR SOLICITUD DE COTIZACIÓN
          </button>
          
          <div id="ext-form-feedback" class="hidden text-center text-sm py-2.5 px-4 rounded border" role="alert"></div>

        </form>
      </div>

      <!-- Success Panel (Hidden by default) -->
      <div id="success-panel" class="hidden bg-slate-900 border border-white/5 rounded-xl p-8 md:p-10 shadow-2xl text-center flex flex-col items-center gap-6">
        <div class="w-16 h-16 rounded-full bg-green-950/40 border border-green-500/30 text-green-400 flex items-center justify-center text-3xl animate-bounce">
          ✓
        </div>
        <div>
          <h2 class="font-title font-extrabold text-2xl text-white uppercase tracking-wide">¡Cotización Procesada!</h2>
          <p class="text-slate-300 text-sm font-light mt-2 max-w-lg mx-auto">
            Hemos enviado un correo electrónico con todos los detalles de tu cotización a <strong class="text-white">contacto@bandabruna.cl</strong>.
          </p>
          <p class="text-slate-450 text-[10px] font-light mt-2 max-w-lg mx-auto italic">
            (Nota: Si es el primer envío desde el sitio, recuerda revisar tu bandeja de contacto@bandabruna.cl para confirmar la activación del formulario de FormSubmit.co).
          </p>
        </div>

        <div class="w-full max-w-md border-t border-white/5 pt-6 mt-2 flex flex-col gap-4">
          <span class="text-[10px] font-bold text-slate-500 tracking-widest uppercase">AVISAR INMEDIATAMENTE POR WHATSAPP</span>
          <p class="text-slate-400 text-xs font-light leading-relaxed">
            Hemos intentado abrir la ventana de WhatsApp para enviar el aviso a Jaime Cárdenas. Si no se abrió o deseas notificar también a César Bruna, haz clic en cualquiera de los siguientes botones para abrir el chat con el mensaje listo para enviar:
          </p>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
            <a id="btn-wa-jaime" href="#" target="_blank" rel="noopener" class="bg-green-600 hover:bg-green-700 text-white font-bold text-xs py-3 px-4 rounded transition-all flex items-center justify-center gap-2 uppercase tracking-wide">
              💬 Jaime Cárdenas
            </a>
            <a id="btn-wa-cesar" href="#" target="_blank" rel="noopener" class="bg-green-600 hover:bg-green-700 text-white font-bold text-xs py-3 px-4 rounded transition-all flex items-center justify-center gap-2 uppercase tracking-wide">
              💬 César Bruna
            </a>
          </div>
        </div>

        <a href="/contrataciones" class="mt-4 border border-white/10 hover:border-gold-bruna text-white hover:text-gold-bruna text-xs py-2 px-6 rounded transition-colors uppercase font-bold tracking-wider">
          Cotizar Otro Show
        </a>
      </div>

    </div>

  </section>

  <!-- Section: Testimonios / Reseñas de Clientes (Dynamic from Supabase) -->
  {testimonios.length > 0 && (
    <section class="border-t border-white/5 bg-slate-950/40 py-16 md:py-24 px-6 mt-12 w-full">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mb-12">
          <span class="text-gold-bruna text-xs tracking-[0.2em] font-bold uppercase block mb-1">RESPALDO COMERCIAL</span>
          <h2 class="text-2xl md:text-3xl font-extrabold font-title uppercase text-white font-title">Opiniones de Nuestros Clientes</h2>
          <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {testimonios.slice(0, 4).map((item, idx) => (
            <blockquote class="bg-slate-900 border border-white/5 p-6 rounded-2xl text-left relative flex flex-col justify-between group hover:border-gold-bruna/20 transition-all duration-300 shadow-xl">
              <div>
                <span class="text-gold-bruna text-4xl font-serif absolute top-4 left-4 opacity-10 leading-none select-none pointer-events-none">“</span>
                <div class="flex gap-0.5 text-gold-bruna text-[10px] mb-3 pl-2">
                  {'★'.repeat(item.calificacion)}{'☆'.repeat(5 - item.calificacion)}
                </div>
                <p class="text-xs text-slate-350 italic font-light relative z-10 pl-2 leading-relaxed mb-4">
                  "{item.contenido}"
                </p>
              </div>
              <cite class="block pl-2 not-italic border-t border-white/5 pt-3">
                <strong class="text-white text-xs font-bold font-title uppercase block tracking-wider group-hover:text-gold-bruna transition-colors">{item.nombre_cliente}</strong>
                {item.cargo_cliente || item.organizacion_cliente ? (
                  <span class="text-[9px] text-slate-500 uppercase tracking-wide block mt-0.5">
                    {item.cargo_cliente} {item.cargo_cliente && item.organizacion_cliente ? '—' : ''} {item.organizacion_cliente}
                  </span>
                ) : null}
              </cite>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <script>
    import { supabase } from '../services/supabaseClient.js';
    import { sendEmail } from '../services/emailService.js';

    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('quote-form-extended');
      const feedback = document.getElementById('ext-form-feedback');
      const nameInput = document.getElementById('ext-name');
      const phoneInput = document.getElementById('ext-phone');
      const emailInput = document.getElementById('ext-email');
      const dateInput = document.getElementById('ext-date');
      const cityInput = document.getElementById('ext-city');

      const nameErr = document.getElementById('ext-name-err');
      const phoneErr = document.getElementById('ext-phone-err');
      const emailErr = document.getElementById('ext-email-err');
      const dateErr = document.getElementById('ext-date-err');
      const cityErr = document.getElementById('ext-city-err');

      // Pre-fill fields from URL query parameters if available
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.has('name') && nameInput) nameInput.value = decodeURIComponent(urlParams.get('name'));
      if (urlParams.has('email') && emailInput) emailInput.value = decodeURIComponent(urlParams.get('email'));
      if (urlParams.has('type')) {
        const typeSelect = document.getElementById('ext-type');
        if (typeSelect) typeSelect.value = decodeURIComponent(urlParams.get('type'));
      }
      if (urlParams.has('date') && dateInput) dateInput.value = decodeURIComponent(urlParams.get('date'));

      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          
          nameErr.classList.add('hidden');
          phoneErr.classList.add('hidden');
          emailErr.classList.add('hidden');
          dateErr.classList.add('hidden');
          cityErr.classList.add('hidden');
          feedback.classList.add('hidden');

          let valid = true;

          if (!nameInput.value.trim()) {
            nameErr.classList.remove('hidden');
            valid = false;
          }

          if (!phoneInput.value.trim()) {
            phoneErr.classList.remove('hidden');
            valid = false;
          }

          if (!emailInput.value.trim() || !emailInput.checkValidity()) {
            emailErr.classList.remove('hidden');
            valid = false;
          }

          if (!dateInput.value) {
            dateErr.classList.remove('hidden');
            valid = false;
          }

          if (!cityInput.value.trim()) {
            cityErr.classList.remove('hidden');
            valid = false;
          }

          if (!valid) return;

          const btn = form.querySelector('button[type="submit"]');
          const origText = btn.textContent;
          btn.textContent = 'Enviando...';
          btn.disabled = true;

          const nameVal = nameInput.value.trim();
          const phoneVal = phoneInput.value.trim();
          const emailVal = emailInput.value.trim();
          const typeSelect = document.getElementById('ext-type');
          const typeVal = typeSelect ? typeSelect.options[typeSelect.selectedIndex].text : '';
          const dateVal = dateInput.value;
          const cityVal = cityInput.value.trim();
          const msgVal = document.getElementById('ext-message').value.trim() || 'Sin detalles adicionales.';

          // Guardar cotización en Supabase
          supabase.from('cotizaciones').insert([
            {
              nombre: nameVal,
              telefono: phoneVal,
              email: emailVal,
              fecha_evento: dateVal || null,
              ciudad: cityVal,
              tipo_evento: typeVal,
              mensaje: msgVal
            }
          ]).then(({ error }) => {
            if (error) {
              console.error('Error al guardar en Supabase:', error);
            } else {
              console.log('Cotización guardada exitosamente en Supabase');
            }
          });

          // Send email asynchronously using Web3Forms
          sendEmail({
            Asunto: "Nueva Cotización desde Sitio Web",
            Nombre: nameVal,
            Teléfono: phoneVal,
            Email: emailVal,
            "Tipo de Evento": typeVal,
            "Fecha Tentativa": dateVal,
            "Ciudad/Comuna": cityVal,
            "Detalles/Mensaje": msgVal
          })
          .then(() => {
            btn.textContent = origText;
            btn.disabled = false;

            // Formulate WhatsApp notification message
            const waMessage = `*Nueva Solicitud de Cotización - Banda Bruna*\n\n` +
              `👤 *Contacto:* ${nameVal}\n` +
              `📞 *Fono:* ${phoneVal}\n` +
              `📧 *Email:* ${emailVal}\n` +
              `🎭 *Evento:* ${typeVal}\n` +
              `📅 *Fecha:* ${dateVal}\n` +
              `📍 *Ciudad/Comuna:* ${cityVal}\n` +
              `📝 *Detalles:* ${msgVal}`;
            
            const encodedMessage = encodeURIComponent(waMessage);

            // Configure Jaime and Cesar WhatsApp links
            const btnJaime = document.getElementById('btn-wa-jaime');
            const btnCesar = document.getElementById('btn-wa-cesar');
            if (btnJaime) btnJaime.href = `https://wa.me/56990021689?text=${encodedMessage}`;
            if (btnCesar) btnCesar.href = `https://wa.me/56976149408?text=${encodedMessage}`;

            // Try opening Jaime's WhatsApp window automatically
            window.open(`https://wa.me/56990021689?text=${encodedMessage}`, '_blank');

            // Hide the form wrapper and show success panel
            const formContainer = document.getElementById('booking-form-container');
            const successPanel = document.getElementById('success-panel');
            if (formContainer) formContainer.classList.add('hidden');
            if (successPanel) successPanel.classList.remove('hidden');

            form.reset();
          })
          .catch(() => {
            btn.textContent = origText;
            btn.disabled = false;
            feedback.textContent = 'Hubo un inconveniente al enviar tu cotización por correo. Por favor, intenta de nuevo o contáctanos directamente a través de WhatsApp.';
            feedback.className = 'text-center text-sm py-2.5 px-4 rounded border bg-red-950/20 border-red-500/20 text-red-450 block';
          });
        });
      }
    });
  </script>

</Layout>
