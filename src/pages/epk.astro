  <!-- Client-side script for interactive tabs -->
  <script>
    // Tab switching logic for EPK Rider Page
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        
        // Remove active states from buttons
        tabButtons.forEach(b => {
          b.classList.remove('active', 'text-gold-bruna', 'border-b-2', 'border-gold-bruna');
          b.classList.add('text-slate-400');
        });
        
        // Add active states to clicked button
        btn.classList.add('active', 'text-gold-bruna', 'border-b-2', 'border-gold-bruna');
        btn.classList.remove('text-slate-400');
        
        // Hide all contents
        tabContents.forEach(content => {
          content.classList.add('hidden');
        });
        
        // Show selected content
        const activeContent = document.getElementById(`tab-${tabId}`);
        if (activeContent) {
          activeContent.classList.remove('hidden');
        }
      });
    });
  </script>
