---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../services/supabaseClient.js';

// Cargar Canales
const { data: dbCanales } = await supabase
  .from('rider_canales')
  .select('*')
  .order('canal', { ascending: true });

// Cargar Monitores
const { data: dbMonitores } = await supabase
  .from('rider_monitores')
  .select('*')
  .order('mezcla', { ascending: true });

// Cargar Requerimientos
const { data: dbReqs } = await supabase
  .from('rider_requerimientos')
  .select('*');

// Fallback estático en caso de que las tablas en Supabase estén vacías
const defaultCanales = [
  { canal: 1, instrumento: 'KICK', conexion: 'SHURE PGA52', categoria: 'bateria' },
  { canal: 2, instrumento: 'SNARE', conexion: 'SHURE PGA57', categoria: 'bateria' },
  { canal: 3, instrumento: 'TIMBAL HIGH', conexion: 'SHURE PGA56', categoria: 'bateria' },
  { canal: 4, instrumento: 'TIMBAL LOW', conexion: 'SHURE PGA56', categoria: 'bateria' },
  { canal: 5, instrumento: 'OCTAPAD', conexion: 'CAJA DIRECTA', categoria: 'bateria' },
  { canal: 6, instrumento: 'OH L', conexion: 'SHURE PGA81', categoria: 'bateria' },
  { canal: 7, instrumento: 'OH R', conexion: 'SHURE PGA81', categoria: 'bateria' },
  { canal: 8, instrumento: 'CONGA HIGH', conexion: 'SHURE PGA56', categoria: 'percusion' },
  { canal: 9, instrumento: 'CONGA LOW', conexion: 'SHURE PGA56', categoria: 'percusion' },
  { canal: 10, instrumento: 'BONGOS', conexion: 'SHURE SM57', categoria: 'percusion' },
  { canal: 11, instrumento: 'CHIMES', conexion: 'SHURE SM57', categoria: 'percusion' },
  { canal: 12, instrumento: 'HUIRO', conexion: 'CAJA DIRECTA', categoria: 'percusion' },
  { canal: 13, instrumento: 'BAJO', conexion: 'XLR DIRECTO', categoria: 'cuerdas' },
  { canal: 14, instrumento: 'GTR', conexion: 'SHURE SM57', categoria: 'cuerdas' },
  { canal: 15, instrumento: 'KEY L', conexion: 'CAJA DIRECTA', categoria: 'teclados' },
  { canal: 16, instrumento: 'KEY R', conexion: 'CAJA DIRECTA', categoria: 'teclados' },
  { canal: 17, instrumento: 'VOZ CONGA', conexion: 'SHURE SM58', categoria: 'voces' },
  { canal: 18, instrumento: 'VOZ BAJO', conexion: 'SHURE SM58', categoria: 'voces' },
  { canal: 19, instrumento: 'VOZ BATERIA', conexion: 'SHURE SM58', categoria: 'voces' },
  { canal: 20, instrumento: 'VOZ GTR', conexion: 'SHURE SM58', categoria: 'voces' },
  { canal: 21, instrumento: 'VOZ PRINCIPAL', conexion: 'SHURE SM58', categoria: 'voces' },
  { canal: 22, instrumento: 'TALBACK', conexion: 'SHURE SM58', categoria: 'voces' },
  { canal: 23, instrumento: 'SECUENCIA L', conexion: 'CAJA DIRECTA', categoria: 'teclados' },
  { canal: 24, instrumento: 'SECUENCIA R', conexion: 'CAJA DIRECTA', categoria: 'teclados' }
];

const defaultMonitores = [
  { mezcla: 1, envio: 'MONITOR BATERIA', sistema: 'IN EAR' },
  { mezcla: 2, envio: 'MONITOR CONGAS', sistema: 'IN EAR' },
  { mezcla: 3, envio: 'MONITOR TECLADO', sistema: 'IN EAR' },
  { mezcla: 4, envio: 'MONITOR GTR', sistema: 'IN EAR' },
  { mezcla: 5, envio: 'MONITOR BAJO', sistema: 'IN EAR' },
  { mezcla: 6, envio: 'MONITOR DE PISO', sistema: 'PISO (FLOOR)' }
];

const defaultReqs = [
  {
    categoria: 'audio',
    titulo: 'SISTEMA DE AUDIO (P.A. & FOH)',
    items: [
      'P.A.: Refuerzo sonoro profesional (Line Array o similar) de marcas reconocidas, con cobertura uniforme para todo el recinto y excelente respuesta en bajas frecuencias.',
      'Presión: Mínimo de 100 dB SPL sostenidos en la mesa de control sin distorsión.',
      'Consola FOH: Consola digital profesional (Midas M32, Behringer X32, A&H SQ/Avantis, Yamaha CL/QL o similar) con mín. 24 canales libres y efectos integrados (Reverb/Delay).'
    ]
  },
  {
    categoria: 'monitores',
    titulo: 'MONITOREO (MONITORS)',
    items: [
      'Sistemas In-Ear: 6 vías independientes (inalámbricas/cableadas) para Voces, Teclados, Secuencia, etc.',
      'Monitores de Piso: Mínimo 3 monitores profesionales de alta calidad.',
      'Drum-Fill / Side-Fill: Sistema de monitoreo con Subwoofer potente para la sección rítmica.'
    ]
  },
  {
    categoria: 'luces',
    titulo: 'ILUMINACIÓN Y ESCENARIO',
    items: [
      'Diseño de Luces: Dinámico y festivo. Uso de focos LED móviles, cegadores para interacción con el público y máquina de humo constante de manera controlada.',
      'Alimentación Eléctrica: Puntos de corriente 220V regulados y estabilizados con toma de tierra en: Teclados, Bajo, Guitarra y Percusión.'
    ]
  },
  {
    categoria: 'logistica',
    titulo: 'LOGÍSTICA Y HOSPITALIDAD',
    items: [
      'Camarines: Espacio privado, limpio, con llave y espejo de cuerpo entero, apto para 10 personas (músicos y staff).',
      'Catering: Agua mineral sin gas abundante (fría y ambiente), bebidas, jugos, energéticas, sándwiches, snacks salados y frutos secos.',
      'Estacionamiento: Cupos reservados y seguros cerca de la zona de carga y descarga para vehículos del equipo.'
    ]
  }
];

const canales = dbCanales && dbCanales.length > 0 ? dbCanales : defaultCanales;
const monitores = dbMonitores && dbMonitores.length > 0 ? dbMonitores : defaultMonitores;

const reqsMap: Record<string, any> = {};
const finalReqs = dbReqs && dbReqs.length > 0 ? dbReqs : defaultReqs;
finalReqs.forEach((r: any) => {
  reqsMap[r.categoria] = r;
});

// Función auxiliar para obtener el canal de un instrumento en el Stage Plot
const getCh = (instrumentoName: string): string => {
  const ch = canales.find((c: any) => c.instrumento.toUpperCase() === instrumentoName.toUpperCase());
  return ch ? `CH ${ch.canal}` : 'CH —';
};

// Función auxiliar para obtener el rango de canales de una categoría
const getChRange = (category: string): string => {
  const matches = canales.filter((c: any) => c.categoria === category).map((c: any) => c.canal);
  if (matches.length === 0) return 'CH —';
  if (matches.length === 1) return `CH ${matches[0]}`;
  return `CH ${Math.min(...matches)} - ${Math.max(...matches)}`;
};
---

<Layout title="Electronic Press Kit (EPK) | Banda Bruna - Kit de Prensa Oficial" description="Kit de prensa digital (EPK) de Banda Bruna para productores, promotores y medios. Biografía corta, logos oficiales, fotos de prensa y rider técnico.">
  <section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">PROMOTORES & PRENSA</span>
      <h1 class="text-4xl font-extrabold font-title uppercase">ELECTRONIC PRESS KIT</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <div class="flex flex-col gap-12 text-slate-300 font-light">
      
      <!-- EPK Bio -->
      <div class="bg-slate-900 border border-white/5 rounded-xl p-8 shadow-lg">
        <h2 class="font-title font-bold text-2xl text-white mb-4 uppercase">Resumen Biográfico</h2>
        <p class="text-sm leading-relaxed mb-4">
          <strong>Banda Bruna</strong> es una agrupación originaria de Temuco, Chile, nacida con la misión de refrescar la escena tropical y tropical-rock del país. Fusionando riffs eléctricos enérgicos con sintetizadores espaciales y la base bailable indiscutible de la cumbia sureña, la banda ha consolidado un show de alto nivel técnico y visual que conecta con todo tipo de públicos en festivales, eventos corporativos y celebraciones municipales.
        </p>
        <p class="text-sm leading-relaxed">
          Su sonido particular combina la alegría rítmica con letras nostálgicas que remiten a las atmósferas y paisajes del sur chileno. Ideal para escenarios masivos y eventos que busquen prender la fiesta con calidad y profesionalismo.
        </p>
      </div>

      <!-- Downloads section -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Brand Assets -->
        <div class="bg-slate-900 border border-white/5 rounded-xl p-6 flex flex-col justify-between">
          <div>
            <h3 class="font-title font-bold text-xl text-white mb-3 uppercase">Kit de Marca & Logos</h3>
            <p class="text-xs text-slate-400 leading-relaxed mb-4">
              Descarga logotipos oficiales de Banda Bruna en formatos de alta definición con fondo transparente para afiches publicitarios.
            </p>
            <!-- Logo previews for visual aesthetics -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="bg-black/40 border border-white/5 rounded p-3 flex items-center justify-center h-20" title="Logo Blanco Horizontal">
                <img src="/assets/images/logos/logo_main.webp" alt="Logo Blanco Horizontal" class="max-h-8 w-auto object-contain" />
              </div>
              <div class="bg-white border border-white/5 rounded p-3 flex items-center justify-center h-20" title="Logo Negro Vertical">
                <img src="/assets/images/logos/logo_2.webp" alt="Logo Negro Vertical" class="max-h-14 w-auto object-contain" />
              </div>
            </div>
          </div>
          <a href="/assets/downloads/logos.zip" download class="w-full text-center block bg-slate-950 border border-white/10 hover:border-gold-bruna text-gold-bruna font-semibold py-3 rounded text-xs transition-colors cursor-pointer uppercase">
            DESCARGAR LOGOS (.ZIP)
          </a>
        </div>

        <!-- Photos Asset -->
        <div class="bg-slate-900 border border-white/5 rounded-xl p-6 flex flex-col justify-between">
          <div>
            <h3 class="font-title font-bold text-xl text-white mb-3 uppercase">Fotografías Oficiales</h3>
            <p class="text-xs text-slate-400 leading-relaxed mb-6">
              Descarga la carpeta con fotos artísticas del grupo y de presentaciones en vivo listas para prensa, sitios web informativos e impresiones.
            </p>
          </div>
          <button class="w-full bg-slate-950 border border-white/10 hover:border-gold-bruna text-gold-bruna font-semibold py-3 rounded text-xs transition-colors cursor-pointer">
            DESCARGAR FOTOS (.ZIP)
          </button>
        </div>

      </div>

      <!-- Technical Rider details -->
      <div class="bg-slate-900 border border-white/5 rounded-xl p-6 md:p-8 shadow-lg">
        <h2 class="font-title font-bold text-2xl text-white mb-2 uppercase">Rider Técnico & Ficha Técnica</h2>
        <p class="text-xs text-slate-400 leading-relaxed mb-6">
          Consulta y descarga los requerimientos de audio (P.A. & FOH), monitores (In-Ears), iluminación, la lista completa de canales (input list) y distribución del escenario.
        </p>
        
        <!-- Tabs Buttons Navigation -->
        <div class="flex border-b border-white/10 mb-6 overflow-x-auto gap-2 scrollbar-none">
          <button class="tab-btn active px-4 py-2.5 text-xs font-title font-bold tracking-widest text-gold-bruna border-b-2 border-gold-bruna cursor-pointer uppercase whitespace-nowrap" data-tab="reqs">
            Requerimientos
          </button>
          <button class="tab-btn px-4 py-2.5 text-xs font-title font-bold tracking-widest text-slate-400 hover:text-white cursor-pointer uppercase whitespace-nowrap" data-tab="channels">
            Lista de Canales
          </button>
          <button class="tab-btn px-4 py-2.5 text-xs font-title font-bold tracking-widest text-slate-400 hover:text-white cursor-pointer uppercase whitespace-nowrap" data-tab="stage">
            Escenario (Stage Plot)
          </button>
        </div>

        <!-- Tab Content 1: Reqs -->
        <div id="tab-reqs" class="tab-content flex flex-col gap-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Audio Reqs -->
            <div class="bg-slate-950/40 border border-white/5 p-5 rounded-lg">
              <h3 class="text-white font-title font-bold text-sm mb-3 text-gold-bruna flex items-center gap-2">
                <span>🔊</span> {reqsMap.audio?.titulo || 'SISTEMA DE AUDIO (P.A. & FOH)'}
              </h3>
              <ul class="list-disc list-inside text-xs text-slate-300 space-y-2 leading-relaxed pl-1">
                {(reqsMap.audio?.items || defaultReqs[0].items).map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <!-- Monitoreo Reqs -->
            <div class="bg-slate-950/40 border border-white/5 p-5 rounded-lg">
              <h3 class="text-white font-title font-bold text-sm mb-3 text-gold-bruna flex items-center gap-2">
                <span>🎧</span> {reqsMap.monitores?.titulo || 'MONITOREO (MONITORS)'}
              </h3>
              <ul class="list-disc list-inside text-xs text-slate-300 space-y-2 leading-relaxed pl-1">
                {(reqsMap.monitores?.items || defaultReqs[1].items).map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <!-- Iluminacion Reqs -->
            <div class="bg-slate-950/40 border border-white/5 p-5 rounded-lg">
              <h3 class="text-white font-title font-bold text-sm mb-3 text-gold-bruna flex items-center gap-2">
                <span>💡</span> {reqsMap.luces?.titulo || 'ILUMINACIÓN Y ESCENARIO'}
              </h3>
              <ul class="list-disc list-inside text-xs text-slate-300 space-y-2 leading-relaxed pl-1">
                {(reqsMap.luces?.items || defaultReqs[2].items).map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <!-- Logística Reqs -->
            <div class="bg-slate-950/40 border border-white/5 p-5 rounded-lg">
              <h3 class="text-white font-title font-bold text-sm mb-3 text-gold-bruna flex items-center gap-2">
                <span>🏥</span> {reqsMap.logistica?.titulo || 'LOGÍSTICA Y HOSPITALIDAD'}
              </h3>
              <ul class="list-disc list-inside text-xs text-slate-300 space-y-2 leading-relaxed pl-1">
                {(reqsMap.logistica?.items || defaultReqs[3].items).map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
          
          <div class="text-[11px] text-slate-400 italic bg-slate-950/40 p-4 border border-white/5 rounded leading-relaxed">
            <strong>Nota de Coordinación Obligatoria:</strong> Cualquier modificación o imposibilidad de cumplir con estos puntos debe ser notificada y consensuada con el equipo técnico de la banda con un mínimo de 10 días de anticipación al evento.
            <br />
            <strong>Contacto Directo:</strong> Tel: +56976149408 / +56990021689 | Email: contactobandabruna@gmail.com
          </div>
        </div>

        <!-- Tab Content 2: Channels -->
        <div id="tab-channels" class="tab-content hidden flex flex-col gap-6">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Channel List Table -->
            <div class="lg:col-span-2 border border-white/5 rounded-lg overflow-hidden text-xs">
              <div class="bg-slate-950 px-4 py-3 font-title font-bold text-gold-bruna border-b border-white/5 uppercase tracking-widest text-[10px]">
                Lista de Canales (Input List) - 24 Canales
              </div>
              <div class="max-h-[480px] overflow-y-auto">
                <table class="w-full border-collapse text-left">
                  <thead>
                    <tr class="bg-slate-950/60 text-slate-400 font-bold border-b border-white/5 text-[10px] uppercase">
                      <th class="p-3">CH</th>
                      <th class="p-3">Fuente / Instrumento</th>
                      <th class="p-3">Micrófono / Conexión (DI)</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/5 text-slate-300">
                    {canales.map((c: any) => (
                      <tr>
                        <td class="p-2.5 pl-4 font-bold text-gold-bruna">{c.canal}</td>
                        <td class="p-2.5">{c.instrumento}</td>
                        <td class="p-2.5">{c.conexion}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Monitor Mixes Table -->
            <div class="border border-white/5 rounded-lg overflow-hidden text-xs self-start">
              <div class="bg-slate-950 px-4 py-3 font-title font-bold text-gold-bruna border-b border-white/5 uppercase tracking-widest text-[10px]">
                Mezclas de Retorno
              </div>
              <table class="w-full border-collapse text-left">
                <thead>
                  <tr class="bg-slate-950/60 text-slate-400 font-bold border-b border-white/5 text-[10px] uppercase">
                    <th class="p-3">MIX</th>
                    <th class="p-3">Asignación</th>
                    <th class="p-3">Sistema</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-white/5 text-slate-300">
                  {monitores.map((m: any) => (
                    <tr>
                      <td class="p-2.5 pl-4 font-bold text-gold-bruna">{m.mezcla}</td>
                      <td class="p-2.5">{m.envio}</td>
                      <td class="p-2.5">{m.sistema}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Tab Content 3: Stageplot -->
        <div id="tab-stage" class="tab-content hidden flex flex-col gap-6">
          <div class="bg-slate-950/60 border border-white/5 p-6 rounded-lg text-xs leading-relaxed text-slate-300">
            <h3 class="text-white font-title font-bold text-sm mb-2 text-gold-bruna text-center uppercase">
              DISTRIBUCIÓN DEL ESCENARIO (STAGE PLOT)
            </h3>
            <p class="mb-6 text-center text-slate-400 text-[10px]">
              Distribución física exacta del escenario, adaptada al mapa gráfico oficial de Banda Bruna.
            </p>
            
            <!-- CSS Grid Visual Stage Map (Exactly matching the uploaded image) -->
            <div class="border border-white/10 rounded-lg p-6 bg-slate-950 flex flex-col gap-6 text-center max-w-3xl mx-auto mb-6 shadow-inner shadow-black relative overflow-hidden">
              
              <!-- Background grid lines decoration -->
              <div class="absolute inset-0 bg-[radial-gradient(#e5a72b05_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none" aria-hidden="true"></div>

              <!-- ESCENARIO FONDO -->
              <div class="text-[9px] text-slate-500 uppercase tracking-[0.2em] border-b border-white/5 pb-2 z-10">FONDO DEL ESCENARIO (BACK LINE)</div>
              
              <!-- Fila Posterior: Percusión (L), Batería (C), Teclados (R) -->
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4 z-10">
                <!-- Lado Izquierdo: Percusión -->
                <div class="bg-slate-900/90 border border-white/15 rounded-lg p-4 shadow-md flex flex-col justify-between h-36">
                  <div>
                    <span class="block text-gold-bruna font-bold text-xs uppercase tracking-wider">🥁 Percusión</span>
                    <span class="text-[10px] text-slate-400 block mt-1">Congas, Bongos y Chimes</span>
                    <span class="text-[10px] text-slate-300 font-semibold block mt-1">{getChRange('percusion')}</span>
                  </div>
                  <div class="border-t border-white/5 pt-2 mt-2">
                    <span class="text-[10px] text-white block font-bold">Voz Conga ({getCh('VOZ CONGA')})</span>
                    <span class="text-[9px] text-slate-500 italic">Mon 2 (In-Ear) + Monitor Piso</span>
                  </div>
                </div>

                <!-- Centro: Batería -->
                <div class="bg-slate-900/95 border border-gold-bruna/30 rounded-lg p-4 shadow-lg shadow-gold-bruna/5 flex flex-col justify-between h-36">
                  <div>
                    <span class="block text-gold-bruna font-bold text-xs uppercase tracking-wider">🥁 Batería & Timbales</span>
                    <span class="text-[10px] text-slate-400 block mt-1">Kick, Snare, Timbales, Octapad y Overheads</span>
                    <span class="text-[10px] text-slate-300 font-semibold block mt-1">{getChRange('bateria')}</span>
                  </div>
                  <div class="border-t border-white/5 pt-2 mt-2">
                    <span class="text-[10px] text-white block font-bold">Voz Batería ({getCh('VOZ BATERIA')})</span>
                    <span class="text-[9px] text-slate-500 italic">Mon 1 (In-Ear) + Drum-Fill</span>
                  </div>
                </div>

                <!-- Lado Derecho: Teclados -->
                <div class="bg-slate-900/90 border border-white/15 rounded-lg p-4 shadow-md flex flex-col justify-between h-36">
                  <div>
                    <span class="block text-gold-bruna font-bold text-xs uppercase tracking-wider">🎹 Teclados</span>
                    <span class="text-[10px] text-slate-400 block mt-1">Sintetizadores & Secuencias</span>
                    <span class="text-[10px] text-slate-300 font-semibold block mt-1">{getCh('KEY L')}, {getCh('KEY R')}</span>
                  </div>
                  <div class="border-t border-white/5 pt-2 mt-2">
                    <span class="text-[10px] text-white block font-bold">Secuencias ({getCh('SECUENCIA L')}, {getCh('SECUENCIA R')})</span>
                    <span class="text-[9px] text-slate-500 italic">Mon 3 (In-Ear)</span>
                  </div>
                </div>
              </div>

              <!-- Fila Media: Bajo (L), Güiro (C-L), Guitarra (R) + Amp (Far Right) -->
              <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center z-10">
                <!-- Lado Izquierdo: Bajo (4 cols) -->
                <div class="md:col-span-4 bg-slate-900/80 border border-white/10 rounded-lg p-3.5 shadow flex flex-col justify-between h-28">
                  <div>
                    <span class="block text-white font-bold text-[11px] uppercase tracking-wide">🎸 Bajo Eléctrico</span>
                    <span class="text-[9px] text-slate-400 block">Línea Directa ({getCh('BAJO')})</span>
                  </div>
                  <div class="border-t border-white/5 pt-1.5">
                    <span class="text-[10px] text-white block font-semibold">Voz Bajo ({getCh('VOZ BAJO')})</span>
                    <span class="text-[9px] text-slate-500 italic">Mon 5 (In-Ear)</span>
                  </div>
                </div>

                <!-- Centro-Izquierda: Güiro / Percusión Menor (3 cols) -->
                <div class="md:col-span-3 bg-slate-900/80 border border-white/10 rounded-lg p-3.5 shadow flex flex-col justify-between h-28">
                  <div>
                    <span class="block text-white font-bold text-[11px] uppercase tracking-wide">🪵 Huiro / Güiro</span>
                    <span class="text-[9px] text-slate-400 block">Línea Directa ({getCh('HUIRO')})</span>
                  </div>
                  <div class="border-t border-white/5 pt-1.5">
                    <span class="text-[9px] text-slate-400 block">Percusión Menor</span>
                    <span class="text-[9px] text-slate-500 italic">Retorno por P.A. / In-Ear</span>
                  </div>
                </div>

                <!-- Spacer (1 col) -->
                <div class="hidden md:block md:col-span-1"></div>

                <!-- Lado Derecho: Guitarra & Amplificador (4 cols) -->
                <div class="md:col-span-4 bg-slate-900/80 border border-white/10 rounded-lg p-3.5 shadow flex flex-col justify-between h-28 relative">
                  <div>
