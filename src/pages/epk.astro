---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Electronic Press Kit (EPK) | Banda Bruna - Kit de Prensa Oficial" description="Kit de prensa digital (EPK) de Banda Bruna para productores, promotores y medios. Biografía corta, logos oficiales, fotos de prensa y rider técnico.">
  <section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    
    <div class="text-center mb-16">
      <span class="text-gold-bruna text-sm tracking-widest font-semibold uppercase block mb-1">PROMOTORES & PRENSA</span>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold font-title uppercase">ELECTRONIC PRESS KIT</h1>
      <div class="w-12 h-0.5 bg-gold-bruna mx-auto mt-4"></div>
    </div>

    <div class="flex flex-col gap-12 text-slate-300 font-light">
      
      <!-- EPK Bio -->
      <div class="bg-slate-900 border border-white/5 rounded-xl p-8 shadow-lg">
        <h2 class="font-title font-bold text-2xl text-white mb-4 uppercase">Resumen Biográfico</h2>
        <p class="text-sm leading-relaxed mb-4">
          <strong>Banda Bruna</strong> es una agrupación originaria de Temuco, Chile, nacida con la misión de refrescar la escena tropical y tropical-rock del país. Fusionando riffs eléctricos enérgicos con sintetizadores espaciales y la base bailable indiscutible de la cumbia sureña, la banda ha consolidado un show de alto nivel técnico y visual que conecta con todo tipo de públicos en festivales, eventos corporativos y celebraciones municipales.
        </p>
        <p class="text-sm leading-relaxed">
          Su sonido particular combina la alegría rítmica con letras nostálgicas que remiten a las atmósferas y paisajes del sur chileno. Ideal para escenarios masivos y eventos que busquen prender la fiesta con calidad y profesionalismo.
        </p>
      </div>

      <!-- Downloads section -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Brand Assets -->
        <div class="bg-slate-900 border border-white/5 rounded-xl p-6 flex flex-col justify-between">
          <div>
            <h3 class="font-title font-bold text-xl text-white mb-3 uppercase">Kit de Marca & Logos</h3>
            <p class="text-xs text-slate-400 leading-relaxed mb-4">
              Descarga logotipos oficiales de Banda Bruna en formatos de alta definición con fondo transparente para afiches publicitarios.
            </p>
            <!-- Logo previews for visual aesthetics -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="bg-black/40 border border-white/5 rounded p-3 flex items-center justify-center h-20" title="Logo Blanco Horizontal">
                <img src="/assets/images/logos/logo_main.webp" alt="Logo Blanco Horizontal" class="max-h-8 w-auto object-contain" />
              </div>
              <div class="bg-white border border-white/5 rounded p-3 flex items-center justify-center h-20" title="Logo Negro Vertical">
                <img src="/assets/images/logos/logo_2.webp" alt="Logo Negro Vertical" class="max-h-14 w-auto object-contain" />
              </div>
            </div>
          </div>
          <a href="/assets/downloads/logos.zip" download class="w-full text-center block bg-slate-950 border border-white/10 hover:border-gold-bruna text-gold-bruna font-semibold py-3 rounded text-xs transition-colors cursor-pointer uppercase">
            DESCARGAR LOGOS (.ZIP)
          </a>
        </div>

        <!-- Photos Asset -->
        <div class="bg-slate-900 border border-white/5 rounded-xl p-6 flex flex-col justify-between">
          <div>
            <h3 class="font-title font-bold text-xl text-white mb-3 uppercase">Fotografías Oficiales</h3>
            <p class="text-xs text-slate-400 leading-relaxed mb-6">
              Descarga la carpeta con fotos artísticas del grupo y de presentaciones en vivo listas para prensa, sitios web informativos e impresiones.
            </p>
          </div>
          <button class="w-full bg-slate-950 border border-white/10 hover:border-gold-bruna text-gold-bruna font-semibold py-3 rounded text-xs transition-colors cursor-pointer">
            DESCARGAR FOTOS (.ZIP)
          </button>
        </div>
      </div>

      <!-- Enlace al Rider Técnico e Iluminación (Diferenciación de secciones) -->
      <div class="bg-slate-900 border border-white/5 rounded-2xl p-6 md:p-8 shadow-lg text-center flex flex-col items-center gap-4 relative overflow-hidden">
        <div class="absolute -top-24 -left-24 w-48 h-48 bg-gold-bruna/5 rounded-full blur-2xl pointer-events-none"></div>
        <div class="absolute -bottom-24 -right-24 w-48 h-48 bg-blue-500/5 rounded-full blur-2xl pointer-events-none"></div>
        
        <div class="w-12 h-12 rounded-xl bg-slate-950 flex items-center justify-center text-gold-bruna mb-2">
          🏗️
        </div>
        <h2 class="font-title font-bold text-xl md:text-2xl text-white uppercase">¿Buscas las Especificaciones Técnicas?</h2>
        <p class="text-xs text-slate-400 max-w-lg leading-relaxed">
          El plano de luces interactivo en 2D/3D, el Input List oficial de canales de audio, mezclas de retorno, backline y las descargas de riders para recintos se encuentran en nuestro portal de producción exclusivo.
        </p>
        <a 
          href="/produccion" 
          class="bg-gold-bruna hover:bg-gold-bruna-hover text-black px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-widest transition-transform hover:scale-[1.03] text-center font-title shadow-lg shadow-gold-bruna/10"
        >
          Entrar al Portal Técnico ➔
        </a>
      </div>

    </div>

  </section>

  <!-- CSS styles for responsives tabs -->
  <style>
    .tab-btn {
      border-left: 2px solid transparent;
      color: #94a3b8; /* text-slate-400 */
      transition: all 0.2s;
    }
    .tab-btn:hover {
      color: #ffffff;
      background-color: rgba(255, 255, 255, 0.02);
    }
    .tab-btn.active {
      color: #d4af37; /* gold-bruna */
      border-color: #d4af37;
      background-color: rgba(255, 255, 255, 0.05);
    }

    @media (min-width: 768px) {
      .tab-btn {
        border-left: none;
        border-bottom: 2px solid transparent;
        text-align: center;
      }
      .tab-btn:hover {
        background-color: transparent;
      }
      .tab-btn.active {
        border-color: #d4af37;
        background-color: transparent;
      }
    }
  </style>

  <!-- Client-side script for interactive tabs -->
  <script>
    // Tab switching logic for EPK Rider Page
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        
        // Remove active state from buttons
        tabButtons.forEach(b => {
          b.classList.remove('active');
        });
        
        // Add active state to clicked button
        btn.classList.add('active');
        
        // Hide all contents
        tabContents.forEach(content => {
          content.classList.add('hidden');
        });
        
        // Show selected content
        const activeContent = document.getElementById(`tab-${tabId}`);
        if (activeContent) {
          activeContent.classList.remove('hidden');
        }
      });
    });
  </script>
</Layout>
