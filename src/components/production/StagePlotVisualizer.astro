---
// Visor del Stage Plot (Distribución de Músicos y Monitores en el Escenario)
import { supabase } from '../../services/supabaseClient.js';

// Cargar elementos del Stageplot desde Supabase
const { data: dbStageData } = await supabase
  .from('rider_stageplot')
  .select('*');

// Fallback estático si la base de datos está vacía o no conecta
const fallbackElements = [
  { id: '1', nombre: 'Batería & Timbales', tipo: 'bateria', pos_x: 25.00, pos_y: 70.00 },
  { id: '2', nombre: 'Percusión', tipo: 'congas', pos_x: 75.00, pos_y: 70.00 },
  { id: '3', nombre: 'Teclados', tipo: 'teclado', pos_x: 68.00, pos_y: 20.00 },
  { id: '4', nombre: 'Bajo Eléctrico', tipo: 'bajo', pos_x: 85.00, pos_y: 20.00 },
  { id: '5', nombre: 'Huiro / Güiro', tipo: 'guiro', pos_x: 15.00, pos_y: 20.00 },
  { id: '6', nombre: 'Guitarra & Amp', tipo: 'gtr', pos_x: 32.00, pos_y: 20.00 },
  { id: '7', nombre: 'Voz Principal', tipo: 'vocal', pos_x: 50.00, pos_y: 20.00 },
  { id: '8', nombre: 'Monitores de Piso', tipo: 'monitor', pos_x: 36.80, pos_y: 89.27 }
];

const rawElements = dbStageData && dbStageData.length > 0 ? dbStageData : fallbackElements;

// Mapear elementos del Stage Plot a los músicos/roles correspondientes
const members = rawElements.map((el: any) => {
  let initials = '';
  let name = el.nombre;
  let role = '';
  let aux = el.retorno || '';
  let borderGlow = 'border-gold-bruna/85 shadow-[0_0_8px_rgba(212,175,55,0.25)]';
  let typeColor = 'text-gold-bruna';
  let isWedge = false;
  let hasAC = false;
  let isMonitorOrPower = false;
  let iconEmoji = '';

  if (el.tipo === 'bateria') {
    initials = 'JQ';
    name = 'Jaime C. Quilodrán';
    role = 'Percusión/Timbal/Voces';
    aux = 'Aux 6 Wedge';
    isWedge = true;
    borderGlow = 'border-blue-500/80 shadow-[0_0_8px_rgba(59,130,246,0.25)]';
    typeColor = 'text-blue-400';
    hasAC = true;
  } else if (el.tipo === 'congas') {
    initials = 'JS';
    name = 'Jaime C. Sanhueza';
    role = 'Congas/Bongós/Coros';
    aux = 'Aux 7 Wedge';
    isWedge = true;
    borderGlow = 'border-blue-500/80 shadow-[0_0_8px_rgba(59,130,246,0.25)]';
    typeColor = 'text-blue-400';
    hasAC = true;
  } else if (el.tipo === 'teclado') {
    initials = 'IL';
    name = 'Israel Lagos Rocha';
    role = 'Pianos/Teclados/Sintetizadores';
    aux = 'Aux 5 IEM';
    hasAC = true;
  } else if (el.tipo === 'bajo') {
    initials = 'GU';
    name = 'Gerson Ulloa';
    role = 'Bajos/Coros';
    aux = 'Aux 4 IEM';
    hasAC = true;
  } else if (el.tipo === 'guiro') {
    initials = 'FG';
    name = 'Fabian Garrido';
    role = 'Guiro/Animación';
    aux = 'Aux 2 IEM';
  } else if (el.tipo === 'gtr') {
    initials = 'VN';
    name = 'Vicente Nuñez';
    role = 'Guitarra Electrica/Dir/Coros';
    aux = 'Aux 3 IEM';
    hasAC = true;
  } else if (el.tipo === 'vocal') {
    initials = 'CB';
    name = 'Cesar Bruna';
    role = 'Voz principal';
    aux = 'Aux 1 IEM';
  } else if (el.tipo === 'monitor') {
    initials = 'MON';
    name = el.nombre || 'Monitor de Piso';
    role = 'Retorno Escenario';
    aux = el.retorno || 'Wedge';
    isWedge = true;
    borderGlow = 'border-blue-500/50 shadow-[0_0_6px_rgba(59,130,246,0.15)]';
    typeColor = 'text-blue-400';
    isMonitorOrPower = true;
    iconEmoji = '🔊';
  } else if (el.tipo === 'power') {
    initials = '220V';
    name = el.nombre || 'Toma de Corriente';
    role = 'AC Power 220V';
    aux = 'Alimentación';
    borderGlow = 'border-emerald-500/50';
    typeColor = 'text-emerald-400';
    isMonitorOrPower = true;
    iconEmoji = '⚡';
    hasAC = true;
  } else {
    initials = el.nombre.substring(0, 2).toUpperCase();
    name = el.nombre;
    role = 'Elemento Stage';
    aux = el.retorno || '';
  }

  return {
    id: el.id,
    name,
    role,
    initials,
    aux,
    borderGlow,
    typeColor,
    isWedge,
    hasAC,
    isMonitorOrPower,
    iconEmoji,
    x: el.pos_x !== null ? parseFloat(el.pos_x) : 50,
    y: el.pos_y !== null ? parseFloat(el.pos_y) : 50
  };
});
---
<div class="bg-slate-900/40 border border-white/5 rounded-3xl p-6 relative overflow-hidden" id="stage-plot-root">
  <div class="absolute -top-40 -left-40 w-80 h-80 bg-gold-bruna/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
    <div>
      <h3 class="font-title font-bold text-lg uppercase text-white mb-1">Stage Plot Oficial (Distribución)</h3>
      <p class="text-xs text-slate-400">Distribución física de los músicos en escenario, tarimas y asignación de monitores.</p>
    </div>
    <!-- Indicadores/Leyenda -->
    <div class="flex flex-wrap gap-3 text-[10px] uppercase font-bold tracking-wider font-mono">
      <div class="flex items-center gap-1.5 text-gold-bruna">
        <span class="w-2.5 h-2.5 rounded-full bg-gold-bruna"></span>
        IEM (In-Ear)
      </div>
      <div class="flex items-center gap-1.5 text-blue-400">
        <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
        Wedge (Piso)
      </div>
      <div class="flex items-center gap-1.5 text-emerald-400">
        <span class="w-2.5 h-2.5 rounded bg-emerald-500"></span>
        [AC] Corriente
      </div>
    </div>
  </div>

  <!-- Lienzo del Escenario (Stage Plot) -->
  <div class="w-full bg-slate-950 border border-white/10 rounded-2xl relative p-6 aspect-[16/9] md:aspect-[16/7.5] min-h-[320px] shadow-inner shadow-black overflow-hidden flex flex-col justify-between">
    <!-- Grid decorativo -->
    <div class="absolute inset-0 bg-[radial-gradient(#ffffff03_1px,transparent_1px)] [background-size:20px_20px] pointer-events-none"></div>
    
    <!-- LÍNEAS DE CONTORNO DE TARIMAS DE PERCUSIÓN COMO GUÍAS DE FONDO -->
    <div class="absolute left-[12%] top-[15%] w-[180px] h-[100px] border border-dashed border-white/5 bg-slate-900/10 rounded-xl flex items-center justify-center text-[7.5px] text-slate-650 uppercase font-mono pointer-events-none">
      Área Tarima Percusión
    </div>
    <div class="absolute right-[12%] top-[15%] w-[180px] h-[100px] border border-dashed border-white/5 bg-slate-900/10 rounded-xl flex items-center justify-center text-[7.5px] text-slate-650 uppercase font-mono pointer-events-none">
      Área Tarima Congas
    </div>

    <!-- Músicos Posicionados de Forma Dinámica -->
    <div class="absolute inset-0 z-10">
      {members.map(m => (
        <div 
          class="absolute flex flex-col items-center gap-1 text-center group transition-all duration-300"
          style={`left: ${m.x}%; top: ${m.y}%; transform: translate(-50%, -50%); width: 120px;`}
        >
          <!-- Círculo del músico / elemento -->
          <div class={`w-11 h-11 rounded-full bg-slate-900 border-2 ${m.borderGlow} flex items-center justify-center relative shadow-lg shadow-black text-white group-hover:scale-105 transition-transform font-bold font-mono text-xs`}>
            {m.isMonitorOrPower ? m.iconEmoji : m.initials}
            {!m.isMonitorOrPower && (
              <div class="absolute -bottom-1 -right-1 bg-slate-950 border border-white/10 text-white text-[6.5px] font-mono px-1 rounded-full">
                {m.aux.split(' ')[0]}
              </div>
            )}
          </div>
          <!-- Nombre y Rol -->
          <div class="pointer-events-none select-none">
            <h4 class="text-[9px] text-white font-bold uppercase font-mono tracking-tight leading-tight">{m.name}</h4>
            <p class="text-[7.5px] text-slate-450 leading-none mt-0.5">{m.role.split('/')[0]}</p>
            <div class="flex items-center justify-center gap-1 mt-0.5">
              <span class={`text-[7px] font-mono font-bold ${m.typeColor}`}>{m.aux.split(' ')[1] || 'IEM'}</span>
              {m.hasAC && <span class="text-[7px] text-emerald-400 font-mono font-bold">[AC]</span>}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Boca de escenario -->
    <div class="absolute bottom-2 left-0 right-0 text-center border-t border-white/5 pt-2 text-[8px] text-slate-500 font-mono uppercase tracking-widest bg-slate-950/80 z-20">
      ▲ Boca de Escenario (Frente al público) ▲
    </div>
  </div>
</div>
