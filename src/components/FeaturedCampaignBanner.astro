---
import { supabase } from '../services/supabaseClient.js';

let campaign = null;

try {
  const { data, error } = await supabase
    .from('featured_campaigns')
    .select('*')
    .eq('active', true)
    .order('created_at', { ascending: false })
    .limit(1);

  if (data && data.length > 0) {
    const activeCampaign = data[0];
    const now = new Date();
    
    // Validar rango de fechas en el servidor
    let isDateValid = true;
    if (activeCampaign.start_date && new Date(activeCampaign.start_date) > now) {
      isDateValid = false;
    }
    if (activeCampaign.end_date && new Date(activeCampaign.end_date) < now) {
      isDateValid = false;
    }
    
    if (isDateValid) {
      campaign = activeCampaign;
    }
  }
} catch (err) {
  console.error("Error al cargar la campaña destacada de Supabase:", err);
}
---

{campaign && (
  <div 
    id={`campaign-banner-${campaign.id}`} 
    data-campaign-id={campaign.id}
    class="relative w-full overflow-hidden bg-gradient-to-r from-[#030612] via-[#091535] to-[#250810] border-b border-gold-bruna/30 text-white py-4 px-6 md:px-12 z-40 transition-all duration-500 max-h-[350px] md:max-h-[200px]"
  >
    <!-- Styles for patriotic effects -->
    <style>
      @keyframes float-star {
        0%, 100% {
          transform: translateY(-50%) translateY(0px) rotate(0deg);
        }
        50% {
          transform: translateY(-50%) translateY(-8px) rotate(3deg);
        }
      }
      .animate-float-star {
        animation: float-star 6s ease-in-out infinite;
      }
      
      /* Shimmer effect for call to action */
      .patria-cta-btn {
        position: relative;
        overflow: hidden;
      }
      .patria-cta-btn::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -60%;
        width: 30%;
        height: 200%;
        background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0) 0%,
          rgba(255, 255, 255, 0.4) 30%,
          rgba(255, 255, 255, 0.8) 50%,
          rgba(255, 255, 255, 0.4) 70%,
          rgba(255, 255, 255, 0) 100%
        );
        transform: rotate(30deg);
        animation: shimmer-effect 3.5s infinite ease-in-out;
      }
      @keyframes shimmer-effect {
        0% {
          left: -60%;
        }
        15%, 100% {
          left: 140%;
        }
      }
    </style>

    <!-- Background Image Layer with opacity mask to merge with colors -->
    <div class="absolute inset-0 z-0 select-none pointer-events-none">
      <div 
        class="absolute right-0 top-0 h-full w-[45%] md:w-[40%] bg-cover bg-no-repeat opacity-40 md:opacity-85"
        style={`
          background-image: url('${campaign.image_url}');
          background-position: center 30%;
          mask-image: linear-gradient(to left, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 100%);
          -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 100%);
        `}
      ></div>
      
      <!-- Estrella solitaria chilena flotante / Símbolo patrio decorativo de fondo -->
      <div class="absolute right-12 md:right-32 top-1/2 -translate-y-1/2 z-10 pointer-events-none select-none opacity-20 md:opacity-35 animate-float-star">
        <svg class="w-16 h-16 md:w-20 md:h-20 filter drop-shadow-[0_0_15px_rgba(255,255,255,0.4)]" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="45" fill="#002B7F" stroke="#ffffff" stroke-width="2"/>
          <path d="M50 15L60.5 37.5H84.5L65 52L75.5 74.5L50 60L24.5 74.5L35 52L15.5 37.5H39.5L50 15Z" fill="#FFFFFF"/>
        </svg>
      </div>

      <!-- Subtle Chilean patriotic stripes at the bottom border -->
      <div class="absolute bottom-0 left-0 w-full h-[2px] flex">
        <div class="h-full w-1/3 bg-blue-600"></div>
        <div class="h-full w-1/3 bg-white"></div>
        <div class="h-full w-1/3 bg-red-600"></div>
      </div>
    </div>

    <!-- Content Container -->
    <div class="relative z-10 max-w-[1400px] mx-auto flex flex-col md:flex-row items-start md:items-center gap-6 pr-10 md:pr-12">
      <div class="flex-1 text-left">
        <div class="flex items-center gap-2.5 mb-1.5 flex-wrap">
          <span class="bg-gradient-to-r from-blue-600 via-white to-red-600 text-white [text-shadow:0_1px_2px_rgba(0,0,0,0.8)] border border-white/20 text-[9px] font-extrabold tracking-widest px-2.5 py-0.5 rounded-sm uppercase font-title animate-pulse shadow-md">
            🇨🇱 Campaña Fiestas Patrias
          </span>
          <span class="text-gold-bruna text-[10px] font-extrabold tracking-widest uppercase font-title">
            ★ Fiestas Patrias 2026 ★
          </span>
        </div>
        <h3 class="text-sm md:text-base font-extrabold font-title tracking-wide text-white uppercase mb-1 leading-tight flex flex-col md:flex-row md:items-center gap-3">
          <span>{campaign.title}</span>
          <a 
            href={campaign.button_url} 
            class="hidden md:inline-block patria-cta-btn bg-gradient-to-r from-blue-600 via-white to-red-600 hover:from-blue-500 hover:via-slate-100 hover:to-red-500 text-white font-extrabold text-[10px] px-5 py-2 rounded border border-white/20 tracking-widest hover:scale-105 transition-all text-center uppercase shadow-lg shadow-red-600/20 active:scale-95 cursor-pointer shrink-0 [text-shadow:0_1px_2px_rgba(0,0,0,0.6)]"
          >
            🇨🇱 {campaign.button_text}
          </a>
        </h3>
        <p class="text-xs text-slate-300 font-light max-w-3xl leading-relaxed">
          {campaign.subtitle}
        </p>
      </div>

      <!-- Mobile Button Only -->
      <div class="flex items-center gap-3 w-full md:hidden shrink-0 mt-2">
        <a 
          href={campaign.button_url} 
          class="w-full patria-cta-btn bg-gradient-to-r from-blue-600 via-white to-red-600 text-white py-3 rounded border border-white/20 font-extrabold text-xs tracking-widest hover:scale-102 transition-all text-center uppercase active:scale-95 cursor-pointer shadow-lg shadow-red-600/20 [text-shadow:0_1px_2px_rgba(0,0,0,0.6)]"
        >
          🇨🇱 {campaign.button_text}
        </a>
      </div>
    </div>

    <!-- Close Button (X) -->
    <button 
      id={`close-banner-${campaign.id}`}
      class="absolute right-3 top-3 md:right-4 md:top-1/2 md:-translate-y-1/2 text-slate-400 hover:text-white p-2 text-base transition-colors z-20 cursor-pointer bg-slate-950/40 hover:bg-slate-900 rounded-full w-8 h-8 flex items-center justify-center border border-white/5"
      aria-label="Cerrar anuncio"
    >
      ✕
    </button>
  </div>
)}

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Buscar todos los banners que tengan id con patron campaign-banner-*
    const banners = document.querySelectorAll('[id^="campaign-banner-"]');
    
    banners.forEach((banner) => {
      const campaignId = banner.getAttribute('data-campaign-id');
      const isClosed = sessionStorage.getItem(`closed_campaign_${campaignId}`);
      
      // Si ya fue cerrado por el usuario, ocultarlo de inmediato
      if (isClosed === 'true') {
        banner.style.display = 'none';
        
        // Ajustar el espaciado del layout si corresponde
        adjustHeaderPadding();
      } else {
        // Asignar el evento del botón de cerrar
        const closeBtn = document.getElementById(`close-banner-${campaignId}`);
        if (closeBtn) {
          closeBtn.addEventListener('click', () => {
            banner.style.maxHeight = '0';
            banner.style.paddingTop = '0';
            banner.style.paddingBottom = '0';
            banner.style.opacity = '0';
            banner.style.border = 'none';
            
            sessionStorage.setItem(`closed_campaign_${campaignId}`, 'true');
            
            // Animación suave de ocultamiento
            setTimeout(() => {
              banner.style.display = 'none';
              adjustHeaderPadding();
            }, 500);
          });
        }
      }
    });

    function adjustHeaderPadding() {
      // Si necesitamos ajustar elementos del DOM dinámicamente
      const main = document.querySelector('main');
      if (main) {
        // Mantiene la altura correcta
      }
    }
  });
</script>
